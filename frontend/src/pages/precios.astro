---
const plans = [
  { name: "Básico", hours: "1h/día", price: "80", pricePen: "300", desc: "Para empezar a probar", features: ["1 agente AI", "Respaldo humano", "Reportes semanales", "3 días gratis de prueba"] },
  { name: "Pro", hours: "4h/día", price: "250", pricePen: "950", desc: "Para negocios en crecimiento", popular: true, features: ["1 agente AI", "Respaldo prioritario", "Reportes diarios", "Personalización avanzada", "3 días gratis de prueba"] },
  { name: "Full", hours: "8h/día", price: "400", pricePen: "1,500", desc: "Máxima productividad", features: ["1 agente dedicado", "Respaldo 24/7", "Reportes tiempo real", "Integración custom", "Soporte prioritario", "3 días gratis de prueba"] },
];
const comparisons = [
  { feature: "Disponibilidad", human: "8h máximo", ai: "24/7" },
  { feature: "Tiempo de respuesta", human: "5-30 min", ai: "< 5 segundos" },
  { feature: "Costo mensual promedio", human: "$500-1,200", ai: "$80-400" },
  { feature: "Conversaciones simultáneas", human: "1", ai: "Ilimitadas" },
  { feature: "Vacaciones / faltas", human: "Sí", ai: "Nunca" },
  { feature: "Capacitación", human: "Semanas", ai: "24 horas" },
  { feature: "Escalabilidad", human: "Contratar más", ai: "Inmediata" },
];
---
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Precios — Agentes AI por WhatsApp desde $80/mes | AGENTES</title>
  <meta name="description" content="Planes y precios de AGENTES: agentes AI con respaldo humano para WhatsApp. Desde $80/mes (≈S/300). Prueba 3 días gratis. Sin contratos."/>
  <meta property="og:title" content="Precios de AGENTES — Desde $80/mes"/>
  <meta property="og:description" content="Agentes AI con respaldo humano para WhatsApp. Planes desde $80/mes. Prueba gratis 3 días."/>
  <meta property="og:type" content="website"/>
  <meta property="og:url" content="https://agentes.luminari.agency/precios"/>
  <meta property="og:image" content="https://agentes.luminari.agency/og.png"/>
  <meta name="twitter:card" content="summary_large_image"/>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
  <link rel="canonical" href="https://agentes.luminari.agency/precios"/>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "AGENTES by Luminari",
    "description": "Agentes AI autónomos con respaldo humano para WhatsApp",
    "url": "https://agentes.luminari.agency/precios",
    "brand": { "@type": "Organization", "name": "Luminari" },
    "offers": plans.map(p => ({
      "@type": "Offer",
      "name": p.name,
      "price": p.price,
      "priceCurrency": "USD",
      "description": p.desc,
      "priceValidUntil": "2026-12-31",
      "availability": "https://schema.org/InStock"
    }))
  })}></script>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet"/>
  <script defer src="https://umami.luminari.agency/script.js" data-website-id="9a5bb1d1-9bc1-417a-8b4b-72b44044d168"></script>
</head>
<body>
  <!-- NAV -->
  <nav>
    <a href="/" class="nav-brand">◆ AGENTES</a>
    <div class="nav-r">
      <a href="/#agentes" class="nav-link">Agentes</a>
      <a href="/#proceso" class="nav-link">Proceso</a>
      <a href="/precios" class="nav-link" style="color:var(--green)">Precios</a>
      <a href="/#faq" class="nav-link">FAQ</a>
      <a href="/#empezar" class="btn-glow nav-cta">Prueba gratis</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero-pricing">
    <span class="tag">Precios</span>
    <h1>Un sueldo fijo. Sin sorpresas.</h1>
    <p class="hero-sub">Sin cobros por token. Sin cargos ocultos. Sin contratos. Cancela cuando quieras.</p>
    <p class="guarantee">✅ 3 días gratis de prueba &nbsp;·&nbsp; 💳 Yape, Plin, VISA, BCP, BBVA</p>
  </section>

  <!-- PLANS -->
  <section class="sec plans-sec">
    <div class="plans-grid">
      {plans.map(p => (
        <div class={`pl-card ${p.popular ? 'pl-pop' : ''}`}>
          {p.popular && <span class="pl-badge">⭐ Más popular</span>}
          <h3>{p.name}</h3>
          <span class="pl-hrs">{p.hours}</span>
          <div class="pl-price"><span class="pl-s">$</span><span class="pl-n">{p.price}</span><span class="pl-p">/mes</span></div>
          <p class="pl-pen">≈ S/{p.pricePen} soles</p>
          <p class="pl-desc">{p.desc}</p>
          <ul>{p.features.map(f => <li>✓ {f}</li>)}</ul>
          <a href="/#empezar" class="btn-glow btn-sm">Empezar gratis</a>
        </div>
      ))}
    </div>
  </section>

  <!-- COMPARISON TABLE -->
  <section class="sec compare-sec">
    <span class="tag">Comparación</span>
    <h2>Empleado humano vs Agente AI</h2>
    <p class="sec-sub">¿Por qué pagar más por menos?</p>
    <div class="compare-table">
      <div class="compare-header">
        <div class="compare-feature">Característica</div>
        <div class="compare-human">👤 Empleado</div>
        <div class="compare-ai">🤖 Agente AI</div>
      </div>
      {comparisons.map(c => (
        <div class="compare-row">
          <div class="compare-feature">{c.feature}</div>
          <div class="compare-human">{c.human}</div>
          <div class="compare-ai">{c.ai}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- INCLUDES -->
  <section class="sec includes-sec">
    <span class="tag">Todos los planes incluyen</span>
    <h2>Todo lo que necesitas, sin extras</h2>
    <div class="includes-grid">
      <div class="inc-card">
        <span class="inc-icon">💬</span>
        <h3>WhatsApp configurado</h3>
        <p>Número dedicado listo para atender desde el día 1.</p>
      </div>
      <div class="inc-card">
        <span class="inc-icon">👤</span>
        <h3>Respaldo humano</h3>
        <p>Si la IA no puede, un humano toma la conversación.</p>
      </div>
      <div class="inc-card">
        <span class="inc-icon">📊</span>
        <h3>Reportes</h3>
        <p>Métricas de conversaciones, respuestas y resultados.</p>
      </div>
      <div class="inc-card">
        <span class="inc-icon">🔧</span>
        <h3>Personalización</h3>
        <p>El agente habla como tu marca. Tono, reglas, horarios.</p>
      </div>
      <div class="inc-card">
        <span class="inc-icon">🚀</span>
        <h3>Activación en 24h</h3>
        <p>Sin semanas de setup. Configuramos y lanzamos rápido.</p>
      </div>
      <div class="inc-card">
        <span class="inc-icon">❌</span>
        <h3>Sin contratos</h3>
        <p>Mes a mes. Cancela cuando quieras, sin penalidades.</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="sec cta-sec">
    <h2>¿Listo para probar?</h2>
    <p>3 días gratis. Sin tarjeta. Sin compromiso.</p>
    <a href="/#empezar" class="btn-glow btn-lg">Empezar prueba gratis →</a>
  </section>

  <!-- FOOTER -->
  <footer>
    <span>◆ AGENTES <span class="by">by Luminari</span></span>
    <span class="copy">© 2026 Luminari. Todos los derechos reservados.</span>
  </footer>

<style>
  :root{--green:#25D366;--green-d:#128C7E;--green-dd:#075E54;--text:#0a0f0d;--text2:#4a5d52;--text3:#8a9e91;--border:#e2ede6;--bg:#fafffe;--font:'Inter',system-ui,sans-serif;--mw:1100px;--r:16px;--r-sm:10px}
  *{margin:0;padding:0;box-sizing:border-box}
  html{scroll-behavior:smooth}
  body{font-family:var(--font);color:var(--text);background:var(--bg);-webkit-font-smoothing:antialiased}
  .tag{display:inline-block;font-size:.7rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--green-d);background:rgba(37,211,102,.08);padding:.25rem .7rem;border-radius:100px;margin-bottom:.75rem}
  .sec{max-width:var(--mw);margin:0 auto;padding:5rem 2rem}
  .sec h2{font-size:clamp(1.7rem,3.5vw,2.3rem);font-weight:800;letter-spacing:-.02em;margin-bottom:.5rem;line-height:1.2}
  .sec-sub{color:var(--text2);font-size:.95rem;margin-bottom:2.5rem}
  .btn-glow{display:inline-block;font-family:var(--font);font-size:.85rem;font-weight:600;color:#fff;background:var(--green);border:1px solid var(--green);padding:.7rem 1.7rem;border-radius:100px;text-decoration:none;transition:all .25s;box-shadow:0 4px 15px rgba(37,211,102,.25)}
  .btn-glow:hover{background:var(--green-d);border-color:var(--green-d);transform:translateY(-1px);box-shadow:0 6px 20px rgba(37,211,102,.35)}
  .btn-lg{font-size:1.1rem;padding:1rem 2.5rem}

  /* NAV */
  nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:1rem 2rem;background:rgba(10,15,13,.85);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border-bottom:1px solid rgba(37,211,102,.08)}
  .nav-brand{font-size:.9rem;font-weight:800;color:#fff;text-decoration:none;letter-spacing:.06em}
  .nav-r{display:flex;align-items:center;gap:1.5rem}
  .nav-link{font-size:.82rem;color:rgba(255,255,255,.7);text-decoration:none;font-weight:500;transition:color .15s}
  .nav-link:hover{color:#fff}
  .nav-cta{font-size:.8rem!important;padding:.5rem 1.2rem!important}

  /* HERO */
  .hero-pricing{padding:8rem 2rem 4rem;text-align:center;max-width:var(--mw);margin:0 auto}
  .hero-pricing h1{font-size:clamp(2rem,4.5vw,3rem);font-weight:900;letter-spacing:-.03em;margin-bottom:1rem}
  .hero-sub{font-size:1.1rem;color:var(--text2);margin-bottom:1rem;max-width:600px;margin-inline:auto}
  .guarantee{font-size:.9rem;color:var(--green-d);font-weight:600}

  /* PLANS */
  .plans-sec{text-align:center;padding-top:2rem}
  .plans-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;text-align:left}
  .pl-card{background:#fff;border:1px solid var(--border);border-radius:var(--r);padding:2rem 1.75rem;position:relative;display:flex;flex-direction:column;transition:all .3s}
  .pl-card:hover{transform:translateY(-4px);box-shadow:0 16px 40px rgba(0,60,30,.06)}
  .pl-pop{border-color:var(--green)!important;box-shadow:0 0 0 1px var(--green),0 8px 30px rgba(37,211,102,.08)!important}
  .pl-badge{position:absolute;top:-10px;left:50%;transform:translateX(-50%);font-size:.68rem;font-weight:700;color:#fff;background:var(--green);padding:.2rem .8rem;border-radius:100px;white-space:nowrap}
  .pl-card h3{font-size:1.1rem;font-weight:800;margin-bottom:.1rem}
  .pl-hrs{font-size:.8rem;color:var(--text3);margin-bottom:1.25rem}
  .pl-price{display:flex;align-items:baseline;gap:.1rem;margin-bottom:.75rem}
  .pl-s{font-size:1rem;font-weight:600;color:var(--text2)}
  .pl-n{font-size:2.8rem;font-weight:900;line-height:1;letter-spacing:-.03em}
  .pl-p{font-size:.82rem;color:var(--text3);margin-left:.15rem}
  .pl-pen{font-size:.75rem;color:var(--text3);margin-top:-.4rem;margin-bottom:.75rem}
  .pl-desc{font-size:.83rem;color:var(--text2);margin-bottom:1.5rem}
  .pl-card ul{list-style:none;display:flex;flex-direction:column;gap:.4rem;margin-bottom:1.5rem;flex:1}
  .pl-card li{font-size:.83rem;color:var(--text2)}
  .btn-sm{font-size:.87rem!important;padding:.7rem 1.5rem!important;display:block;text-align:center;width:100%;border-radius:var(--r-sm)!important}

  /* COMPARISON */
  .compare-sec{text-align:center}
  .compare-table{max-width:700px;margin:0 auto;border:1px solid var(--border);border-radius:var(--r);overflow:hidden}
  .compare-header,.compare-row{display:grid;grid-template-columns:1.5fr 1fr 1fr;gap:0}
  .compare-header{background:#0a0f0d;color:#fff;font-size:.78rem;font-weight:700;letter-spacing:.05em;text-transform:uppercase}
  .compare-header>div,.compare-row>div{padding:.85rem 1rem;border-bottom:1px solid var(--border)}
  .compare-row:last-child>div{border-bottom:none}
  .compare-row:nth-child(even){background:rgba(37,211,102,.02)}
  .compare-feature{font-weight:600;font-size:.85rem}
  .compare-human{font-size:.85rem;color:#dc2626;text-align:center}
  .compare-ai{font-size:.85rem;color:var(--green-d);font-weight:600;text-align:center}

  /* INCLUDES */
  .includes-sec{text-align:center}
  .includes-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem;margin-top:2rem}
  .inc-card{background:#fff;border:1px solid var(--border);border-radius:var(--r);padding:1.75rem;text-align:center;transition:all .3s}
  .inc-card:hover{transform:translateY(-3px);box-shadow:0 12px 32px rgba(0,60,30,.05)}
  .inc-icon{font-size:2rem;display:block;margin-bottom:.75rem}
  .inc-card h3{font-size:.95rem;font-weight:700;margin-bottom:.35rem}
  .inc-card p{font-size:.83rem;color:var(--text2);line-height:1.6}

  /* CTA */
  .cta-sec{text-align:center;padding:5rem 2rem 6rem}
  .cta-sec h2{margin-bottom:.5rem}
  .cta-sec p{color:var(--text2);margin-bottom:1.5rem}

  /* FOOTER */
  footer{border-top:1px solid var(--border);padding:1.5rem 2rem;display:flex;justify-content:space-between;align-items:center;max-width:var(--mw);margin:0 auto;font-size:.82rem;font-weight:700;letter-spacing:.06em;color:var(--green-dd)}
  .by{font-weight:400;color:var(--text3);letter-spacing:0}
  .copy{font-size:.75rem;color:var(--text3);font-weight:400;letter-spacing:0}

  @media(max-width:900px){
    .plans-grid,.includes-grid{grid-template-columns:1fr;max-width:400px;margin-inline:auto}
    .compare-header>div,.compare-row>div{padding:.65rem .6rem;font-size:.78rem}
  }
  @media(max-width:600px){
    nav{padding:.75rem 1.25rem}
    .hero-pricing{padding:6.5rem 1.25rem 3rem}
    .sec{padding:3.5rem 1.25rem}
    footer{flex-direction:column;gap:.5rem;text-align:center}
  }
</style>
</body>
</html>
