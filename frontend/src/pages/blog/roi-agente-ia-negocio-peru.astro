    .comp-card ul{list-style:none;margin-left:0;font-size:.95rem}
    .comp-card ul li{padding:.3rem 0}
    .roi-table{width:100%;border-collapse:collapse;margin:1.5rem 0;font-size:.95rem}
    .roi-table th,.roi-table td{padding:.75rem 1rem;text-align:left;border-bottom:1px solid var(--border)}
    .roi-table th{color:var(--muted);font-weight:600;font-size:.85rem;text-transform:uppercase}
    .roi-table td:last-child{text-align:right;font-weight:700}
    .roi-positive{color:var(--green)}
    .roi-negative{color:#ef4444}
    .scenario{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:2rem;margin:2rem 0}
    .scenario h3{margin-top:0;color:var(--green)}
