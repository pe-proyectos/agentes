    h2{font-size:1.5rem;font-weight:700;margin:2.5rem 0 1rem;letter-spacing:-0.5px}
    h3{font-size:1.2rem;font-weight:600;margin:1.5rem 0 .75rem}
    p{margin-bottom:1.25rem;font-size:1.02rem}
    ul,ol{margin:0 0 1.25rem 1.5rem}li{margin-bottom:.5rem}
    strong{color:#fff}
    .highlight{background:var(--card);border:1px solid var(--border);border-left:3px solid var(--green);border-radius:12px;padding:1.5rem;margin:2rem 0}
    .comparison{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin:2rem 0}
