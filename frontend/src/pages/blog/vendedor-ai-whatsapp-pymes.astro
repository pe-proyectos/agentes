  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    :root{--bg:#0a0a0f;--card:#12121a;--border:#1e1e2e;--green:#25D366;--green-d:#1da851;--text:#e4e4e7;--muted:#71717a}
    body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);line-height:1.8}
    a{color:var(--green);text-decoration:none}a:hover{text-decoration:underline}
    nav{max-width:1100px;margin:0 auto;padding:1.5rem 2rem;display:flex;align-items:center;justify-content:space-between}
    nav a{color:var(--text)}
    .logo{font-weight:800;font-size:1.1rem;letter-spacing:-0.5px}
    .nav-r a{margin-left:1.5rem;font-size:.9rem;color:var(--muted);transition:color .2s}
    .nav-r a:hover{color:var(--green);text-decoration:none}
    .nav-cta{background:var(--green)!important;color:#000!important;padding:.5rem 1.2rem;border-radius:8px;font-weight:600}
    article{max-width:720px;margin:2rem auto 4rem;padding:0 2rem}
    .breadcrumb{font-size:.85rem;color:var(--muted);margin-bottom:2rem}
    .breadcrumb a{color:var(--muted)}.breadcrumb a:hover{color:var(--green)}
    h1{font-size:2.2rem;font-weight:800;letter-spacing:-1px;line-height:1.2;margin-bottom:1rem}
    .meta{color:var(--muted);font-size:.9rem;margin-bottom:2.5rem}
    h2{font-size:1.5rem;font-weight:700;margin:2.5rem 0 1rem;letter-spacing:-0.5px}
    h3{font-size:1.2rem;font-weight:600;margin:1.5rem 0 .75rem}
    p{margin-bottom:1.25rem;font-size:1.02rem}
    ul,ol{margin:0 0 1.25rem 1.5rem}li{margin-bottom:.5rem}
    strong{color:#fff}
    .highlight{background:var(--card);border:1px solid var(--border);border-left:3px solid var(--green);border-radius:12px;padding:1.5rem;margin:2rem 0}
    .case-study{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:2rem;margin:2rem 0}
    .case-study h3{margin-top:0;color:var(--green)}
    .case-study .stats{display:flex;gap:1.5rem;flex-wrap:wrap;margin-top:1rem}
    .case-study .stat{text-align:center}
    .case-study .stat-num{font-size:1.8rem;font-weight:800;color:var(--green)}
    .case-study .stat-label{font-size:.8rem;color:var(--muted)}
    .cta-box{background:linear-gradient(135deg,rgba(37,211,102,.1),rgba(37,211,102,.05));border:1px solid rgba(37,211,102,.3);border-radius:16px;padding:2rem;text-align:center;margin:3rem 0}
    .cta-box h3{color:var(--green);margin-top:0}
    .btn-glow{display:inline-block;background:var(--green);color:#000;font-weight:700;padding:.75rem 2rem;border-radius:10px;text-decoration:none;margin-top:1rem}
    .btn-glow:hover{text-decoration:none;opacity:.9}
    footer{text-align:center;padding:2rem;color:var(--muted);font-size:.85rem;border-top:1px solid var(--border)}
  </style>
</head>
<body>
  <nav>
    <a href="/" class="logo">◆ AGENTES</a>
