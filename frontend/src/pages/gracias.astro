import WhatsAppFloat from "../components/WhatsAppFloat.astro";
---
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>¡Gracias! Tu solicitud fue recibida — AGENTES</title>
  <meta name="description" content="Tu solicitud fue recibida. Te contactaremos en menos de 24 horas para activar tu agente AI."/>
  <meta name="robots" content="noindex, nofollow"/>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet"/>
  <script defer src="https://umami.luminari.agency/script.js" data-website-id="9a5bb1d1-9bc1-417a-8b4b-72b44044d168"></script>

  <!-- META PIXEL CONVERSION TRACKING -->
  <!-- TODO: Add Meta Pixel base code here -->
  <!-- <script>fbq('track', 'Lead');</script> -->

  <!-- GOOGLE ADS CONVERSION TRACKING -->
  <!-- TODO: Add Google Ads gtag conversion snippet here -->
  <!-- <script>gtag('event', 'conversion', {'send_to': 'AW-XXXXXXXXX/XXXXXXXXX'});</script> -->
</head>
<body>
  <nav>
    <a href="/" class="nav-brand">◆ AGENTES</a>
    <div class="nav-r">
      <a href="/" class="nav-link">Inicio</a>
      <a href="/precios" class="nav-link">Precios</a>
    </div>
  </nav>

  <main class="thank-you">
    <div class="ty-card">
      <div class="ty-icon">🎉</div>
      <h1>¡Solicitud recibida!</h1>
      <p class="ty-sub">Gracias por confiar en nosotros. Tu agente AI está a punto de cobrar vida.</p>

      <div class="ty-steps">
        <h2>¿Qué sigue?</h2>
        <div class="step">
          <span class="step-num">1</span>
          <div>
            <strong>Te contactamos en menos de 24h</strong>
            <p>Un especialista revisará tu solicitud y te escribirá por WhatsApp o email.</p>
          </div>
        </div>
        <div class="step">
          <span class="step-num">2</span>
          <div>
            <strong>Configuramos tu agente</strong>
            <p>Lo personalizamos con tu información, tono y reglas de negocio.</p>
          </div>
        </div>
        <div class="step">
          <span class="step-num">3</span>
          <div>
            <strong>¡Listo para trabajar!</strong>
            <p>Tu agente empieza a atender clientes por WhatsApp. 3 días gratis.</p>
          </div>
        </div>
      </div>

      <div class="ty-wa">
        <p>¿Quieres activar tu prueba más rápido?</p>
        <a href="https://wa.me/51987654321?text=Hola!%20Acabo%20de%20registrarme%20en%20AGENTES%20para%20una%20prueba%20gratis.%20%F0%9F%9A%80" target="_blank" rel="noopener" class="btn-glow btn-wa">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="vertical-align:middle;margin-right:6px"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.612.616l4.532-1.474A11.943 11.943 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75c-2.17 0-4.207-.69-5.87-1.882l-.42-.312-2.689.875.891-2.633-.345-.445A9.722 9.722 0 012.25 12c0-5.385 4.365-9.75 9.75-9.75S21.75 6.615 21.75 12s-4.365 9.75-9.75 9.75z"/></svg>
          Escribir por WhatsApp
        </a>
      </div>

      <a href="/" class="ty-back">← Volver al inicio</a>
    </div>
  </main>

  <footer>
    <span>◆ AGENTES <span class="by">by Luminari</span></span>
    <span class="copy">© 2026 Luminari. Todos los derechos reservados.</span>
  </footer>

<style>
  :root{--green:#25D366;--green-d:#128C7E;--green-dd:#075E54;--text:#0a0f0d;--text2:#4a5d52;--text3:#8a9e91;--border:#e2ede6;--bg:#fafffe;--font:'Inter',system-ui,sans-serif;--mw:1100px;--r:16px;--r-sm:10px}
  *{margin:0;padding:0;box-sizing:border-box}
  html{scroll-behavior:smooth}
  body{font-family:var(--font);color:var(--text);background:var(--bg);-webkit-font-smoothing:antialiased;min-height:100vh;display:flex;flex-direction:column}

  nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:1rem 2rem;background:rgba(10,15,13,.85);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border-bottom:1px solid rgba(37,211,102,.08)}
  .nav-brand{font-size:.9rem;font-weight:800;color:#fff;text-decoration:none;letter-spacing:.06em}
  .nav-r{display:flex;align-items:center;gap:1.5rem}
  .nav-link{font-size:.82rem;color:rgba(255,255,255,.7);text-decoration:none;font-weight:500;transition:color .15s}
  .nav-link:hover{color:#fff}

  .thank-you{flex:1;display:flex;align-items:center;justify-content:center;padding:7rem 2rem 4rem}
  .ty-card{max-width:600px;width:100%;background:#fff;border:1px solid var(--border);border-radius:var(--r);padding:3rem;text-align:center;box-shadow:0 4px 20px rgba(0,60,30,.03)}
  .ty-icon{font-size:4rem;margin-bottom:1rem}
  .ty-card h1{font-size:clamp(1.5rem,3vw,2rem);font-weight:900;letter-spacing:-.02em;margin-bottom:.5rem}
  .ty-sub{color:var(--text2);font-size:.95rem;line-height:1.6;margin-bottom:2rem}

  .ty-steps{text-align:left;margin-bottom:2rem}
  .ty-steps h2{font-size:1rem;font-weight:700;margin-bottom:1rem;text-align:center;color:var(--green-d)}
  .step{display:flex;gap:1rem;align-items:flex-start;margin-bottom:1rem}
  .step-num{flex-shrink:0;width:2rem;height:2rem;background:var(--green);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.85rem;font-weight:700}
  .step strong{font-size:.9rem;display:block;margin-bottom:.15rem}
  .step p{font-size:.82rem;color:var(--text2);line-height:1.5}

  .ty-wa{background:rgba(37,211,102,.05);border:1px solid rgba(37,211,102,.15);border-radius:var(--r-sm);padding:1.5rem;margin-bottom:1.5rem}
  .ty-wa p{font-size:.88rem;color:var(--text2);margin-bottom:.75rem}
  .btn-glow{display:inline-block;font-family:var(--font);font-size:.85rem;font-weight:600;color:#fff;background:var(--green);border:1px solid var(--green);padding:.7rem 1.7rem;border-radius:100px;text-decoration:none;transition:all .25s;box-shadow:0 4px 15px rgba(37,211,102,.25)}
  .btn-glow:hover{background:var(--green-d);border-color:var(--green-d);transform:translateY(-1px);box-shadow:0 6px 20px rgba(37,211,102,.35)}
  .btn-wa{font-size:1rem;padding:.85rem 2rem}

  .ty-back{display:inline-block;font-size:.85rem;color:var(--text3);text-decoration:none;transition:color .15s}
  .ty-back:hover{color:var(--green-d)}

  footer{border-top:1px solid var(--border);padding:1.5rem 2rem;display:flex;justify-content:space-between;align-items:center;max-width:var(--mw);margin:0 auto;font-size:.82rem;font-weight:700;letter-spacing:.06em;color:var(--green-dd);width:100%}
  .by{font-weight:400;color:var(--text3);letter-spacing:0}
  .copy{font-size:.75rem;color:var(--text3);font-weight:400;letter-spacing:0}

  @media(max-width:600px){
    nav{padding:.75rem 1.25rem}
    .thank-you{padding:5.5rem 1.25rem 2rem}
    .ty-card{padding:2rem 1.5rem}
    footer{flex-direction:column;gap:.5rem;text-align:center}
  }
</style>
<WhatsAppFloat />
</body>
</html>
