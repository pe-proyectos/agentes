---
// Landing page - AGENTES by Luminari
---
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AGENTES - Tu empleado digital que ejecuta</title>
  <meta name="description" content="Imagina un empleado que nunca descansa, que sabe programar, diseñar y resolver problemas. Y lo manejas todo desde WhatsApp." />
  <meta property="og:title" content="AGENTES - Tu empleado digital que ejecuta" />
  <meta property="og:description" content="Un empleado AI que hace cosas reales por tu negocio." />
  <meta property="og:image" content="/og.png" />
  <meta property="og:type" content="website" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <script defer src="https://umami.luminari.agency/script.js" data-website-id="9a5bb1d1-9bc1-417a-8b4b-72b44044d168"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --green: #25D366;
      --green-light: #e8faf0;
      --green-lighter: #f0fdf5;
      --green-medium: #b8f0d0;
      --white: #ffffff;
      --gray-50: #f9fafb;
      --gray-100: #f3f4f6;
      --gray-200: #e5e7eb;
      --gray-400: #9ca3af;
      --gray-500: #6b7280;
      --gray-600: #4b5563;
      --gray-700: #374151;
      --gray-800: #1f2937;
      --gray-900: #111827;
      --radius: 16px;
      --radius-sm: 12px;
    }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', -apple-system, sans-serif;
      background: var(--white);
      color: var(--gray-800);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }
    .container { max-width: 1120px; margin: 0 auto; padding: 0 24px; }

    /* SCROLL REVEAL */
    .reveal {
      opacity: 0;
      transform: translateY(40px);
      transition: opacity 0.8s ease, transform 0.8s ease;
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* NAV */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      background: rgba(255,255,255,0.8);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--gray-200);
    }
    nav .inner {
      max-width: 1120px; margin: 0 auto; padding: 0 24px;
      display: flex; align-items: center; justify-content: space-between;
      height: 64px;
    }
    .logo { font-weight: 800; font-size: 1.15rem; color: var(--gray-900); text-decoration: none; letter-spacing: -0.02em; }
    .logo span { color: var(--green); }
    nav .links { display: flex; align-items: center; gap: 28px; }
    nav .links a { text-decoration: none; color: var(--gray-600); font-weight: 500; font-size: 0.9rem; transition: color .2s; }
    nav .links a:hover { color: var(--gray-900); }
    nav .links .cta-nav {
      background: var(--green); color: white; padding: 8px 20px; border-radius: 100px;
      font-weight: 600; font-size: 0.85rem; transition: transform .2s, box-shadow .2s;
    }
    nav .links .cta-nav:hover { transform: translateY(-1px); box-shadow: 0 4px 16px rgba(37,211,102,0.35); color: white; }

    /* HERO */
    .hero {
      padding: 140px 0 80px;
      background: linear-gradient(170deg, var(--white) 0%, var(--green-lighter) 50%, var(--green-light) 100%);
      position: relative; overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute; top: -200px; right: -200px;
      width: 600px; height: 600px; border-radius: 50%;
      background: radial-gradient(circle, rgba(37,211,102,0.08) 0%, transparent 70%);
    }
    .hero .container { text-align: center; position: relative; }
    .hero .badge {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(37,211,102,0.1); border: 1px solid rgba(37,211,102,0.2);
      padding: 6px 16px; border-radius: 100px; font-size: 0.82rem;
      font-weight: 600; color: #15803d; margin-bottom: 24px;
    }
    .hero .badge .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--green); animation: pulse 2s infinite; }
    @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.4; } }
    .hero h1 {
      font-size: clamp(2.2rem, 5vw, 3.8rem);
      font-weight: 900; line-height: 1.1; letter-spacing: -0.03em;
      color: var(--gray-900); max-width: 780px; margin: 0 auto 20px;
    }
    .hero h1 em { font-style: normal; color: var(--green); }
    .hero p {
      font-size: clamp(1rem, 2vw, 1.2rem);
      color: var(--gray-600); max-width: 560px; margin: 0 auto 36px;
      line-height: 1.7;
    }
    .hero .cta-btn {
      display: inline-flex; align-items: center; gap: 10px;
      background: var(--green); color: white; padding: 16px 36px;
      border-radius: 100px; font-weight: 700; font-size: 1.05rem;
      text-decoration: none; transition: all .3s;
      box-shadow: 0 4px 24px rgba(37,211,102,0.3);
    }
    .hero .cta-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(37,211,102,0.4); }
    .hero .cta-btn svg { width: 20px; height: 20px; }

    /* CAPABILITIES CAROUSEL */
    .capabilities { padding: 100px 0; background: var(--white); }
    .section-label {
      text-align: center; font-size: 0.8rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.12em; color: var(--green);
      margin-bottom: 12px;
    }
    .section-title {
      text-align: center; font-size: clamp(1.6rem, 3.5vw, 2.4rem);
      font-weight: 800; color: var(--gray-900); margin-bottom: 16px;
      letter-spacing: -0.02em;
    }
    .section-sub {
      text-align: center; font-size: 1.05rem; color: var(--gray-500);
      max-width: 520px; margin: 0 auto 56px;
    }

    .carousel-wrapper {
      position: relative;
      max-width: 680px;
      margin: 0 auto;
    }
    .carousel-track {
      position: relative;
      overflow: hidden;
      border-radius: var(--radius);
    }
    .carousel-slide {
      display: none;
      align-items: center;
      gap: 40px;
      padding: 48px 40px;
      background: rgba(255,255,255,0.7);
      backdrop-filter: blur(16px);
      border: 1px solid rgba(37,211,102,0.15);
      border-radius: var(--radius);
      animation: fadeIn 0.5s ease;
    }
    .carousel-slide.active {
      display: flex;
    }
    .carousel-slide .slide-icon {
      flex-shrink: 0;
      width: 120px; height: 120px;
      background: var(--green-light);
      border-radius: 20px;
      display: flex; align-items: center; justify-content: center;
    }
    .carousel-slide .slide-icon svg {
      width: 56px; height: 56px;
      color: var(--green);
    }
    .carousel-slide .slide-content { flex: 1; }
    .carousel-slide .slide-content h3 {
      font-size: 1.4rem; font-weight: 800; color: var(--gray-900); margin-bottom: 12px;
    }
    .carousel-slide .slide-content p {
      font-size: 1rem; color: var(--gray-600); line-height: 1.7;
    }

    .carousel-arrows {
      position: absolute;
      top: 50%; left: -20px; right: -20px;
      display: flex; justify-content: space-between;
      transform: translateY(-50%);
      pointer-events: none;
      z-index: 2;
    }
    .carousel-arrow {
      pointer-events: all;
      width: 44px; height: 44px;
      border-radius: 50%;
      background: var(--white);
      border: 1px solid var(--gray-200);
      display: flex; align-items: center; justify-content: center;
      cursor: pointer;
      transition: all 0.2s;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }
    .carousel-arrow:hover {
      border-color: var(--green);
      box-shadow: 0 4px 16px rgba(37,211,102,0.2);
    }
    .carousel-arrow svg { width: 18px; height: 18px; color: var(--gray-700); }

    .carousel-dots {
      display: flex; justify-content: center; gap: 8px; margin-top: 24px;
    }
    .carousel-dot {
      width: 10px; height: 10px;
      border-radius: 50%;
      background: var(--gray-200);
      border: none;
      cursor: pointer;
      transition: all 0.3s;
    }
    .carousel-dot.active {
      background: var(--green);
      transform: scale(1.2);
    }

    /* FORM */
    .form-section { padding: 100px 0; background: var(--green-lighter); }
    .form-wrapper {
      max-width: 560px; margin: 0 auto;
      background: rgba(255,255,255,0.8);
      backdrop-filter: blur(20px);
      border: 1px solid var(--gray-200);
      border-radius: 20px;
      padding: 40px 36px;
      box-shadow: 0 12px 48px rgba(0,0,0,0.06);
    }
    .progress-bar { display: flex; gap: 8px; margin-bottom: 36px; }
    .progress-bar .bar {
      flex: 1; height: 4px; border-radius: 100px;
      background: var(--gray-200); transition: background .4s;
    }
    .progress-bar .bar.active { background: var(--green); }

    .form-step { display: none; animation: fadeIn .4s ease; }
    .form-step.active { display: block; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }

    .form-step h3 { font-size: 1.3rem; font-weight: 800; color: var(--gray-900); margin-bottom: 8px; }
    .form-step .hint { font-size: 0.88rem; color: var(--gray-500); margin-bottom: 28px; }

    label.field { display: block; margin-bottom: 16px; }
    label.field span { display: block; font-size: 0.82rem; font-weight: 600; color: var(--gray-700); margin-bottom: 6px; }
    input[type="text"], input[type="email"], input[type="tel"] {
      width: 100%; padding: 14px 16px; border: 1.5px solid var(--gray-200);
      border-radius: var(--radius-sm); font-size: 0.95rem;
      font-family: inherit; transition: border-color .2s;
      background: var(--white); color: var(--gray-900);
    }
    input:focus { outline: none; border-color: var(--green); box-shadow: 0 0 0 3px rgba(37,211,102,0.15); }

    .checkbox-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .checkbox-item {
      display: flex; align-items: center; gap: 10px;
      padding: 12px 14px; border: 1.5px solid var(--gray-200);
      border-radius: var(--radius-sm); cursor: pointer;
      transition: all .2s; font-size: 0.88rem; font-weight: 500; color: var(--gray-700);
    }
    .checkbox-item:hover { border-color: var(--green-medium); }
    .checkbox-item.checked { border-color: var(--green); background: var(--green-light); color: #15803d; }
    .checkbox-item input { display: none; }

    .form-nav { display: flex; gap: 12px; margin-top: 28px; }
    .btn-back {
      flex: 1; padding: 14px; border-radius: 100px;
      border: 1.5px solid var(--gray-200); background: var(--white);
      font-family: inherit; font-weight: 600; font-size: 0.95rem;
      color: var(--gray-600); cursor: pointer; transition: all .2s;
    }
    .btn-back:hover { border-color: var(--gray-400); }
    .btn-next, .btn-submit {
      flex: 2; padding: 14px; border-radius: 100px;
      border: none; background: var(--green);
      font-family: inherit; font-weight: 700; font-size: 0.95rem;
      color: white; cursor: pointer; transition: all .2s;
    }
    .btn-next:hover, .btn-submit:hover { box-shadow: 0 4px 16px rgba(37,211,102,0.35); transform: translateY(-1px); }
    .btn-next:disabled, .btn-submit:disabled { opacity: 0.5; cursor: not-allowed; transform: none; box-shadow: none; }

    .success-msg {
      display: none; text-align: center; padding: 20px;
    }
    .success-msg.show { display: block; animation: fadeIn .5s ease; }
    .success-msg h3 { font-size: 1.3rem; font-weight: 800; color: var(--gray-900); margin-bottom: 8px; }
    .success-msg p { color: var(--gray-500); font-size: 0.95rem; }

    /* FAQ */
    .faq { padding: 100px 0; background: var(--white); }
    .faq-list { max-width: 700px; margin: 0 auto; display: flex; flex-direction: column; gap: 12px; }
    .faq-item {
      background: rgba(255,255,255,0.7);
      backdrop-filter: blur(16px);
      border: 1px solid var(--gray-200);
      border-radius: var(--radius);
      overflow: hidden;
      transition: border-color 0.3s;
    }
    .faq-item:hover { border-color: var(--green-medium); }
    .faq-question {
      display: flex; align-items: center; justify-content: space-between;
      padding: 20px 24px;
      cursor: pointer;
      font-weight: 600; font-size: 1rem; color: var(--gray-900);
      background: none; border: none; width: 100%;
      font-family: inherit; text-align: left;
    }
    .faq-question .faq-toggle {
      width: 28px; height: 28px; border-radius: 50%;
      background: var(--green-light);
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
      font-size: 1.2rem; font-weight: 700; color: var(--green);
      transition: transform 0.3s;
    }
    .faq-item.open .faq-toggle { transform: rotate(45deg); }
    .faq-answer {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.4s ease, padding 0.4s ease;
      padding: 0 24px;
    }
    .faq-item.open .faq-answer {
      max-height: 200px;
      padding: 0 24px 20px;
    }
    .faq-answer p { font-size: 0.92rem; color: var(--gray-600); line-height: 1.7; }

    /* FOOTER */
    footer {
      padding: 40px 0; text-align: center;
      border-top: 1px solid var(--gray-200);
      color: var(--gray-400); font-size: 0.82rem;
    }
    footer a { color: var(--green); text-decoration: none; font-weight: 600; }

    /* MOBILE */
    @media (max-width: 640px) {
      .hero { padding: 120px 0 60px; }
      .form-wrapper { padding: 28px 20px; }
      .checkbox-grid { grid-template-columns: 1fr; }
      nav .links a:not(.cta-nav) { display: none; }
      .carousel-slide { flex-direction: column; gap: 20px; padding: 32px 24px; }
      .carousel-slide .slide-icon { width: 80px; height: 80px; }
      .carousel-slide .slide-icon svg { width: 40px; height: 40px; }
      .carousel-arrows { left: -8px; right: -8px; }
      .carousel-arrow { width: 36px; height: 36px; }
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="inner">
    <a href="/" class="logo"><span>&#9670;</span> AGENTES</a>
    <div class="links">
      <a href="/blog">Blog</a>
      <a href="#empezar" class="cta-nav">Empezar</a>
    </div>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="container">
    <div class="badge"><div class="dot"></div> Disponible ahora</div>
    <h1>Tu negocio merece un <em>empleado digital</em> que ejecute</h1>
    <p>Imagina un empleado que nunca descansa, que sabe programar, diseñar y resolver problemas. Y lo manejas todo desde WhatsApp.</p>
    <a href="#empezar" class="cta-btn">
      Quiero mi agente
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </a>
  </div>
</section>

<!-- CAPABILITIES CAROUSEL -->
<section class="capabilities">
  <div class="container">
    <div class="section-label reveal">Capacidades</div>
    <h2 class="section-title reveal">Todo lo que tu agente puede hacer</h2>
    <p class="section-sub reveal">Un empleado que aprende tu negocio y trabaja sin parar, de verdad.</p>
    <div class="carousel-wrapper reveal">
      <div class="carousel-track">
        <!-- Slide 1: Contabilidad -->
        <div class="carousel-slide active">
          <div class="slide-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 2v20l2-1 2 1 2-1 2 1 2-1 2 1 2-1 2 1V2l-2 1-2-1-2 1-2-1-2 1-2-1-2 1Z"/><path d="M8 7h8"/><path d="M8 11h8"/><path d="M8 15h5"/></svg>
          </div>
          <div class="slide-content">
            <h3>Contabilidad</h3>
            <p>Tu agente registra cada gasto, organiza tus finanzas y genera reportes claros. T&uacute; solo pides y &eacute;l se encarga de los n&uacute;meros.</p>
          </div>
        </div>
        <!-- Slide 2: Diseño gráfico -->
        <div class="carousel-slide">
          <div class="slide-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
          </div>
          <div class="slide-content">
            <h3>Diseño gráfico</h3>
            <p>Necesitas un post para redes, un flyer o material visual? Solo dile qué quieres y lo crea en minutos. Nada de esperar días.</p>
          </div>
        </div>
        <!-- Slide 3: Desarrollo web -->
        <div class="carousel-slide">
          <div class="slide-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/><line x1="14" y1="4" x2="10" y2="20"/></svg>
          </div>
          <div class="slide-content">
            <h3>Desarrollo web</h3>
            <p>Tu agente puede construir páginas web, paneles internos y herramientas a medida. Como tener un programador disponible las 24 horas.</p>
          </div>
        </div>
        <!-- Slide 4: Agendar citas -->
        <div class="carousel-slide">
          <div class="slide-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="m9 16 2 2 4-4"/></svg>
          </div>
          <div class="slide-content">
            <h3>Agendar citas</h3>
            <p>Tu agente maneja el calendario por ti. Agenda, confirma y recuerda las citas a tus clientes de forma automática.</p>
          </div>
        </div>
        <!-- Slide 5: Atención al cliente -->
        <div class="carousel-slide">
          <div class="slide-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M8 10h8"/><path d="M8 14h4"/></svg>
          </div>
          <div class="slide-content">
            <h3>Atención al cliente</h3>
            <p>Responde dudas, resuelve problemas y da seguimiento a cada cliente. Siempre amable, siempre disponible, sin importar la hora.</p>
          </div>
        </div>
        <!-- Slide 6: Redes sociales -->
        <div class="carousel-slide">
          <div class="slide-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
          </div>
          <div class="slide-content">
            <h3>Redes sociales</h3>
            <p>Planifica tu contenido, redacta publicaciones y te dice qué está funcionando. Tu presencia en redes, en piloto automático.</p>
          </div>
        </div>
        <!-- Slide 7: Reportes y métricas -->
        <div class="carousel-slide">
          <div class="slide-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/><line x1="2" y1="20" x2="22" y2="20"/></svg>
          </div>
          <div class="slide-content">
            <h3>Reportes y métricas</h3>
            <p>Pide un resumen de tu negocio y lo tienes al instante. Ventas, gastos, tendencias... todo claro y visual.</p>
          </div>
        </div>
        <!-- Slide 8: Ventas -->
        <div class="carousel-slide">
          <div class="slide-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
          </div>
          <div class="slide-content">
            <h3>Ventas</h3>
            <p>Tu agente contacta prospectos, envía cotizaciones y hace seguimiento hasta cerrar la venta. Como tu mejor vendedor, pero que nunca para.</p>
          </div>
        </div>
      </div>
      <div class="carousel-arrows">
        <button class="carousel-arrow" id="carousel-prev">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </button>
        <button class="carousel-arrow" id="carousel-next">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </button>
      </div>
      <div class="carousel-dots" id="carousel-dots"></div>
    </div>
  </div>
</section>

<!-- FORM -->
<section class="form-section" id="empezar">
  <div class="container">
    <div class="section-label reveal">Empieza hoy</div>
    <h2 class="section-title reveal">Cuéntanos sobre tu negocio</h2>
    <p class="section-sub reveal">Solo 3 pasos rápidos y nos ponemos en contacto contigo.</p>
    <div class="form-wrapper reveal">
      <div class="progress-bar">
        <div class="bar active" data-step="1"></div>
        <div class="bar" data-step="2"></div>
        <div class="bar" data-step="3"></div>
      </div>

      <form id="onboarding-form">
        <!-- Step 1 -->
        <div class="form-step active" data-step="1">
          <h3>¿Cómo se llama tu negocio?</h3>
          <p class="hint">Tu marca, empresa o proyecto. Lo que sea.</p>
          <label class="field">
            <span>Nombre del negocio</span>
            <input type="text" id="business-name" placeholder="Ej: Clínica San Martín" required />
          </label>
          <div class="form-nav">
            <button type="button" class="btn-next" id="btn-step1">Continuar</button>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="form-step" data-step="2">
          <h3>¿En qué áreas necesitas ayuda?</h3>
          <p class="hint">Elige todas las que necesites.</p>
          <div class="checkbox-grid">
            <label class="checkbox-item"><input type="checkbox" name="areas" value="ventas" /> Ventas</label>
            <label class="checkbox-item"><input type="checkbox" name="areas" value="soporte" /> Soporte</label>
            <label class="checkbox-item"><input type="checkbox" name="areas" value="contabilidad" /> Contabilidad</label>
            <label class="checkbox-item"><input type="checkbox" name="areas" value="diseño" /> Diseño</label>
            <label class="checkbox-item"><input type="checkbox" name="areas" value="desarrollo-web" /> Desarrollo web</label>
            <label class="checkbox-item"><input type="checkbox" name="areas" value="redes-sociales" /> Redes sociales</label>
            <label class="checkbox-item"><input type="checkbox" name="areas" value="citas" /> Agendar citas</label>
            <label class="checkbox-item"><input type="checkbox" name="areas" value="otro" /> Otro</label>
          </div>
          <div class="form-nav">
            <button type="button" class="btn-back" id="btn-back2">Atrás</button>
            <button type="button" class="btn-next" id="btn-step2">Continuar</button>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="form-step" data-step="3">
          <h3>¿Cómo te contactamos?</h3>
          <p class="hint">Te escribiremos para poner tu agente a trabajar.</p>
          <label class="field">
            <span>Correo electrónico</span>
            <input type="email" id="email" placeholder="tu@empresa.com" required />
          </label>
          <label class="field">
            <span>WhatsApp</span>
            <input type="tel" id="whatsapp" placeholder="+51 999 999 999" required />
          </label>
          <div class="form-nav">
            <button type="button" class="btn-back" id="btn-back3">Atrás</button>
            <button type="submit" class="btn-submit">Empezar ahora</button>
          </div>
        </div>
      </form>

      <div class="success-msg" id="success">
        <h3>¡Listo!</h3>
        <p>Recibimos tu solicitud. Te contactaremos pronto para poner tu agente a trabajar.</p>
      </div>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="faq">
  <div class="container">
    <div class="section-label reveal">Preguntas frecuentes</div>
    <h2 class="section-title reveal">¿Tienes dudas? Aquí las resolvemos</h2>
    <p class="section-sub reveal">Las preguntas más comunes sobre nuestros agentes digitales.</p>
    <div class="faq-list reveal">
      <div class="faq-item">
        <button class="faq-question">¿Qué es un agente digital? <span class="faq-toggle">+</span></button>
        <div class="faq-answer"><p>Es como un empleado real, pero potenciado con inteligencia artificial. No solo responde preguntas: ejecuta tareas concretas como agendar citas, crear diseños, llevar cuentas y atender clientes. Trabaja las 24 horas y aprende cada día más sobre tu negocio.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-question">¿Cómo se comunica el agente? <span class="faq-toggle">+</span></button>
        <div class="faq-answer"><p>Principalmente por WhatsApp, que es lo más práctico. Pero también puede trabajar por email o desde la web, según lo que necesites.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-question">¿Necesito conocimientos técnicos? <span class="faq-toggle">+</span></button>
        <div class="faq-answer"><p>Para nada. Nosotros nos encargamos de todo: la configuración, el entrenamiento del agente y la puesta en marcha. Tú solo tienes que decirle qué necesitas.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-question">¿Cuánto tiempo toma configurarlo? <span class="faq-toggle">+</span></button>
        <div class="faq-answer"><p>Menos de 48 horas. En cuanto nos cuentes sobre tu negocio, ponemos a tu agente a trabajar lo antes posible.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-question">¿Puedo cancelar en cualquier momento? <span class="faq-toggle">+</span></button>
        <div class="faq-answer"><p>Sí, sin contratos ni compromisos a largo plazo. Si en algún momento quieres pausar o cancelar, lo haces sin problema.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-question">¿Qué pasa si el agente no sabe resolver algo? <span class="faq-toggle">+</span></button>
        <div class="faq-answer"><p>Nuestro equipo técnico interviene de inmediato. Resolvemos el caso y le enseñamos al agente para que la próxima vez lo maneje solo. Así va mejorando con el tiempo.</p></div>
      </div>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <div class="container">
    <a href="/">&#9670; AGENTES</a> by <a href="https://luminari.agency/" target="_blank" rel="noopener">Luminari Agency</a> &copy; 2026
  </div>
</footer>

<script>
  // Form multi-step
  function goToStep(n) {
    document.querySelectorAll('.form-step').forEach(function(s) { s.classList.remove('active'); });
    document.querySelector('.form-step[data-step="' + n + '"]').classList.add('active');
    document.querySelectorAll('.progress-bar .bar').forEach(function(b) {
      b.classList.toggle('active', parseInt(b.dataset.step) <= n);
    });
  }

  document.getElementById('btn-step1').addEventListener('click', function() { goToStep(2); });
  document.getElementById('btn-step2').addEventListener('click', function() { goToStep(3); });
  document.getElementById('btn-back2').addEventListener('click', function() { goToStep(1); });
  document.getElementById('btn-back3').addEventListener('click', function() { goToStep(2); });

  // Checkbox toggle
  document.querySelectorAll('.checkbox-item').forEach(function(item) {
    item.addEventListener('click', function() {
      var cb = item.querySelector('input');
      setTimeout(function() { item.classList.toggle('checked', cb.checked); }, 0);
    });
  });

  // Form submit
  document.getElementById('onboarding-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    var btn = e.target.querySelector('.btn-submit');
    btn.disabled = true;
    btn.textContent = 'Enviando...';
    var areas = Array.from(document.querySelectorAll('input[name="areas"]:checked')).map(function(c) { return c.value; });
    try {
      await fetch('https://agentes-api.luminari.agency/api/waitlist', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          businessName: document.getElementById('business-name').value,
          areas: areas,
          email: document.getElementById('email').value,
          whatsapp: document.getElementById('whatsapp').value,
        })
      });
    } catch (err) {}
    document.getElementById('onboarding-form').style.display = 'none';
    document.querySelector('.progress-bar').style.display = 'none';
    document.getElementById('success').classList.add('show');
  });

  // Carousel
  (function() {
    var slides = document.querySelectorAll('.carousel-slide');
    var dotsContainer = document.getElementById('carousel-dots');
    var current = 0;
    var timer;

    // Create dots
    slides.forEach(function(_, i) {
      var dot = document.createElement('button');
      dot.className = 'carousel-dot' + (i === 0 ? ' active' : '');
      dot.addEventListener('click', function() { goTo(i); resetTimer(); });
      dotsContainer.appendChild(dot);
    });

    function goTo(n) {
      slides[current].classList.remove('active');
      dotsContainer.children[current].classList.remove('active');
      current = (n + slides.length) % slides.length;
      slides[current].classList.add('active');
      dotsContainer.children[current].classList.add('active');
    }

    function resetTimer() {
      clearInterval(timer);
      timer = setInterval(function() { goTo(current + 1); }, 3000);
    }

    document.getElementById('carousel-prev').addEventListener('click', function() { goTo(current - 1); resetTimer(); });
    document.getElementById('carousel-next').addEventListener('click', function() { goTo(current + 1); resetTimer(); });

    resetTimer();
  })();

  // FAQ accordion
  document.querySelectorAll('.faq-question').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var item = btn.parentElement;
      var wasOpen = item.classList.contains('open');
      document.querySelectorAll('.faq-item').forEach(function(i) { i.classList.remove('open'); });
      if (!wasOpen) item.classList.add('open');
    });
  });

  // Scroll reveal
  (function() {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });
    document.querySelectorAll('.reveal').forEach(function(el) { observer.observe(el); });
  })();
</script>

</body>
</html>
