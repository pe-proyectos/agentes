    navMenu.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
      navMenu.classList.remove('open');
      navToggle.setAttribute('aria-expanded', 'false');
    }));

    // === Form ===
    const form = document.getElementById('wl-form') as HTMLFormElement;
    const msg = document.getElementById('form-msg')!;
    const btn = document.getElementById('sub-btn') as HTMLButtonElement;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      btn.disabled = true; btn.textContent = 'Procesando...';
      msg.textContent = ''; msg.className = 'form-msg';
      try {
        const data = Object.fromEntries(new FormData(form));
        const r = await fetch('https://agentes-api.luminari.agency/api/waitlist', {
          method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(data)
        });
        if (r.ok) {
          window.umami?.track('waitlist-submit', { agentType: data.agentType });
          const userName = data.name;
          const userPhone = data.phone?.toString().replace(/\D/g, '') || '';
          form.reset();
          // Show success state
          form.style.display = 'none';
          const successDiv = document.createElement('div');
          successDiv.className = 'form-success';
          successDiv.innerHTML = `
            <div class="success-icon">🎉</div>
