---
// Landing page - AGENTES by Luminari
---
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AGENTES — Tu empleado digital que ejecuta</title>
  <meta name="description" content="No es un chatbot. Es un empleado digital que programa, diseña, administra y ejecuta por ti. WhatsApp es solo el canal." />
  <meta property="og:title" content="AGENTES — Tu empleado digital que ejecuta" />
  <meta property="og:description" content="Un empleado AI que hace cosas reales por tu negocio." />
  <meta property="og:image" content="/og.png" />
  <meta property="og:type" content="website" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <script defer src="https://umami.luminari.agency/script.js" data-website-id="9a5bb1d1-9bc1-417a-8b4b-72b44044d168"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --green: #25D366;
      --green-light: #e8faf0;
      --green-lighter: #f0fdf5;
      --green-medium: #b8f0d0;
      --white: #ffffff;
      --gray-50: #f9fafb;
      --gray-100: #f3f4f6;
      --gray-200: #e5e7eb;
      --gray-400: #9ca3af;
      --gray-500: #6b7280;
      --gray-600: #4b5563;
      --gray-700: #374151;
      --gray-800: #1f2937;
      --gray-900: #111827;
      --radius: 16px;
      --radius-sm: 12px;
    }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', -apple-system, sans-serif;
      background: var(--white);
      color: var(--gray-800);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }
    .container { max-width: 1120px; margin: 0 auto; padding: 0 24px; }

    /* NAV */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      background: rgba(255,255,255,0.8);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--gray-200);
    }
    nav .inner {
      max-width: 1120px; margin: 0 auto; padding: 0 24px;
      display: flex; align-items: center; justify-content: space-between;
      height: 64px;
    }
    .logo { font-weight: 800; font-size: 1.15rem; color: var(--gray-900); text-decoration: none; letter-spacing: -0.02em; }
    .logo span { color: var(--green); }
    nav .links { display: flex; align-items: center; gap: 28px; }
    nav .links a { text-decoration: none; color: var(--gray-600); font-weight: 500; font-size: 0.9rem; transition: color .2s; }
    nav .links a:hover { color: var(--gray-900); }
    nav .links .cta-nav {
      background: var(--green); color: white; padding: 8px 20px; border-radius: 100px;
      font-weight: 600; font-size: 0.85rem; transition: transform .2s, box-shadow .2s;
    }
    nav .links .cta-nav:hover { transform: translateY(-1px); box-shadow: 0 4px 16px rgba(37,211,102,0.35); color: white; }

    /* HERO */
    .hero {
      padding: 140px 0 80px;
      background: linear-gradient(170deg, var(--white) 0%, var(--green-lighter) 50%, var(--green-light) 100%);
      position: relative; overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute; top: -200px; right: -200px;
      width: 600px; height: 600px; border-radius: 50%;
      background: radial-gradient(circle, rgba(37,211,102,0.08) 0%, transparent 70%);
    }
    .hero .container { text-align: center; position: relative; }
    .hero .badge {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(37,211,102,0.1); border: 1px solid rgba(37,211,102,0.2);
      padding: 6px 16px; border-radius: 100px; font-size: 0.82rem;
      font-weight: 600; color: #15803d; margin-bottom: 24px;
    }
    .hero .badge .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--green); animation: pulse 2s infinite; }
    @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.4; } }
    .hero h1 {
      font-size: clamp(2.2rem, 5vw, 3.8rem);
      font-weight: 900; line-height: 1.1; letter-spacing: -0.03em;
      color: var(--gray-900); max-width: 780px; margin: 0 auto 20px;
    }
    .hero h1 em { font-style: normal; color: var(--green); }
    .hero p {
      font-size: clamp(1rem, 2vw, 1.2rem);
      color: var(--gray-600); max-width: 560px; margin: 0 auto 36px;
      line-height: 1.7;
    }
    .hero .cta-btn {
      display: inline-flex; align-items: center; gap: 10px;
      background: var(--green); color: white; padding: 16px 36px;
      border-radius: 100px; font-weight: 700; font-size: 1.05rem;
      text-decoration: none; transition: all .3s;
      box-shadow: 0 4px 24px rgba(37,211,102,0.3);
    }
    .hero .cta-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(37,211,102,0.4); }
    .hero .cta-btn svg { width: 20px; height: 20px; }

    /* CAPABILITIES */
    .capabilities { padding: 100px 0; background: var(--white); }
    .section-label {
      text-align: center; font-size: 0.8rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.12em; color: var(--green);
      margin-bottom: 12px;
    }
    .section-title {
      text-align: center; font-size: clamp(1.6rem, 3.5vw, 2.4rem);
      font-weight: 800; color: var(--gray-900); margin-bottom: 16px;
      letter-spacing: -0.02em;
    }
    .section-sub {
      text-align: center; font-size: 1.05rem; color: var(--gray-500);
      max-width: 520px; margin: 0 auto 56px;
    }
    .cap-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 20px;
    }
    .cap-card {
      background: var(--white);
      border: 1px solid var(--gray-200);
      border-radius: var(--radius);
      padding: 28px 24px;
      transition: all .3s;
      position: relative; overflow: hidden;
    }
    .cap-card:hover {
      border-color: var(--green-medium);
      box-shadow: 0 8px 32px rgba(37,211,102,0.1);
      transform: translateY(-4px);
    }
    .cap-icon {
      width: 48px; height: 48px; border-radius: 12px;
      background: var(--green-light); display: flex; align-items: center;
      justify-content: center; margin-bottom: 16px; font-size: 1.5rem;
    }
    .cap-card h3 { font-size: 0.95rem; font-weight: 700; color: var(--gray-900); margin-bottom: 6px; }
    .cap-card p { font-size: 0.82rem; color: var(--gray-500); line-height: 1.5; }

    /* HOW IT WORKS */
    .how { padding: 100px 0; background: var(--green-lighter); }
    .steps { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 32px; margin-top: 0; }
    .step {
      text-align: center; padding: 40px 28px;
      background: rgba(255,255,255,0.7);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(37,211,102,0.15);
      border-radius: var(--radius);
    }
    .step-num {
      width: 52px; height: 52px; border-radius: 50%;
      background: var(--green); color: white;
      display: inline-flex; align-items: center; justify-content: center;
      font-weight: 800; font-size: 1.3rem; margin-bottom: 20px;
    }
    .step h3 { font-size: 1.1rem; font-weight: 700; color: var(--gray-900); margin-bottom: 8px; }
    .step p { font-size: 0.9rem; color: var(--gray-500); }

    /* FORM */
    .form-section { padding: 100px 0; background: var(--white); }
    .form-wrapper {
      max-width: 560px; margin: 0 auto;
      background: rgba(255,255,255,0.8);
      backdrop-filter: blur(20px);
      border: 1px solid var(--gray-200);
      border-radius: 20px;
      padding: 40px 36px;
      box-shadow: 0 12px 48px rgba(0,0,0,0.06);
    }
    .progress-bar { display: flex; gap: 8px; margin-bottom: 36px; }
    .progress-bar .bar {
      flex: 1; height: 4px; border-radius: 100px;
      background: var(--gray-200); transition: background .4s;
    }
    .progress-bar .bar.active { background: var(--green); }

    .form-step { display: none; animation: fadeIn .4s ease; }
    .form-step.active { display: block; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }

    .form-step h3 { font-size: 1.3rem; font-weight: 800; color: var(--gray-900); margin-bottom: 8px; }
    .form-step .hint { font-size: 0.88rem; color: var(--gray-500); margin-bottom: 28px; }

    label.field { display: block; margin-bottom: 16px; }
    label.field span { display: block; font-size: 0.82rem; font-weight: 600; color: var(--gray-700); margin-bottom: 6px; }
    input[type="text"], input[type="email"], input[type="tel"] {
      width: 100%; padding: 14px 16px; border: 1.5px solid var(--gray-200);
      border-radius: var(--radius-sm); font-size: 0.95rem;
      font-family: inherit; transition: border-color .2s;
      background: var(--white); color: var(--gray-900);
    }
    input:focus { outline: none; border-color: var(--green); box-shadow: 0 0 0 3px rgba(37,211,102,0.15); }

    .checkbox-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .checkbox-item {
      display: flex; align-items: center; gap: 10px;
      padding: 12px 14px; border: 1.5px solid var(--gray-200);
      border-radius: var(--radius-sm); cursor: pointer;
      transition: all .2s; font-size: 0.88rem; font-weight: 500; color: var(--gray-700);
    }
    .checkbox-item:hover { border-color: var(--green-medium); }
    .checkbox-item.checked { border-color: var(--green); background: var(--green-light); color: #15803d; }
    .checkbox-item input { display: none; }

    .form-nav { display: flex; gap: 12px; margin-top: 28px; }
    .btn-back {
      flex: 1; padding: 14px; border-radius: 100px;
      border: 1.5px solid var(--gray-200); background: var(--white);
      font-family: inherit; font-weight: 600; font-size: 0.95rem;
      color: var(--gray-600); cursor: pointer; transition: all .2s;
    }
    .btn-back:hover { border-color: var(--gray-400); }
    .btn-next, .btn-submit {
      flex: 2; padding: 14px; border-radius: 100px;
      border: none; background: var(--green);
      font-family: inherit; font-weight: 700; font-size: 0.95rem;
      color: white; cursor: pointer; transition: all .2s;
    }
    .btn-next:hover, .btn-submit:hover { box-shadow: 0 4px 16px rgba(37,211,102,0.35); transform: translateY(-1px); }
    .btn-next:disabled, .btn-submit:disabled { opacity: 0.5; cursor: not-allowed; transform: none; box-shadow: none; }

    .success-msg {
      display: none; text-align: center; padding: 20px;
    }
    .success-msg.show { display: block; animation: fadeIn .5s ease; }
    .success-msg .check { font-size: 3rem; margin-bottom: 12px; }
    .success-msg h3 { font-size: 1.3rem; font-weight: 800; color: var(--gray-900); margin-bottom: 8px; }
    .success-msg p { color: var(--gray-500); font-size: 0.95rem; }

    /* FOOTER */
    footer {
      padding: 40px 0; text-align: center;
      border-top: 1px solid var(--gray-200);
      color: var(--gray-400); font-size: 0.82rem;
    }
    footer a { color: var(--green); text-decoration: none; font-weight: 600; }

    /* MOBILE */
    @media (max-width: 640px) {
      .hero { padding: 120px 0 60px; }
      .form-wrapper { padding: 28px 20px; }
      .checkbox-grid { grid-template-columns: 1fr; }
      .cap-grid { grid-template-columns: 1fr 1fr; }
      nav .links a:not(.cta-nav) { display: none; }
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="inner">
    <a href="/" class="logo"><span>◆</span> AGENTES</a>
    <div class="links">
      <a href="/blog">Blog</a>
      <a href="#empezar" class="cta-nav">Empezar</a>
    </div>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="container">
    <div class="badge"><div class="dot"></div> Disponible ahora</div>
    <h1>Tu negocio merece un <em>empleado digital</em> que ejecute</h1>
    <p>No es un chatbot. Es un agente AI que programa, diseña, administra y resuelve — todo desde WhatsApp.</p>
    <a href="#empezar" class="cta-btn">
      Quiero mi agente
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </a>
  </div>
</section>

<!-- CAPABILITIES -->
<section class="capabilities">
  <div class="container">
    <div class="section-label">Capacidades</div>
    <h2 class="section-title">Todo lo que tu agente puede hacer</h2>
    <p class="section-sub">Un empleado que nunca descansa, aprende tu negocio y ejecuta tareas reales.</p>
    <div class="cap-grid">
      <div class="cap-card">
        <div class="cap-icon">📊</div>
        <h3>Contabilidad</h3>
        <p>Registra gastos, genera reportes y organiza tus finanzas.</p>
      </div>
      <div class="cap-card">
        <div class="cap-icon">🎨</div>
        <h3>Diseño gráfico</h3>
        <p>Crea posts, flyers y material visual para tus redes.</p>
      </div>
      <div class="cap-card">
        <div class="cap-icon">💻</div>
        <h3>Desarrollo web</h3>
        <p>Construye landing pages, dashboards y herramientas internas.</p>
      </div>
      <div class="cap-card">
        <div class="cap-icon">📅</div>
        <h3>Agendar citas</h3>
        <p>Gestiona tu calendario y confirma citas automáticamente.</p>
      </div>
      <div class="cap-card">
        <div class="cap-icon">🤝</div>
        <h3>Atención al cliente</h3>
        <p>Responde consultas, resuelve dudas y da seguimiento 24/7.</p>
      </div>
      <div class="cap-card">
        <div class="cap-icon">📱</div>
        <h3>Redes sociales</h3>
        <p>Planifica contenido, redacta posts y analiza métricas.</p>
      </div>
      <div class="cap-card">
        <div class="cap-icon">📈</div>
        <h3>Dashboards</h3>
        <p>Genera reportes visuales y métricas de tu negocio en tiempo real.</p>
      </div>
      <div class="cap-card">
        <div class="cap-icon">🛒</div>
        <h3>Ventas</h3>
        <p>Califica leads, envía cotizaciones y cierra ventas por ti.</p>
      </div>
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section class="how">
  <div class="container">
    <div class="section-label">Proceso</div>
    <h2 class="section-title">3 pasos para empezar</h2>
    <p class="section-sub">Configurar tu agente es rápido y simple.</p>
    <div class="steps">
      <div class="step">
        <div class="step-num">1</div>
        <h3>Cuéntanos sobre tu negocio</h3>
        <p>Completa el formulario con las áreas donde necesitas ayuda.</p>
      </div>
      <div class="step">
        <div class="step-num">2</div>
        <h3>Configuramos tu agente</h3>
        <p>Lo entrenamos con la info de tu negocio y lo conectamos a WhatsApp.</p>
      </div>
      <div class="step">
        <div class="step-num">3</div>
        <h3>Tu agente empieza a trabajar</h3>
        <p>Desde el día uno ejecuta tareas reales y aprende cada vez más.</p>
      </div>
    </div>
  </div>
</section>

<!-- FORM -->
<section class="form-section" id="empezar">
  <div class="container">
    <div class="section-label">Únete</div>
    <h2 class="section-title">Empieza ahora</h2>
    <p class="section-sub">Completa estos 3 pasos y nos pondremos en contacto contigo.</p>
    <div class="form-wrapper">
      <div class="progress-bar">
        <div class="bar active" data-step="1"></div>
        <div class="bar" data-step="2"></div>
        <div class="bar" data-step="3"></div>
      </div>

      <form id="onboarding-form">
        <!-- Step 1 -->
        <div class="form-step active" data-step="1">
          <h3>¿Cómo se llama tu negocio?</h3>
          <p class="hint">Puede ser tu marca, empresa o proyecto.</p>
          <label class="field">
            <span>Nombre del negocio</span>
            <input type="text" id="business-name" placeholder="Ej: Clínica San Martín" required />
          </label>
          <div class="form-nav">
            <button type="button" class="btn-next" onclick="nextStep(2)">Continuar</button>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="form-step" data-step="2">
          <h3>¿En qué áreas necesitas ayuda?</h3>
          <p class="hint">Selecciona todas las que apliquen.</p>
          <div class="checkbox-grid">
            <label class="checkbox-item" onclick="toggleCheck(this)"><input type="checkbox" name="areas" value="ventas" />🛒 Ventas</label>
            <label class="checkbox-item" onclick="toggleCheck(this)"><input type="checkbox" name="areas" value="soporte" />🤝 Soporte</label>
            <label class="checkbox-item" onclick="toggleCheck(this)"><input type="checkbox" name="areas" value="contabilidad" />📊 Contabilidad</label>
            <label class="checkbox-item" onclick="toggleCheck(this)"><input type="checkbox" name="areas" value="diseño" />🎨 Diseño</label>
            <label class="checkbox-item" onclick="toggleCheck(this)"><input type="checkbox" name="areas" value="desarrollo-web" />💻 Desarrollo web</label>
            <label class="checkbox-item" onclick="toggleCheck(this)"><input type="checkbox" name="areas" value="redes-sociales" />📱 Redes sociales</label>
            <label class="checkbox-item" onclick="toggleCheck(this)"><input type="checkbox" name="areas" value="citas" />📅 Agendar citas</label>
            <label class="checkbox-item" onclick="toggleCheck(this)"><input type="checkbox" name="areas" value="otro" />✨ Otro</label>
          </div>
          <div class="form-nav">
            <button type="button" class="btn-back" onclick="prevStep(1)">Atrás</button>
            <button type="button" class="btn-next" onclick="nextStep(3)">Continuar</button>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="form-step" data-step="3">
          <h3>¿Cómo te contactamos?</h3>
          <p class="hint">Te escribiremos para configurar tu agente.</p>
          <label class="field">
            <span>Correo electrónico</span>
            <input type="email" id="email" placeholder="tu@empresa.com" required />
          </label>
          <label class="field">
            <span>WhatsApp</span>
            <input type="tel" id="whatsapp" placeholder="+51 999 999 999" required />
          </label>
          <div class="form-nav">
            <button type="button" class="btn-back" onclick="prevStep(2)">Atrás</button>
            <button type="submit" class="btn-submit">Empezar ahora 🚀</button>
          </div>
        </div>
      </form>

      <div class="success-msg" id="success">
        <div class="check">✅</div>
        <h3>¡Listo!</h3>
        <p>Recibimos tu solicitud. Te contactaremos pronto para configurar tu agente.</p>
      </div>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <div class="container">
    <a href="/">◆ AGENTES</a> by Luminari &copy; 2026
  </div>
</footer>

<script>
  function nextStep(n) {
    document.querySelectorAll('.form-step').forEach(s => s.classList.remove('active'));
    document.querySelector(`.form-step[data-step="${n}"]`).classList.add('active');
    document.querySelectorAll('.progress-bar .bar').forEach(b => {
      b.classList.toggle('active', parseInt(b.dataset.step) <= n);
    });
  }
  function prevStep(n) { nextStep(n); }
  function toggleCheck(el) {
    setTimeout(() => {
      el.classList.toggle('checked', el.querySelector('input').checked);
    }, 0);
  }

  document.getElementById('onboarding-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = e.target.querySelector('.btn-submit');
    btn.disabled = true;
    btn.textContent = 'Enviando...';
    const areas = [...document.querySelectorAll('input[name="areas"]:checked')].map(c => c.value);
    try {
      await fetch('https://agentes-api.luminari.agency/api/waitlist', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          businessName: document.getElementById('business-name').value,
          areas,
          email: document.getElementById('email').value,
          whatsapp: document.getElementById('whatsapp').value,
        })
      });
    } catch (err) {}
    document.getElementById('onboarding-form').style.display = 'none';
    document.querySelector('.progress-bar').style.display = 'none';
    document.getElementById('success').classList.add('show');
  });
</script>

</body>
</html>
