---
const agents = [
  {
    name: "Sofía",
    role: "Ventas",
    desc: "Prospecta, califica y cierra ventas por WhatsApp. Tu mejor vendedora, 24/7.",
    tags: ["WhatsApp", "CRM", "Follow-ups"],
    image: "/agents/sofia.png",
  },
  {
    name: "Carlos",
    role: "Atención al Cliente",
    desc: "Resuelve dudas al instante y mantiene a tus clientes felices. Siempre amable.",
    tags: ["Soporte", "FAQ", "Tickets"],
    image: "/agents/carlos.png",
  },
  {
    name: "Valentina",
    role: "Coordinación",
    desc: "Agenda reuniones, envía recordatorios y optimiza tu calendario automáticamente.",
    tags: ["Calendario", "Recordatorios", "Booking"],
    image: "/agents/valentina.png",
  },
];

const plans = [
  { name: "Básico", hours: "1h/día", price: "80", desc: "Para empezar a probar", features: ["1 agente AI", "Respaldo humano", "Reportes semanales"] },
  { name: "Pro", hours: "4h/día", price: "250", desc: "Para negocios en crecimiento", popular: true, features: ["1 agente AI", "Respaldo prioritario", "Reportes diarios", "Personalización avanzada"] },
  { name: "Full", hours: "8h/día", price: "400", desc: "Máxima productividad", features: ["1 agente dedicado", "Respaldo 24/7", "Reportes tiempo real", "Integración custom", "Soporte prioritario"] },
];
---

<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AGENTES — Contrata tu primer empleado AI</title>
  <meta name="description" content="Trabajadores AI autónomos con respaldo humano. Costos fijos como un sueldo." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&family=Caveat:wght@500;600;700&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- Animated background -->
  <div class="bg-wrap">
    <div class="bg-blob blob-1"></div>
    <div class="bg-blob blob-2"></div>
    <div class="bg-blob blob-3"></div>
    <div class="bg-dots"></div>
  </div>

  <!-- Nav -->
  <nav>
    <div class="nav-inner">
      <a href="#" class="logo">◆ AGENTES</a>
      <div class="nav-right">
        <a href="#agentes" class="nav-link">Equipo</a>
        <a href="#pricing" class="nav-link">Planes</a>
        <a href="#empezar" class="nav-btn">Empezar ahora</a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-left anim-up in-view">
      <div class="hero-pill">
        <span class="pill-dot"></span>
        Disponible ahora
      </div>
      <h1>
        Tu próximo empleado no es humano.
        <span class="hero-accent">Pero trabaja como uno.</span>
      </h1>
      <p class="hero-p">
        Agentes AI autónomos con respaldo humano real. Recibe un WhatsApp configurado y listo para trabajar. <strong>Paga un sueldo fijo, no tokens.</strong>
      </p>
      <div class="hero-cta-row">
        <a href="#empezar" class="cta-main">Contratar mi agente</a>
        <span class="hero-note">Desde $80/mes · Activo en 24h</span>
      </div>
    </div>
    <div class="hero-right anim-up in-view" style="--delay: 0.15s">
      <div class="phone-frame">
        <div class="phone-notch"></div>
        <div class="wa-chat">
          <div class="wa-header">
            <div class="wa-back">‹</div>
            <div class="wa-avatar">S</div>
            <div class="wa-header-info">
              <span class="wa-name">Sofía — Ventas</span>
              <span class="wa-status">en línea</span>
            </div>
          </div>
          <div class="wa-body">
            <div class="wa-date">Hoy</div>
            <div class="wa-msg wa-incoming">
              <p>Hola, vi su anuncio. ¿Cuánto cuesta el plan básico?</p>
              <span class="wa-time">10:32 a.m.</span>
            </div>
            <div class="wa-msg wa-outgoing">
              <p>¡Hola! 👋 El plan básico es de $80/mes. Incluye 1 hora diaria de trabajo y respaldo humano.</p>
              <span class="wa-time">10:32 a.m. ✓✓</span>
            </div>
            <div class="wa-msg wa-outgoing">
              <p>¿Te gustaría agendar una demo de 15 min? Puedo buscarte un horario mañana 📅</p>
              <span class="wa-time">10:33 a.m. ✓✓</span>
            </div>
            <div class="wa-msg wa-incoming">
              <p>Dale, mañana a las 10am</p>
              <span class="wa-time">10:34 a.m.</span>
            </div>
            <div class="wa-msg wa-outgoing">
              <p>¡Listo! Agendado para mañana 10am. Te envié la invitación al correo. ¡Nos vemos! ✅</p>
              <span class="wa-time">10:34 a.m. ✓✓</span>
            </div>
          </div>
        </div>
        <!-- Hand-drawn annotations -->
        <div class="annotation ann-1">
          <svg class="ann-arrow" viewBox="0 0 80 60" fill="none"><path d="M5 55 C 20 20, 50 5, 75 10" stroke="var(--green)" stroke-width="2.5" stroke-linecap="round" fill="none" stroke-dasharray="4 3"/><polygon points="72,4 80,10 70,14" fill="var(--green)"/></svg>
          <span class="ann-text">¡Esto lo hace la IA!</span>
        </div>
        <div class="annotation ann-2">
          <svg class="ann-arrow arr-flip" viewBox="0 0 80 60" fill="none"><path d="M75 55 C 60 20, 30 5, 5 10" stroke="var(--green)" stroke-width="2.5" stroke-linecap="round" fill="none" stroke-dasharray="4 3"/><polygon points="8,4 0,10 10,14" fill="var(--green)"/></svg>
          <span class="ann-text">Sin intervención humana 🤯</span>
        </div>
        <div class="annotation ann-3">
          <span class="ann-text ann-bottom">Agenda, responde y cierra ventas sola →</span>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="steps-section">
    <span class="label anim-up">Proceso</span>
    <h2 class="anim-up">Así de simple funciona</h2>
    <div class="steps">
      <div class="step glass-card anim-up">
        <div class="step-n">1</div>
        <h3>Define el rol</h3>
        <p>Ventas, soporte, agendamiento... tú eliges qué hace tu agente.</p>
      </div>
      <div class="step-arrow anim-up" style="--delay:0.05s">→</div>
      <div class="step glass-card anim-up" style="--delay:0.1s">
        <div class="step-n">2</div>
        <h3>Lo configuramos</h3>
        <p>Entrenamos al agente con tu info y le asignamos respaldo humano.</p>
      </div>
      <div class="step-arrow anim-up" style="--delay:0.15s">→</div>
      <div class="step glass-card anim-up" style="--delay:0.2s">
        <div class="step-n">3</div>
        <h3>Listo para trabajar</h3>
        <p>Recibes un WhatsApp funcional. Tu agente empieza de inmediato.</p>
      </div>
    </div>
  </section>

  <!-- Agents -->
  <section class="agents-section" id="agentes">
    <span class="label anim-up">Equipo</span>
    <h2 class="anim-up">Conoce a tus agentes</h2>
    <div class="agents-row">
      {agents.map((agent, i) => (
        <div class="agent-card glass-card anim-up" style={`--delay: ${i * 0.1}s`}>
          <div class="agent-photo-area">
            <img src={agent.image} alt={agent.name} class="agent-photo" loading="lazy" />
          </div>
          <div class="agent-meta">
            <span class="agent-role">{agent.role}</span>
            <h3>{agent.name}</h3>
            <p>{agent.desc}</p>
            <div class="agent-tag-row">
              {agent.tags.map((t) => <span class="atag">{t}</span>)}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Pricing -->
  <section class="pricing-section" id="pricing">
    <span class="label anim-up">Planes</span>
    <h2 class="anim-up">Un sueldo fijo. Sin sorpresas.</h2>
    <p class="pricing-sub anim-up">Sin cobros por token, sin cargos ocultos. Cancela cuando quieras.</p>
    <div class="plans-row">
      {plans.map((plan, i) => (
        <div class={`plan-card glass-card anim-up ${plan.popular ? 'plan-pop' : ''}`} style={`--delay: ${i * 0.08}s`}>
          {plan.popular && <span class="pop-label">Recomendado</span>}
          <h3>{plan.name}</h3>
          <p class="plan-hours">{plan.hours}</p>
          <div class="plan-price">
            <span class="pp-dollar">$</span>
            <span class="pp-amount">{plan.price}</span>
            <span class="pp-mo">/mes</span>
          </div>
          <p class="plan-desc">{plan.desc}</p>
          <ul>
            {plan.features.map((f) => <li><span class="check">✓</span> {f}</li>)}
          </ul>
          <a href="#empezar" class={plan.popular ? 'plan-btn-main' : 'plan-btn'}>Contratar</a>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA / "Empezar" (disguised waitlist) -->
  <section class="start-section" id="empezar">
    <div class="start-container glass-card anim-up">
      <div class="start-info">
        <h2>Empieza hoy</h2>
        <p>Completa tus datos y en menos de 24 horas tendrás tu agente configurado y funcionando.</p>
        <ul class="start-perks">
          <li><span class="check">✓</span> Activo en menos de 24h</li>
          <li><span class="check">✓</span> Precio fijo garantizado</li>
          <li><span class="check">✓</span> Configuración personalizada incluida</li>
          <li><span class="check">✓</span> Cancela cuando quieras</li>
        </ul>
      </div>
      <form id="waitlist-form">
        <input type="text" name="name" placeholder="Tu nombre" required />
        <input type="email" name="email" placeholder="tu@email.com" required />
        <input type="text" name="company" placeholder="Empresa (opcional)" />
        <select name="agentType" required>
          <option value="" disabled selected>¿Qué agente necesitas?</option>
          <option value="ventas">Ventas</option>
          <option value="atencion">Atención al cliente</option>
          <option value="agendamiento">Agendamiento de citas</option>
          <option value="soporte">Soporte técnico</option>
          <option value="community">Community manager</option>
          <option value="otro">Otro</option>
        </select>
        <textarea name="message" placeholder="Cuéntanos sobre tu negocio (opcional)" rows="3"></textarea>
        <button type="submit" class="cta-main start-btn" id="wl-submit">Empezar ahora</button>
        <p id="form-status" class="form-status"></p>
      </form>
    </div>
  </section>

  <!-- Footer -->
  <footer>
    <div class="footer-inner">
      <span class="logo-sm">◆ AGENTES <span class="by">by Luminari</span></span>
      <span class="copy">© 2025 Luminari</span>
    </div>
  </footer>

  <script>
    // Form submit
    const form = document.getElementById('waitlist-form') as HTMLFormElement;
    const status = document.getElementById('form-status')!;
    const btn = document.getElementById('wl-submit') as HTMLButtonElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      btn.disabled = true;
      btn.textContent = 'Procesando...';
      status.textContent = '';
      status.className = 'form-status';
      try {
        const data = Object.fromEntries(new FormData(form));
        const res = await fetch('https://agentes-api.luminari.agency/api/waitlist', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        const json = await res.json();
        if (res.ok) {
          status.textContent = '🎉 ¡Recibido! Te contactaremos en menos de 24h para configurar tu agente.';
          status.className = 'form-status success';
          form.reset();
        } else {
          throw new Error(json.message || 'Error al enviar');
        }
      } catch (err: any) {
        status.textContent = '❌ ' + err.message;
        status.className = 'form-status error';
      } finally {
        btn.disabled = false;
        btn.textContent = 'Empezar ahora';
      }
    });

    // Scroll animations
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('in-view');
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.anim-up').forEach(el => observer.observe(el));
  </script>
</body>
</html>

<style is:global>
  :root {
    --white: #ffffff;
    --bg: #F0FAF4;
    --bg-2: #E6F5EC;
    --surface: rgba(255,255,255,0.6);
    --surface-solid: #ffffff;
    --border: rgba(0,80,40,0.08);
    --border-hover: rgba(0,80,40,0.15);
    --text: #1A2E23;
    --text-2: #3D5A4A;
    --text-3: #7A9484;
    --green: #25D366;
    --green-dark: #128C7E;
    --green-deep: #075E54;
    --green-light: #DCF8C6;
    --green-soft: rgba(37,211,102,0.1);
    --green-glass: rgba(37,211,102,0.06);
    --radius: 20px;
    --radius-sm: 12px;
    --max-w: 1080px;
    --font-body: 'Instrument Sans', system-ui, sans-serif;
    --font-display: 'Space Grotesk', system-ui, sans-serif;
    --font-hand: 'Caveat', cursive;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font-body);
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }

  /* ===== ANIMATED BACKGROUND ===== */
  .bg-wrap {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .bg-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.5;
    animation: float 20s ease-in-out infinite;
  }
  .blob-1 {
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(37,211,102,0.2), transparent 70%);
    top: -10%; right: -5%;
    animation-delay: 0s;
  }
  .blob-2 {
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(18,140,126,0.15), transparent 70%);
    bottom: 10%; left: -8%;
    animation-delay: -7s;
  }
  .blob-3 {
    width: 350px; height: 350px;
    background: radial-gradient(circle, rgba(37,211,102,0.12), transparent 70%);
    top: 40%; right: 20%;
    animation-delay: -14s;
  }
  @keyframes float {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(30px, -40px) scale(1.05); }
    66% { transform: translate(-20px, 20px) scale(0.95); }
  }
  .bg-dots {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(0,80,40,0.04) 1px, transparent 1px);
    background-size: 32px 32px;
  }

  /* ===== GLASS CARDS ===== */
  .glass-card {
    background: rgba(255,255,255,0.45);
    backdrop-filter: blur(24px) saturate(140%);
    -webkit-backdrop-filter: blur(24px) saturate(140%);
    border: 1px solid rgba(255,255,255,0.5);
    border-radius: var(--radius);
    box-shadow: 0 4px 16px rgba(0,80,40,0.04), inset 0 1px 0 rgba(255,255,255,0.6);
    transition: transform 0.3s cubic-bezier(0.16,1,0.3,1), box-shadow 0.3s, border-color 0.3s;
  }
  .glass-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(0,80,40,0.08), inset 0 1px 0 rgba(255,255,255,0.7);
    border-color: rgba(255,255,255,0.7);
  }

  /* ===== ANIMATIONS ===== */
  @keyframes slideUp {
    from { opacity: 0; transform: translateY(28px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .anim-up {
    opacity: 0;
    transform: translateY(28px);
  }
  .anim-up.in-view {
    animation: slideUp 0.7s cubic-bezier(0.16,1,0.3,1) forwards;
    animation-delay: var(--delay, 0s);
  }
  /* Fallback: show content if JS fails */
  @media (prefers-reduced-motion: reduce) {
    .anim-up { opacity: 1; transform: none; }
  }

  /* ===== NAV ===== */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: rgba(240,250,244,0.7);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0.85rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .logo {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--green-deep);
    text-decoration: none;
  }
  .nav-right { display: flex; align-items: center; gap: 1.5rem; }
  .nav-link {
    font-size: 0.85rem;
    color: var(--text-2);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.15s;
  }
  .nav-link:hover { color: var(--text); }
  .nav-btn {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--white);
    background: var(--green);
    padding: 0.5rem 1.2rem;
    border-radius: 100px;
    text-decoration: none;
    transition: all 0.2s;
    box-shadow: 0 2px 8px rgba(37,211,102,0.25);
  }
  .nav-btn:hover { background: #20c05c; box-shadow: 0 4px 12px rgba(37,211,102,0.35); }

  /* ===== COMMON ===== */
  section {
    position: relative;
    z-index: 1;
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 6rem 2rem;
  }
  .label {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--green-dark);
    background: var(--green-soft);
    padding: 0.3rem 0.8rem;
    border-radius: 100px;
    margin-bottom: 1rem;
  }
  h2 {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
    color: var(--text);
  }

  /* ===== CTA ===== */
  .cta-main {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--white);
    background: var(--green);
    padding: 0.85rem 2.2rem;
    border-radius: 100px;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s;
    box-shadow: 0 4px 14px rgba(37,211,102,0.3);
  }
  .cta-main:hover {
    background: #20c05c;
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(37,211,102,0.4);
  }
  .cta-main:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
  .check { color: var(--green); font-weight: 700; }

  /* ===== HERO ===== */
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 3rem;
    padding-top: 7rem;
  }
  .hero-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--green-dark);
    background: var(--green-soft);
    border: 1px solid rgba(37,211,102,0.15);
    padding: 0.4rem 1rem;
    border-radius: 100px;
    margin-bottom: 1.5rem;
  }
  .pill-dot {
    width: 7px; height: 7px;
    background: var(--green);
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(37,211,102,0.4); }
    50% { opacity: 0.7; box-shadow: 0 0 0 6px rgba(37,211,102,0); }
  }

  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5vw, 3rem);
    font-weight: 700;
    line-height: 1.18;
    letter-spacing: -0.025em;
    margin-bottom: 1.25rem;
  }
  .hero-accent { color: var(--green-dark); }
  .hero-p {
    font-size: 1.05rem;
    color: var(--text-2);
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 440px;
  }
  .hero-p strong { color: var(--text); }
  .hero-cta-row {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }
  .hero-note { font-size: 0.82rem; color: var(--text-3); }

  /* ===== PHONE FRAME + WHATSAPP ===== */
  .phone-frame {
    position: relative;
    max-width: 340px;
    margin: 0 auto;
    background: #111;
    border-radius: 36px;
    padding: 8px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.15), 0 0 0 1px rgba(0,0,0,0.1);
  }
  .phone-notch {
    position: absolute;
    top: 8px;
    left: 50%;
    transform: translateX(-50%);
    width: 100px;
    height: 22px;
    background: #111;
    border-radius: 0 0 16px 16px;
    z-index: 10;
  }
  .wa-chat {
    border-radius: 28px;
    overflow: hidden;
    background: #ECE5DD;
  }
  .wa-header {
    background: var(--green-deep);
    color: white;
    padding: 2rem 0.85rem 0.65rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .wa-back { font-size: 1.2rem; opacity: 0.7; }
  .wa-avatar {
    width: 30px; height: 30px;
    border-radius: 50%;
    background: rgba(255,255,255,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 600;
  }
  .wa-header-info { display: flex; flex-direction: column; }
  .wa-name { font-size: 0.8rem; font-weight: 600; }
