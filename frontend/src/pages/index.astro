---
const agents = [
  {
    name: "Sofía",
    role: "Ventas",
    desc: "Prospecta, califica y cierra ventas por WhatsApp. Tu mejor vendedora, 24/7.",
    tags: ["WhatsApp", "CRM", "Follow-ups"],
    image: "/agents/sofia.png",
  },
  {
    name: "Carlos",
    role: "Atención al Cliente",
    desc: "Resuelve dudas al instante y mantiene a tus clientes felices. Siempre amable.",
    tags: ["Soporte", "FAQ", "Tickets"],
    image: "/agents/carlos.png",
  },
  {
    name: "Valentina",
    role: "Coordinación",
    desc: "Agenda reuniones, envía recordatorios y optimiza tu calendario automáticamente.",
    tags: ["Calendario", "Recordatorios", "Booking"],
    image: "/agents/valentina.png",
  },
];

const plans = [
  { name: "Básico", hours: "1h/día", price: "80", desc: "Para empezar a probar", features: ["1 agente AI", "Respaldo humano", "Reportes semanales"] },
  { name: "Pro", hours: "4h/día", price: "250", desc: "Para negocios en crecimiento", popular: true, features: ["1 agente AI", "Respaldo prioritario", "Reportes diarios", "Personalización avanzada"] },
  { name: "Full", hours: "8h/día", price: "400", desc: "Máxima productividad", features: ["1 agente dedicado", "Respaldo 24/7", "Reportes tiempo real", "Integración custom", "Soporte prioritario"] },
];
---

<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AGENTES — Contrata tu primer empleado AI | Luminari</title>
  <meta name="description" content="Agentes AI autónomos con respaldo humano. Recibe un WhatsApp configurado y listo. Costos fijos desde $80/mes." />
  <meta name="keywords" content="agente AI, empleado AI, WhatsApp, ventas automatizadas, atención al cliente, agendamiento, inteligencia artificial, Perú, Latinoamérica" />
  <meta property="og:title" content="AGENTES — Tu primer empleado AI" />
  <meta property="og:description" content="Agentes AI con respaldo humano. WhatsApp listo para trabajar. Desde $80/mes." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://agentes.luminari.agency" />
  <meta property="og:image" content="https://agentes.luminari.agency/og.png" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="AGENTES — Tu primer empleado AI" />
  <meta name="twitter:description" content="Agentes AI con respaldo humano. WhatsApp listo para trabajar. Desde $80/mes." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href="https://agentes.luminari.agency" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&family=Caveat:wght@500;600;700&display=swap" rel="stylesheet" />
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "AGENTES by Luminari",
    "url": "https://agentes.luminari.agency",
    "description": "Agentes AI autónomos con respaldo humano para empresas."
  }</script>
</head>
<body>

  <!-- Animated background -->
  <div class="bg-wrap" aria-hidden="true">
    <div class="bg-blob blob-1"></div>
    <div class="bg-blob blob-2"></div>
    <div class="bg-blob blob-3"></div>
    <div class="bg-dots"></div>
  </div>

  <!-- Nav -->
  <nav>
    <div class="nav-inner">
      <a href="#" class="logo">◆ AGENTES</a>
      <div class="nav-right">
        <a href="#agentes" class="nav-link">Equipo</a>
        <a href="#pricing" class="nav-link">Planes</a>
        <a href="#empezar" class="nav-btn">Empezar ahora</a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-left reveal">
      <div class="hero-pill">
        <span class="pill-dot"></span>
        Disponible ahora
      </div>
      <h1>
        Tu próximo empleado no es humano.
        <span class="hero-accent">Pero trabaja como uno.</span>
      </h1>
      <p class="hero-p">
        Agentes AI autónomos con respaldo humano real. Recibe un WhatsApp configurado y listo para trabajar. <strong>Paga un sueldo fijo, no tokens.</strong>
      </p>
      <div class="hero-cta-row">
        <a href="#empezar" class="cta-main">Contratar mi agente</a>
        <span class="hero-note">Desde $80/mes · Activo en 24h</span>
      </div>
    </div>
    <div class="hero-right reveal" style="--d:0.15s">
      <div class="phone-frame">
        <div class="phone-notch"></div>
        <div class="wa-chat">
          <div class="wa-header">
            <div class="wa-back">‹</div>
            <div class="wa-avatar">S</div>
            <div class="wa-header-info">
              <span class="wa-name">Sofía — Ventas</span>
              <span class="wa-status">en línea</span>
            </div>
          </div>
          <div class="wa-body">
            <div class="wa-date">Hoy</div>
            <div class="wa-msg wa-incoming">
              <p>Hola, vi su anuncio. ¿Cuánto cuesta el plan básico?</p>
              <span class="wa-time">10:32 a.m.</span>
            </div>
            <div class="wa-msg wa-outgoing">
              <p>¡Hola! 👋 El plan básico es $80/mes. Incluye 1h diaria de trabajo y respaldo humano.</p>
              <span class="wa-time">10:32 a.m. ✓✓</span>
            </div>
            <div class="wa-msg wa-outgoing">
              <p>¿Te gustaría una demo de 15 min? Puedo buscarte horario mañana 📅</p>
              <span class="wa-time">10:33 a.m. ✓✓</span>
            </div>
            <div class="wa-msg wa-incoming">
              <p>Dale, mañana a las 10am</p>
              <span class="wa-time">10:34 a.m.</span>
            </div>
            <div class="wa-msg wa-outgoing">
              <p>¡Listo! Agendado mañana 10am. Te envié la invitación. ¡Nos vemos! ✅</p>
              <span class="wa-time">10:34 a.m. ✓✓</span>
            </div>
          </div>
        </div>
        <!-- Hand annotations -->
        <div class="ann ann-right">
          <span class="ann-label">¡Esto lo hace la IA! →</span>
        </div>
        <div class="ann ann-left">
          <span class="ann-label">← Sin intervención humana 🤯</span>
        </div>
        <div class="ann ann-bottom">
          <span class="ann-label">↑ Agenda, responde y cierra ventas sola</span>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="steps-section">
    <span class="label reveal">Proceso</span>
    <h2 class="reveal">Así de simple funciona</h2>
    <div class="steps">
      <div class="step glass reveal">
        <div class="step-n">1</div>
        <h3>Define el rol</h3>
        <p>Ventas, soporte, agendamiento... tú eliges qué hace tu agente.</p>
      </div>
      <div class="step-arrow reveal">→</div>
      <div class="step glass reveal" style="--d:0.08s">
        <div class="step-n">2</div>
        <h3>Lo configuramos</h3>
        <p>Entrenamos al agente con tu info y le asignamos respaldo humano.</p>
      </div>
      <div class="step-arrow reveal">→</div>
      <div class="step glass reveal" style="--d:0.16s">
        <div class="step-n">3</div>
        <h3>Listo para trabajar</h3>
        <p>Recibes un WhatsApp funcional. Tu agente empieza de inmediato.</p>
      </div>
    </div>
  </section>

  <!-- Agents -->
  <section class="agents-section" id="agentes">
    <span class="label reveal">Equipo</span>
    <h2 class="reveal">Conoce a tus agentes</h2>
    <div class="agents-row">
      {agents.map((agent, i) => (
        <div class="agent-card glass reveal" style={`--d:${i * 0.1}s`}>
          <div class="agent-photo-area">
            <img src={agent.image} alt={agent.name} class="agent-photo" loading="lazy" />
          </div>
          <div class="agent-meta">
            <span class="agent-role">{agent.role}</span>
            <h3>{agent.name}</h3>
            <p>{agent.desc}</p>
            <div class="agent-tag-row">
              {agent.tags.map((t) => <span class="atag">{t}</span>)}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Pricing -->
  <section class="pricing-section" id="pricing">
    <span class="label reveal">Planes</span>
    <h2 class="reveal">Un sueldo fijo. Sin sorpresas.</h2>
    <p class="pricing-sub reveal">Sin cobros por token, sin cargos ocultos. Cancela cuando quieras.</p>
    <div class="plans-row">
      {plans.map((plan, i) => (
        <div class={`plan-card glass reveal ${plan.popular ? 'plan-pop' : ''}`} style={`--d:${i * 0.08}s`}>
          {plan.popular && <span class="pop-label">Recomendado</span>}
          <h3>{plan.name}</h3>
          <p class="plan-hours">{plan.hours}</p>
          <div class="plan-price">
            <span class="pp-dollar">$</span>
            <span class="pp-amount">{plan.price}</span>
            <span class="pp-mo">/mes</span>
          </div>
          <p class="plan-desc">{plan.desc}</p>
          <ul>
            {plan.features.map((f) => <li><span class="check">✓</span> {f}</li>)}
          </ul>
          <a href="#empezar" class={plan.popular ? 'plan-btn-main' : 'plan-btn'}>Contratar</a>
        </div>
      ))}
    </div>
    <!-- Payment methods -->
    <div class="payments reveal">
      <span class="payments-label">Métodos de pago aceptados</span>
      <div class="payments-row">
        <div class="pay-icon" title="Yape">
          <svg viewBox="0 0 40 40" width="32" height="32"><rect width="40" height="40" rx="8" fill="#6B2D8B"/><text x="20" y="26" text-anchor="middle" fill="white" font-size="14" font-weight="700" font-family="system-ui">Y</text></svg>
          <span>Yape</span>
        </div>
        <div class="pay-icon" title="Plin">
          <svg viewBox="0 0 40 40" width="32" height="32"><rect width="40" height="40" rx="8" fill="#00BFA5"/><text x="20" y="26" text-anchor="middle" fill="white" font-size="14" font-weight="700" font-family="system-ui">P</text></svg>
          <span>Plin</span>
        </div>
        <div class="pay-icon" title="BCP">
          <svg viewBox="0 0 40 40" width="32" height="32"><rect width="40" height="40" rx="8" fill="#002884"/><text x="20" y="26" text-anchor="middle" fill="white" font-size="10" font-weight="700" font-family="system-ui">BCP</text></svg>
          <span>BCP</span>
        </div>
        <div class="pay-icon" title="BBVA">
          <svg viewBox="0 0 40 40" width="32" height="32"><rect width="40" height="40" rx="8" fill="#004481"/><text x="20" y="26" text-anchor="middle" fill="white" font-size="9" font-weight="700" font-family="system-ui">BBVA</text></svg>
          <span>BBVA</span>
        </div>
        <div class="pay-icon" title="Visa">
          <svg viewBox="0 0 40 40" width="32" height="32"><rect width="40" height="40" rx="8" fill="#1A1F71"/><text x="20" y="27" text-anchor="middle" fill="white" font-size="11" font-weight="700" font-family="system-ui" font-style="italic">VISA</text></svg>
          <span>Visa</span>
        </div>
        <div class="pay-icon" title="Mastercard">
          <svg viewBox="0 0 40 40" width="32" height="32"><rect width="40" height="40" rx="8" fill="#1A1A1A"/><circle cx="16" cy="20" r="9" fill="#EB001B"/><circle cx="24" cy="20" r="9" fill="#F79E1B"/><path d="M20 13.5a9 9 0 010 13" fill="#FF5F00"/></svg>
          <span>Mastercard</span>
        </div>
        <div class="pay-icon" title="Transferencia">
          <svg viewBox="0 0 40 40" width="32" height="32"><rect width="40" height="40" rx="8" fill="#2E7D32"/><text x="20" y="26" text-anchor="middle" fill="white" font-size="16" font-family="system-ui">🏦</text></svg>
          <span>Transferencia</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Empezar (disguised waitlist) -->
  <section class="start-section" id="empezar">
    <div class="start-container glass">
      <div class="start-info reveal">
        <h2>Empieza hoy</h2>
        <p>Completa tus datos y en menos de 24 horas tendrás tu agente configurado y funcionando.</p>
        <ul class="start-perks">
          <li><span class="check">✓</span> Activo en menos de 24h</li>
          <li><span class="check">✓</span> Precio fijo garantizado</li>
          <li><span class="check">✓</span> Configuración personalizada incluida</li>
          <li><span class="check">✓</span> Cancela cuando quieras</li>
        </ul>
      </div>
      <form id="waitlist-form" class="reveal" style="--d:0.1s">
        <input type="text" name="name" placeholder="Tu nombre" required />
        <input type="email" name="email" placeholder="tu@email.com" required />
        <input type="text" name="company" placeholder="Empresa (opcional)" />
        <select name="agentType" required>
          <option value="" disabled selected>¿Qué agente necesitas?</option>
          <option value="ventas">Ventas</option>
          <option value="atencion">Atención al cliente</option>
          <option value="agendamiento">Agendamiento de citas</option>
          <option value="soporte">Soporte técnico</option>
          <option value="community">Community manager</option>
          <option value="otro">Otro</option>
        </select>
        <textarea name="message" placeholder="Cuéntanos sobre tu negocio (opcional)" rows="3"></textarea>
        <button type="submit" class="cta-main start-btn" id="wl-submit">Empezar ahora</button>
        <p id="form-status" class="form-status"></p>
      </form>
    </div>
  </section>

  <!-- Footer -->
  <footer>
    <div class="footer-inner">
      <span class="logo-sm">◆ AGENTES <span class="by">by Luminari</span></span>
      <span class="copy">© 2025 Luminari. Todos los derechos reservados.</span>
    </div>
  </footer>

  <script>
    const form = document.getElementById('waitlist-form') as HTMLFormElement;
    const status = document.getElementById('form-status')!;
    const btn = document.getElementById('wl-submit') as HTMLButtonElement;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      btn.disabled = true;
      btn.textContent = 'Procesando...';
      status.textContent = '';
      status.className = 'form-status';
      try {
        const data = Object.fromEntries(new FormData(form));
        const res = await fetch('https://agentes-api.luminari.agency/api/waitlist', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        const json = await res.json();
        if (res.ok) {
          status.textContent = '🎉 ¡Recibido! Te contactaremos en menos de 24h para configurar tu agente.';
          status.className = 'form-status success';
          form.reset();
        } else { throw new Error(json.message || 'Error al enviar'); }
      } catch (err: any) {
        status.textContent = '❌ ' + err.message;
        status.className = 'form-status error';
      } finally {
        btn.disabled = false;
        btn.textContent = 'Empezar ahora';
      }
    });

    // Scroll reveal — elements start visible via CSS, class just adds animation
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('shown'); io.unobserve(e.target); } });
    }, { threshold: 0.1, rootMargin: '0px 0px -30px 0px' });
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));
  </script>
</body>
</html>

<style is:global>
  :root {
    --white: #ffffff;
    --bg: #F2F9F4;
    --bg-2: #E4F3E9;
    --border: rgba(0,80,40,0.07);
    --border-hover: rgba(0,80,40,0.14);
    --text: #1A2E23;
    --text-2: #3D5A4A;
    --text-3: #7A9484;
    --green: #25D366;
    --green-dark: #128C7E;
    --green-deep: #075E54;
    --green-light: #DCF8C6;
    --green-soft: rgba(37,211,102,0.08);
    --radius: 20px;
    --radius-sm: 12px;
    --max-w: 1080px;
    --font: 'Instrument Sans', system-ui, sans-serif;
    --font-d: 'Space Grotesk', system-ui, sans-serif;
    --font-h: 'Caveat', cursive;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    font-family: var(--font);
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }

  /* BACKGROUND */
  .bg-wrap { position: fixed; inset: 0; z-index: 0; pointer-events: none; overflow: hidden; }
  .bg-blob { position: absolute; border-radius: 50%; filter: blur(100px); animation: bfloat 25s ease-in-out infinite; }
  .blob-1 { width: 500px; height: 500px; background: radial-gradient(circle, rgba(37,211,102,0.18), transparent 70%); top: -10%; right: -5%; }
  .blob-2 { width: 400px; height: 400px; background: radial-gradient(circle, rgba(18,140,126,0.12), transparent 70%); bottom: 10%; left: -8%; animation-delay: -8s; }
  .blob-3 { width: 350px; height: 350px; background: radial-gradient(circle, rgba(37,211,102,0.1), transparent 70%); top: 45%; right: 25%; animation-delay: -16s; }
  @keyframes bfloat { 0%,100%{transform:translate(0,0) scale(1)} 33%{transform:translate(30px,-40px) scale(1.05)} 66%{transform:translate(-20px,20px) scale(.95)} }
  .bg-dots { position: absolute; inset: 0; background-image: radial-gradient(circle, rgba(0,80,40,0.035) 1px, transparent 1px); background-size: 32px 32px; }

  /* GLASS */
  .glass {
    background: rgba(255,255,255,0.5);
    backdrop-filter: blur(24px) saturate(140%);
    -webkit-backdrop-filter: blur(24px) saturate(140%);
    border: 1px solid rgba(255,255,255,0.55);
    border-radius: var(--radius);
    box-shadow: 0 4px 20px rgba(0,60,30,0.04), inset 0 1px 0 rgba(255,255,255,0.65);
    transition: transform .3s cubic-bezier(.16,1,.3,1), box-shadow .3s;
  }
  .glass:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(0,60,30,0.07), inset 0 1px 0 rgba(255,255,255,0.75);
  }

  /* REVEAL — content visible by default, animation on scroll */
  .reveal {
    opacity: 1;
    transform: translateY(0);
    transition: opacity .65s cubic-bezier(.16,1,.3,1), transform .65s cubic-bezier(.16,1,.3,1);
    transition-delay: var(--d, 0s);
  }
  .reveal:not(.shown) {
    opacity: 0;
    transform: translateY(24px);
  }
  /* Ensure hero is always visible */
  .hero .reveal { opacity: 1 !important; transform: none !important; }
  .hero .reveal.shown { animation: fadeSlide .7s cubic-bezier(.16,1,.3,1) forwards; animation-delay: var(--d, 0s); }
  @keyframes fadeSlide { from{opacity:0;transform:translateY(24px)} to{opacity:1;transform:translateY(0)} }
  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) { .reveal { opacity: 1 !important; transform: none !important; transition: none !important; } }

  /* NAV */
  nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: rgba(242,249,244,0.7); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border-bottom: 1px solid var(--border); }
  .nav-inner { max-width: var(--max-w); margin: 0 auto; padding: .85rem 2rem; display: flex; justify-content: space-between; align-items: center; }
  .logo { font-family: var(--font-d); font-size: .95rem; font-weight: 700; letter-spacing: .1em; color: var(--green-deep); text-decoration: none; }
  .nav-right { display: flex; align-items: center; gap: 1.5rem; }
  .nav-link { font-size: .85rem; color: var(--text-2); text-decoration: none; font-weight: 500; transition: color .15s; }
  .nav-link:hover { color: var(--text); }
  .nav-btn { font-size: .82rem; font-weight: 600; color: var(--white); background: var(--green); padding: .5rem 1.2rem; border-radius: 100px; text-decoration: none; transition: all .2s; box-shadow: 0 2px 8px rgba(37,211,102,.25); }
  .nav-btn:hover { background: #20c05c; box-shadow: 0 4px 12px rgba(37,211,102,.35); }

  /* COMMON */
  section { position: relative; z-index: 1; max-width: var(--max-w); margin: 0 auto; padding: 5.5rem 2rem; }
  .label { display: inline-block; font-size: .72rem; font-weight: 600; letter-spacing: .15em; text-transform: uppercase; color: var(--green-dark); background: var(--green-soft); padding: .3rem .8rem; border-radius: 100px; margin-bottom: 1rem; }
  h2 { font-family: var(--font-d); font-size: clamp(1.8rem,4vw,2.5rem); font-weight: 700; line-height: 1.2; letter-spacing: -.02em; margin-bottom: .75rem; }

  /* CTA */
  .cta-main { display: inline-block; font-family: var(--font); font-size: .95rem; font-weight: 600; color: var(--white); background: var(--green); padding: .85rem 2.2rem; border-radius: 100px; border: none; cursor: pointer; text-decoration: none; transition: all .2s; box-shadow: 0 4px 14px rgba(37,211,102,.3); }
  .cta-main:hover { background: #20c05c; transform: translateY(-1px); box-shadow: 0 6px 20px rgba(37,211,102,.4); }
  .cta-main:disabled { opacity: .5; cursor: not-allowed; transform: none; }
  .check { color: var(--green); font-weight: 700; }

  /* HERO */
  .hero { min-height: 100vh; display: grid; grid-template-columns: 1fr 1fr; align-items: center; gap: 3rem; padding-top: 7rem; }
  .hero-pill { display: inline-flex; align-items: center; gap: .5rem; font-size: .78rem; font-weight: 500; color: var(--green-dark); background: var(--green-soft); border: 1px solid rgba(37,211,102,.15); padding: .4rem 1rem; border-radius: 100px; margin-bottom: 1.5rem; }
  .pill-dot { width: 7px; height: 7px; background: var(--green); border-radius: 50%; animation: pulse 2s ease-in-out infinite; }
  @keyframes pulse { 0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(37,211,102,.4)} 50%{opacity:.7;box-shadow:0 0 0 6px rgba(37,211,102,0)} }
  .hero h1 { font-family: var(--font-d); font-size: clamp(2.1rem,4.5vw,2.9rem); font-weight: 700; line-height: 1.18; letter-spacing: -.025em; margin-bottom: 1.25rem; }
  .hero-accent { color: var(--green-dark); }
