---
const agents = [
  { name: "Sofía", role: "Ventas", desc: "Prospecta, califica y cierra ventas por WhatsApp. Tu mejor vendedora, 24/7.", tags: ["WhatsApp", "CRM", "Follow-ups"], image: "/agents/sofia.png" },
  { name: "Carlos", role: "Atención al Cliente", desc: "Resuelve dudas al instante y mantiene a tus clientes felices. Siempre amable.", tags: ["Soporte", "FAQ", "Tickets"], image: "/agents/carlos.png" },
  { name: "Valentina", role: "Coordinación", desc: "Agenda reuniones, envía recordatorios y optimiza tu calendario automáticamente.", tags: ["Calendario", "Recordatorios", "Booking"], image: "/agents/valentina.png" },
];
const plans = [
  { name: "Básico", hours: "1h/día", price: "80", desc: "Para empezar a probar", features: ["1 agente AI", "Respaldo humano", "Reportes semanales"] },
  { name: "Pro", hours: "4h/día", price: "250", desc: "Para negocios en crecimiento", popular: true, features: ["1 agente AI", "Respaldo prioritario", "Reportes diarios", "Personalización avanzada"] },
  { name: "Full", hours: "8h/día", price: "400", desc: "Máxima productividad", features: ["1 agente dedicado", "Respaldo 24/7", "Reportes tiempo real", "Integración custom", "Soporte prioritario"] },
];
---
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>AGENTES — Contrata tu primer empleado AI | Luminari</title>
  <meta name="description" content="Agentes AI autónomos con respaldo humano. Recibe un WhatsApp configurado y listo. Costos fijos desde $80/mes."/>
  <meta property="og:title" content="AGENTES — Tu primer empleado AI"/>
  <meta property="og:description" content="Agentes AI con respaldo humano. WhatsApp listo para trabajar. Desde $80/mes."/>
  <meta property="og:type" content="website"/>
  <meta property="og:url" content="https://agentes.luminari.agency"/>
  <meta property="og:image" content="https://agentes.luminari.agency/og.png"/>
  <meta name="twitter:card" content="summary_large_image"/>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
  <link rel="canonical" href="https://agentes.luminari.agency"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;700&family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet"/>
</head>
<body>

  <!-- ===== HERO (dark, full-bleed) ===== -->
  <div class="hero-wrap">
    <div class="aurora" aria-hidden="true">
      <div class="aurora-beam a1"></div>
      <div class="aurora-beam a2"></div>
      <div class="aurora-beam a3"></div>
    </div>
    <div class="grid-overlay" aria-hidden="true"></div>
    <nav>
      <a href="#" class="logo">◆ AGENTES</a>
      <div class="nav-r">
        <a href="#agentes" class="nav-link">Equipo</a>
        <a href="#planes" class="nav-link">Planes</a>
        <a href="#empezar" class="nav-cta">Empezar →</a>
      </div>
    </nav>

    <section class="hero">
      <div class="hero-text">
        <p class="hero-tag">Empleados AI con respaldo humano</p>
        <h1>Contrata un agente que<br/><span class="glow-text">trabaja por WhatsApp.</span></h1>
        <p class="hero-sub">Responde clientes, agenda citas y cierra ventas. Tú supervisas, la IA ejecuta. <strong>Desde $80/mes.</strong></p>
        <div class="hero-btns">
          <a href="#empezar" class="btn-glow">Contratar mi agente</a>
          <a href="#demo" class="btn-outline">Ver demo ↓</a>
        </div>
        <div class="hero-logos">
          <span class="hl-label">Métodos de pago:</span>
          <div class="hl-row">
            <span class="hl-chip">Yape</span>
            <span class="hl-chip">Plin</span>
            <span class="hl-chip">VISA</span>
            <span class="hl-chip">BCP</span>
            <span class="hl-chip">BBVA</span>
            <span class="hl-chip">Transferencia</span>
          </div>
        </div>
      </div>
      <div class="hero-phone" id="demo">
        <div class="phone">
          <div class="ph-notch"></div>
          <div class="wa">
            <div class="wa-top">
              <span class="wa-back">‹</span>
              <div class="wa-av">S</div>
              <div><div class="wa-n">Sofía — Ventas</div><div class="wa-s">en línea</div></div>
            </div>
            <div class="wa-msgs">
              <div class="wa-day">Hoy</div>
              <div class="msg msg-in"><p>Hola, vi su anuncio. ¿Cuánto cuesta?</p><span>10:32</span></div>
              <div class="msg msg-out"><p>¡Hola! 👋 El plan básico es $80/mes. Incluye 1h diaria y respaldo humano.</p><span>10:32 ✓✓</span></div>
              <div class="msg msg-out"><p>¿Agendamos una demo de 15 min? Puedo buscarte horario mañana 📅</p><span>10:33 ✓✓</span></div>
              <div class="msg msg-in"><p>Dale, mañana a las 10am</p><span>10:34</span></div>
              <div class="msg msg-out"><p>¡Listo! Agendado mañana 10am. Te envié la invitación. ✅</p><span>10:34 ✓✓</span></div>
            </div>
          </div>
        </div>
        <div class="phone-label">
          <span class="pl-dot"></span>
          Conversación real de un agente AI
        </div>
        <!-- Hand-drawn annotations -->
        <div class="ann ann-ai">
          <svg class="ann-arrow" width="50" height="40" viewBox="0 0 50 40"><path d="M45 5 C30 5, 15 10, 8 35" stroke="#25D366" stroke-width="2" fill="none" stroke-linecap="round"/><path d="M3 28 L8 35 L14 30" stroke="#25D366" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <span>¡Esto lo hace la IA!</span>
        </div>
        <div class="ann ann-auto">
          <span>Agenda sola 🤯</span>
          <svg class="ann-arrow" width="50" height="40" viewBox="0 0 50 40"><path d="M5 5 C20 5, 35 10, 42 35" stroke="#25D366" stroke-width="2" fill="none" stroke-linecap="round"/><path d="M36 30 L42 35 L47 28" stroke="#25D366" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
      </div>
    </section>
  </div>

  <!-- ===== STATS BAR ===== -->
  <div class="stats-bar">
    <div class="stats-inner">
      <div class="stat-item"><strong>24/7</strong><span>Disponibilidad</span></div>
      <div class="stat-div"></div>
      <div class="stat-item"><strong>< 5s</strong><span>Tiempo de respuesta</span></div>
      <div class="stat-div"></div>
      <div class="stat-item"><strong>100%</strong><span>Respaldo humano</span></div>
      <div class="stat-div"></div>
      <div class="stat-item"><strong>$80</strong><span>Desde / mes</span></div>
    </div>
  </div>

  <!-- ===== HOW IT WORKS ===== -->
  <section class="sec steps-sec">
    <span class="tag">Proceso</span>
    <h2>Tres pasos. Listo.</h2>
    <div class="steps-grid">
      <div class="step-card">
        <div class="sc-num">01</div>
        <h3>Nos cuentas qué necesitas</h3>
        <p>Ventas, soporte, agendamiento — tú defines el rol y las reglas.</p>
      </div>
      <div class="step-card">
        <div class="sc-num">02</div>
        <h3>Configuramos tu agente</h3>
        <p>Lo entrenamos con tu info, conectamos WhatsApp y asignamos respaldo humano.</p>
      </div>
      <div class="step-card">
        <div class="sc-num">03</div>
        <h3>Tu agente empieza a trabajar</h3>
        <p>Recibes un número de WhatsApp activo. Tu agente responde desde el día 1.</p>
      </div>
    </div>
  </section>

  <!-- ===== AGENTS ===== -->
  <section class="sec agents-sec" id="agentes">
    <span class="tag">Equipo</span>
    <h2>Conoce a tus agentes</h2>
    <div class="agents-grid">
      {agents.map((a) => (
        <div class="ag-card">
          <div class="ag-img-wrap">
            <img src={a.image} alt={a.name} loading="lazy"/>
          </div>
          <div class="ag-info">
            <span class="ag-role">{a.role}</span>
            <h3>{a.name}</h3>
            <p>{a.desc}</p>
            <div class="ag-tags">{a.tags.map(t => <span>{t}</span>)}</div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== PRICING ===== -->
  <section class="sec pricing-sec" id="planes">
    <span class="tag">Planes</span>
    <h2>Un sueldo fijo. Sin sorpresas.</h2>
    <p class="sec-sub">Sin cobros por token. Sin cargos ocultos. Cancela cuando quieras.</p>
    <div class="plans-grid">
      {plans.map((p) => (
        <div class={`pl-card ${p.popular ? 'pl-pop' : ''}`}>
          {p.popular && <span class="pl-badge">Popular</span>}
          <h3>{p.name}</h3>
          <p class="pl-hrs">{p.hours}</p>
          <div class="pl-price"><span class="pl-s">$</span><span class="pl-n">{p.price}</span><span class="pl-p">/mes</span></div>
          <p class="pl-desc">{p.desc}</p>
          <ul>{p.features.map(f => <li>✓ {f}</li>)}</ul>
          <a href="#empezar" class={p.popular ? 'btn-glow btn-sm' : 'btn-outline-dark btn-sm'}>Contratar</a>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== EMPEZAR (disguised waitlist) ===== -->
  <section class="sec start-sec" id="empezar">
    <div class="start-wrap">
      <div class="start-left">
        <h2>Empieza hoy</h2>
        <p>Completa tus datos y en menos de 24h tendrás tu agente funcionando.</p>
        <ul>
          <li>✓ Activo en menos de 24h</li>
          <li>✓ Precio fijo garantizado</li>
          <li>✓ Setup personalizado incluido</li>
          <li>✓ Cancela cuando quieras</li>
        </ul>
      </div>
      <form id="wl-form">
        <input type="text" name="name" placeholder="Tu nombre" required/>
        <input type="email" name="email" placeholder="tu@email.com" required/>
        <input type="text" name="company" placeholder="Empresa (opcional)"/>
        <select name="agentType" required>
          <option value="" disabled selected>¿Qué agente necesitas?</option>
          <option value="ventas">Ventas</option>
          <option value="atencion">Atención al cliente</option>
          <option value="agendamiento">Agendamiento de citas</option>
          <option value="soporte">Soporte técnico</option>
          <option value="community">Community manager</option>
          <option value="otro">Otro</option>
        </select>
        <textarea name="message" placeholder="Cuéntanos sobre tu negocio (opcional)" rows="3"></textarea>
        <button type="submit" class="btn-glow btn-full" id="sub-btn">Empezar ahora</button>
        <p id="form-msg" class="form-msg"></p>
      </form>
    </div>
  </section>

  <!-- ===== FOOTER ===== -->
  <footer>
    <span>◆ AGENTES <span class="by">by Luminari</span></span>
    <span class="copy">© 2026 Luminari</span>
  </footer>

  <script>
    // === Form ===
    const form = document.getElementById('wl-form') as HTMLFormElement;
    const msg = document.getElementById('form-msg')!;
    const btn = document.getElementById('sub-btn') as HTMLButtonElement;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      btn.disabled = true; btn.textContent = 'Procesando...';
      msg.textContent = ''; msg.className = 'form-msg';
      try {
        const data = Object.fromEntries(new FormData(form));
        const r = await fetch('https://agentes-api.luminari.agency/api/waitlist', {
          method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(data)
        });
        if (r.ok) { msg.textContent = '🎉 ¡Recibido! Te contactamos en menos de 24h.'; msg.className = 'form-msg ok'; form.reset(); }
        else { const j = await r.json(); throw new Error(j.message || 'Error'); }
      } catch (err: any) { msg.textContent = '❌ ' + err.message; msg.className = 'form-msg err'; }
      finally { btn.disabled = false; btn.textContent = 'Empezar ahora'; }
    });

    // === Scroll reveal ===
    const io = new IntersectionObserver((es) => {
      es.forEach(e => { if (e.isIntersecting) { (e.target as HTMLElement).style.opacity = '1'; (e.target as HTMLElement).style.transform = 'translateY(0)'; io.unobserve(e.target); }});
    }, { threshold: 0.1 });
    document.querySelectorAll('.step-card, .ag-card, .pl-card').forEach(el => {
      (el as HTMLElement).style.opacity = '0';
      (el as HTMLElement).style.transform = 'translateY(24px)';
      (el as HTMLElement).style.transition = 'opacity .6s ease, transform .6s ease';
      io.observe(el);
    });
    // Fallback
    setTimeout(() => {
      document.querySelectorAll('.step-card, .ag-card, .pl-card').forEach(el => {
        (el as HTMLElement).style.opacity = '1';
        (el as HTMLElement).style.transform = 'translateY(0)';
      });
    }, 2500);
  </script>
</body>
</html>

<style is:global>
  :root {
    --bg: #fafffe;
    --dark: #0a0f0d;
    --text: #1a2e23;
    --text2: #3d5a4a;
    --text3: #7a9484;
    --green: #25D366;
    --green-d: #128C7E;
    --green-dd: #075E54;
    --green-l: #DCF8C6;
    --border: rgba(0,60,30,0.08);
    --r: 18px;
    --r-sm: 10px;
    --mw: 1100px;
    --font: 'Inter', system-ui, sans-serif;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  html{scroll-behavior:smooth}
  body{font-family:var(--font);color:var(--text);line-height:1.6;-webkit-font-smoothing:antialiased;overflow-x:hidden;background:var(--bg)}

  /* === HERO DARK SECTION === */
  .hero-wrap{position:relative;background:var(--dark);overflow:hidden;min-height:100vh}

  /* Aurora gradient mesh */
  .aurora{position:absolute;inset:-20%;z-index:0;overflow:hidden;filter:blur(100px) saturate(1.8)}
  .aurora-beam{position:absolute;border-radius:50%}
  .a1{width:70%;height:60%;top:-5%;right:-5%;background:radial-gradient(ellipse,rgba(37,211,102,.5),rgba(0,200,120,.15) 50%,transparent 70%);animation:drift1 12s ease-in-out infinite}
  .a2{width:60%;height:65%;bottom:0;left:-5%;background:radial-gradient(ellipse,rgba(0,180,160,.35),rgba(18,140,126,.1) 50%,transparent 70%);animation:drift2 15s ease-in-out infinite}
  .a3{width:50%;height:50%;top:20%;left:30%;background:radial-gradient(ellipse,rgba(46,230,120,.25),rgba(0,220,180,.08) 50%,transparent 70%);animation:drift3 18s ease-in-out infinite}
  @keyframes drift1{0%,100%{transform:translate(0,0) scale(1) rotate(0deg)}50%{transform:translate(-40px,30px) scale(1.15) rotate(8deg)}}
  @keyframes drift2{0%,100%{transform:translate(0,0) scale(1) rotate(0deg)}50%{transform:translate(50px,-40px) scale(1.1) rotate(-6deg)}}
  @keyframes drift3{0%,100%{transform:translate(0,0) scale(1)}33%{transform:translate(-30px,20px) scale(1.2)}66%{transform:translate(20px,-30px) scale(.9)}}

  /* Subtle grid overlay */
  .grid-overlay{position:absolute;inset:0;z-index:0;background-image:
    linear-gradient(rgba(37,211,102,.045) 1px,transparent 1px),
    linear-gradient(90deg,rgba(37,211,102,.045) 1px,transparent 1px);
  background-size:70px 70px;mask-image:radial-gradient(ellipse 70% 60% at 50% 45%,black,transparent)}

  nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;justify-content:space-between;align-items:center;padding:1rem 2.5rem;background:rgba(10,15,13,0.5);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border-bottom:1px solid rgba(37,211,102,0.08)}
  .logo{font-size:.95rem;font-weight:800;letter-spacing:.12em;color:#fff;text-decoration:none}
  .nav-r{display:flex;align-items:center;gap:1.5rem}
  .nav-link{font-size:.85rem;color:rgba(255,255,255,.6);text-decoration:none;font-weight:500;transition:color .15s}
  .nav-link:hover{color:#fff}
  .nav-cta{font-size:.82rem;font-weight:600;color:var(--dark);background:var(--green);padding:.45rem 1.1rem;border-radius:100px;text-decoration:none;transition:all .2s}
  .nav-cta:hover{background:#2ee072;box-shadow:0 0 20px rgba(37,211,102,.3)}

  .hero{position:relative;z-index:1;max-width:var(--mw);margin:0 auto;padding:8rem 2rem 5rem;display:grid;grid-template-columns:1.1fr 0.9fr;align-items:center;gap:3rem}
  .hero-tag{font-size:.78rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--green);margin-bottom:1.25rem;display:flex;align-items:center;gap:.5rem}
  .hero-tag::before{content:'';width:24px;height:2px;background:var(--green);border-radius:2px}
  .hero h1{font-size:clamp(2.2rem,4.8vw,3.2rem);font-weight:900;line-height:1.1;letter-spacing:-.03em;color:#fff;margin-bottom:1.5rem}
  .glow-text{color:var(--green);text-shadow:0 0 40px rgba(37,211,102,.3)}
  .hero-sub{font-size:1.05rem;color:rgba(255,255,255,.55);line-height:1.75;margin-bottom:2rem;max-width:460px}
  .hero-sub strong{color:rgba(255,255,255,.85)}

  .hero-btns{display:flex;gap:1rem;margin-bottom:2.5rem;flex-wrap:wrap}
  .btn-glow{display:inline-flex;align-items:center;gap:.4rem;font-family:var(--font);font-size:.95rem;font-weight:700;color:var(--dark);background:var(--green);padding:.9rem 2rem;border-radius:100px;border:none;cursor:pointer;text-decoration:none;transition:all .25s;box-shadow:0 0 30px rgba(37,211,102,.2),0 4px 14px rgba(37,211,102,.3)}
  .btn-glow:hover{background:#2ee072;box-shadow:0 0 50px rgba(37,211,102,.3),0 6px 20px rgba(37,211,102,.4);transform:translateY(-1px)}
  .btn-glow:disabled{opacity:.5;cursor:not-allowed;transform:none}
  .btn-outline{font-size:.95rem;font-weight:500;color:rgba(255,255,255,.6);border:1px solid rgba(255,255,255,.15);padding:.85rem 1.8rem;border-radius:100px;text-decoration:none;transition:all .2s}
  .btn-outline:hover{color:#fff;border-color:rgba(255,255,255,.35);background:rgba(255,255,255,.04)}

  .hero-logos{display:flex;flex-direction:column;gap:.5rem}
  .hl-label{font-size:.7rem;color:rgba(255,255,255,.3);font-weight:500;letter-spacing:.05em}
  .hl-row{display:flex;gap:.4rem;flex-wrap:wrap}
  .hl-chip{font-size:.65rem;font-weight:600;color:rgba(255,255,255,.4);border:1px solid rgba(255,255,255,.1);padding:.2rem .55rem;border-radius:100px;background:rgba(255,255,255,.03)}

  /* Phone mockup */
  .hero-phone{display:flex;flex-direction:column;align-items:center;gap:.75rem;position:relative}
  .hero-phone::before{content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:420px;height:420px;background:radial-gradient(circle,rgba(37,211,102,.28),rgba(0,180,130,.12) 45%,transparent 70%);border-radius:50%;z-index:0;animation:phoneglow 4s ease-in-out infinite}
  @keyframes phoneglow{0%,100%{opacity:.8;transform:translate(-50%,-50%) scale(1)}50%{opacity:1;transform:translate(-50%,-50%) scale(1.15)}}
  .phone{background:#111;border-radius:32px;padding:6px;box-shadow:0 20px 80px rgba(0,0,0,.5),0 0 0 1px rgba(255,255,255,.06),0 0 80px rgba(37,211,102,.12);max-width:300px;width:100%;position:relative;z-index:1}
  .ph-notch{position:absolute;top:6px;left:50%;transform:translateX(-50%);width:80px;height:18px;background:#111;border-radius:0 0 12px 12px;z-index:5}
  .wa{border-radius:26px;overflow:hidden;background:#ECE5DD}
  .wa-top{background:var(--green-dd);color:#fff;padding:1.6rem .7rem .5rem;display:flex;align-items:center;gap:.4rem}
  .wa-back{font-size:1rem;opacity:.7}
  .wa-av{width:26px;height:26px;border-radius:50%;background:rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;font-size:.65rem;font-weight:700}
  .wa-n{font-size:.72rem;font-weight:600}
  .wa-s{font-size:.58rem;opacity:.7}
  .wa-msgs{padding:.4rem;display:flex;flex-direction:column;gap:.2rem}
  .wa-day{text-align:center;font-size:.58rem;color:#8696a0;background:rgba(255,255,255,.8);padding:.15rem .5rem;border-radius:6px;align-self:center;margin:.15rem 0}
  .msg{max-width:84%;padding:.35rem .5rem;border-radius:7px;font-size:.7rem;line-height:1.4}
  .msg span{display:block;text-align:right;font-size:.52rem;color:#8696a0;margin-top:.1rem}
  .msg-in{background:#fff;align-self:flex-start;border-radius:0 7px 7px 7px;box-shadow:0 1px 1px rgba(0,0,0,.04)}
  .msg-out{background:var(--green-l);align-self:flex-end;border-radius:7px 0 7px 7px}
  .phone-label{display:flex;align-items:center;gap:.4rem;font-size:.72rem;color:rgba(255,255,255,.35);font-weight:500}
  .pl-dot{width:6px;height:6px;background:var(--green);border-radius:50%;animation:pulse 2s infinite}
  @keyframes pulse{0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(37,211,102,.4)}50%{opacity:.6;box-shadow:0 0 0 5px rgba(37,211,102,0)}}

  /* === ANNOTATIONS === */
  .ann{position:absolute;z-index:3;font-family:'Caveat',cursive;font-size:1.1rem;font-weight:700;color:var(--green);display:flex;align-items:flex-start;gap:.2rem;white-space:nowrap;filter:drop-shadow(0 2px 8px rgba(0,0,0,.3))}
  .ann-ai{top:35%;right:-80px}
  .ann-ai span{margin-top:-5px}
  .ann-auto{bottom:25%;left:-70px}
  .ann-auto span{margin-top:-5px}
  @media(max-width:900px){.ann{display:none}}

  /* === STATS BAR === */
  .stats-bar{background:#fff;border-bottom:1px solid var(--border);position:relative;z-index:2}
  .stats-inner{max-width:var(--mw);margin:0 auto;padding:1.5rem 2rem;display:flex;justify-content:center;align-items:center;gap:2.5rem}
  .stat-item{text-align:center}
  .stat-item strong{display:block;font-size:1.4rem;font-weight:800;color:var(--green-dd);letter-spacing:-.02em}
  .stat-item span{font-size:.72rem;color:var(--text3);font-weight:500}
  .stat-div{width:1px;height:32px;background:var(--border)}

  /* === COMMON SECTION === */
