---
const agents = [
  { name: "Sofía", role: "Ventas", desc: "Prospecta, califica y cierra ventas por WhatsApp. Tu mejor vendedora, 24/7.", tags: ["WhatsApp", "CRM", "Follow-ups"], image: "/agents/sofia.png", link: "/ventas" },
  { name: "Carlos", role: "Atención al Cliente", desc: "Resuelve dudas al instante y mantiene a tus clientes felices. Siempre amable.", tags: ["Soporte", "FAQ", "Tickets"], image: "/agents/carlos.png", link: "/soporte" },
  { name: "Valentina", role: "Coordinación", desc: "Agenda reuniones, envía recordatorios y optimiza tu calendario automáticamente.", tags: ["Calendario", "Recordatorios", "Booking"], image: "/agents/valentina.png", link: "/citas" },
];
const plans = [
  { name: "Básico", hours: "1h/día", price: "80", pricePen: "300", desc: "Para empezar a probar", features: ["1 agente AI", "Respaldo humano", "Reportes semanales", "3 días gratis de prueba"] },
  { name: "Pro", hours: "4h/día", price: "250", pricePen: "950", desc: "Para negocios en crecimiento", popular: true, features: ["1 agente AI", "Respaldo prioritario", "Reportes diarios", "Personalización avanzada", "3 días gratis de prueba"] },
  { name: "Full", hours: "8h/día", price: "400", pricePen: "1,500", desc: "Máxima productividad", features: ["1 agente dedicado", "Respaldo 24/7", "Reportes tiempo real", "Integración custom", "Soporte prioritario", "3 días gratis de prueba"] },
];
---
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>AGENTES — Contrata tu primer empleado AI | Luminari</title>
  <meta name="description" content="Agentes AI autónomos con respaldo humano. Recibe un WhatsApp configurado y listo. Prueba 3 días gratis."/>
  <meta property="og:title" content="AGENTES — Tu primer empleado AI | Prueba gratis"/>
  <meta property="og:description" content="Agentes AI con respaldo humano. WhatsApp listo para trabajar. Prueba 3 días gratis."/>
  <meta property="og:type" content="website"/>
  <meta property="og:url" content="https://agentes.luminari.agency"/>
  <meta property="og:image" content="https://agentes.luminari.agency/og.png"/>
  <meta name="twitter:card" content="summary_large_image"/>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
  <link rel="canonical" href="https://agentes.luminari.agency"/>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "AGENTES by Luminari",
    "applicationCategory": "BusinessApplication",
    "description": "Agentes AI autónomos con respaldo humano para WhatsApp. Ventas, soporte y agendamiento automatizado.",
    "url": "https://agentes.luminari.agency",
    "offers": [
      { "@type": "Offer", "name": "Básico", "price": "80", "priceCurrency": "USD", "description": "1 agente AI, 1h/día, respaldo humano" },
      { "@type": "Offer", "name": "Pro", "price": "250", "priceCurrency": "USD", "description": "1 agente AI, 4h/día, respaldo prioritario" },
      { "@type": "Offer", "name": "Full", "price": "400", "priceCurrency": "USD", "description": "1 agente dedicado, 8h/día, respaldo 24/7" }
    ],
    "provider": {
      "@type": "Organization",
      "name": "Luminari",
      "url": "https://luminari.agency"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5",
      "ratingCount": "3",
      "bestRating": "5"
    }
  })}></script>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿Qué pasa si la IA no sabe responder?", "acceptedAnswer": { "@type": "Answer", "text": "Cada agente tiene respaldo humano. Si la IA no puede resolver algo, un humano de nuestro equipo toma el control de la conversación sin que el cliente lo note." }},
      { "@type": "Question", "name": "¿Necesito un número de WhatsApp nuevo?", "acceptedAnswer": { "@type": "Answer", "text": "Sí, te proporcionamos un número dedicado ya configurado. También podemos integrarlo con tu número existente según el plan." }},
      { "@type": "Question", "name": "¿Cuánto tarda en estar listo?", "acceptedAnswer": { "@type": "Answer", "text": "Menos de 24 horas. Nos cuentas qué necesitas, configuramos el agente con tu información y lo activamos." }},
      { "@type": "Question", "name": "¿Puedo cancelar cuando quiera?", "acceptedAnswer": { "@type": "Answer", "text": "Sí, sin penalidades ni contratos a largo plazo. Pagas mes a mes." }},
      { "@type": "Question", "name": "¿Los precios son en dólares o soles?", "acceptedAnswer": { "@type": "Answer", "text": "Los precios están en dólares (USD). Aceptamos Yape, Plin, transferencia bancaria, y tarjetas VISA." }},
      { "@type": "Question", "name": "¿Qué tipo de negocios atienden?", "acceptedAnswer": { "@type": "Answer", "text": "Clínicas, consultorios, tiendas, restaurantes, inmobiliarias — cualquier negocio que atienda clientes por WhatsApp." }}
    ]
  })}></script>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;700&family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet"/>
  <script defer src="https://umami.luminari.agency/script.js" data-website-id="9a5bb1d1-9bc1-417a-8b4b-72b44044d168"></script>
</head>
<body>

  <!-- ===== HERO (dark, full-bleed) ===== -->
  <div class="hero-wrap">
    <div class="aurora" aria-hidden="true">
      <div class="aurora-beam a1"></div>
      <div class="aurora-beam a2"></div>
      <div class="aurora-beam a3"></div>
    </div>
    <div class="grid-overlay" aria-hidden="true"></div>
    <nav>
      <a href="#" class="logo">◆ AGENTES</a>
      <button class="nav-toggle" id="nav-toggle" aria-label="Abrir menú" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
      <div class="nav-r" id="nav-menu">
        <a href="#calculadora" class="nav-link">Ahorro</a>
        <a href="#agentes" class="nav-link">Equipo</a>
        <a href="#planes" class="nav-link">Planes</a>
        <a href="/precios" class="nav-link">Precios</a>
        <a href="/blog" class="nav-link">Blog</a>
        <a href="#faq" class="nav-link">FAQ</a>
        <a href="#empezar" class="nav-cta">Probar gratis →</a>
      </div>
    </nav>

    <section class="hero">
      <div class="hero-text">
        <p class="hero-tag">Empleados AI con respaldo humano</p>
        <h1>Contrata un agente que<br/><span class="glow-text">trabaja por WhatsApp.</span></h1>
        <p class="hero-sub">Responde clientes, agenda citas y cierra ventas. Tú supervisas, la IA ejecuta. <strong>Prueba 3 días gratis.</strong></p>
        <div class="hero-btns">
          <a href="#empezar" class="btn-glow">Probar gratis 3 días →</a>
          <a href="#demo" class="btn-outline">Ver demo ↓</a>
        </div>
        <div class="hero-logos">
          <span class="hl-label">Métodos de pago:</span>
          <div class="hl-row">
            <span class="hl-chip">Yape</span>
            <span class="hl-chip">Plin</span>
            <span class="hl-chip">VISA</span>
            <span class="hl-chip">BCP</span>
            <span class="hl-chip">BBVA</span>
            <span class="hl-chip">Transferencia</span>
          </div>
        </div>
      </div>
      <div class="hero-phone" id="demo">
        <div class="phone">
          <div class="ph-notch"></div>
          <div class="wa">
            <div class="wa-top">
              <span class="wa-back">‹</span>
              <div class="wa-av">S</div>
              <div><div class="wa-n">Sofía — Ventas</div><div class="wa-s">en línea</div></div>
            </div>
            <div class="wa-msgs">
              <div class="wa-day">Hoy</div>
              <div class="msg msg-in"><p>Hola, vi su anuncio. ¿Cuánto cuesta?</p><span>10:32</span></div>
              <div class="msg msg-out"><p>¡Hola! 👋 El plan básico es $80/mes. Incluye 1h diaria y respaldo humano.</p><span>10:32 ✓✓</span></div>
              <div class="msg msg-out"><p>¿Agendamos una demo de 15 min? Puedo buscarte horario mañana 📅</p><span>10:33 ✓✓</span></div>
              <div class="msg msg-in"><p>Dale, mañana a las 10am</p><span>10:34</span></div>
              <div class="msg msg-out"><p>¡Listo! Agendado mañana 10am. Te envié la invitación. ✅</p><span>10:34 ✓✓</span></div>
            </div>
          </div>
        </div>
        <div class="phone-label">
          <span class="pl-dot"></span>
          Conversación real de un agente AI
        </div>
        <!-- Hand-drawn annotations -->
        <div class="ann ann-ai">
          <svg class="ann-arrow" width="50" height="40" viewBox="0 0 50 40"><path d="M45 5 C30 5, 15 10, 8 35" stroke="#25D366" stroke-width="2" fill="none" stroke-linecap="round"/><path d="M3 28 L8 35 L14 30" stroke="#25D366" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <span>¡Esto lo hace la IA!</span>
        </div>
        <div class="ann ann-auto">
          <span>Agenda sola 🤯</span>
          <svg class="ann-arrow" width="50" height="40" viewBox="0 0 50 40"><path d="M5 5 C20 5, 35 10, 42 35" stroke="#25D366" stroke-width="2" fill="none" stroke-linecap="round"/><path d="M36 30 L42 35 L47 28" stroke="#25D366" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
      </div>
    </section>
  </div>

  <!-- ===== STATS BAR ===== -->
  <div class="stats-bar">
    <div class="stats-inner">
      <div class="stat-item"><strong>24/7</strong><span>Disponibilidad</span></div>
      <div class="stat-div"></div>
      <div class="stat-item"><strong>< 5s</strong><span>Tiempo de respuesta</span></div>
      <div class="stat-div"></div>
      <div class="stat-item"><strong>100%</strong><span>Respaldo humano</span></div>
      <div class="stat-div"></div>
      <div class="stat-item"><strong>3 días</strong><span>Gratis de prueba</span></div>
    </div>
  </div>

  <!-- ===== ROI CALCULATOR ===== -->
  <section class="sec calc-sec" id="calculadora">
    <span class="tag">Ahorro</span>
    <h2>¿Cuánto te ahorras con un agente AI?</h2>
    <p class="sec-sub">Compara el costo de un empleado humano vs un agente AI de AGENTES.</p>
    <div class="calc-wrap">
      <div class="calc-left">
        <label class="calc-label">Sueldo mensual de un empleado (USD)</label>
        <input type="range" id="calc-salary" min="300" max="2000" value="800" step="50"/>
        <div class="calc-range-labels"><span>$300</span><span id="calc-salary-val">$800</span><span>$2,000</span></div>

        <label class="calc-label" style="margin-top:1.25rem">Horas diarias que necesitas</label>
        <input type="range" id="calc-hours" min="1" max="8" value="4" step="1"/>
        <div class="calc-range-labels"><span>1h</span><span id="calc-hours-val">4h</span><span>8h</span></div>
      </div>
      <div class="calc-right">
        <div class="calc-compare">
          <div class="calc-col calc-human">
            <span class="calc-col-label">👤 Empleado humano</span>
            <div class="calc-col-price" id="calc-human-price">$800<span>/mes</span></div>
            <ul>
              <li>Horario limitado</li>
              <li>Vacaciones, faltas</li>
              <li>Capacitación lenta</li>
              <li>1 conversación a la vez</li>
            </ul>
          </div>
          <div class="calc-vs">VS</div>
          <div class="calc-col calc-ai">
            <span class="calc-col-label">🤖 Agente AGENTES</span>
            <div class="calc-col-price" id="calc-ai-price">$250<span>/mes</span></div>
            <ul>
              <li>✓ Disponible 24/7</li>
              <li>✓ Nunca falta</li>
              <li>✓ Listo en 24h</li>
              <li>✓ Multiples chats simultáneos</li>
            </ul>
          </div>
        </div>
        <div class="calc-savings">
          Ahorras <strong id="calc-savings-val">$550</strong>/mes → <strong id="calc-savings-year">$6,600</strong>/año
        </div>
      </div>
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section class="sec steps-sec">
    <span class="tag">Proceso</span>
    <h2>Tres pasos. Listo.</h2>
    <div class="steps-grid">
      <div class="step-card">
        <div class="sc-num">01</div>
        <h3>Nos cuentas qué necesitas</h3>
        <p>Ventas, soporte, agendamiento — tú defines el rol y las reglas.</p>
      </div>
      <div class="step-card">
        <div class="sc-num">02</div>
        <h3>Configuramos tu agente</h3>
        <p>Lo entrenamos con tu info, conectamos WhatsApp y asignamos respaldo humano.</p>
      </div>
      <div class="step-card">
        <div class="sc-num">03</div>
        <h3>Tu agente empieza a trabajar</h3>
        <p>Recibes un número de WhatsApp activo. Tu agente responde desde el día 1.</p>
      </div>
    </div>
  </section>

  <!-- ===== AGENTS ===== -->
  <section class="sec agents-sec" id="agentes">
    <span class="tag">Equipo</span>
    <h2>Conoce a tus agentes</h2>
    <div class="agents-grid">
      {agents.map((a) => (
        <div class="ag-card">
          <div class="ag-img-wrap">
            <img src={a.image} alt={a.name} loading="lazy"/>
          </div>
          <div class="ag-info">
            <span class="ag-role">{a.role}</span>
            <h3>{a.name}</h3>
            <p>{a.desc}</p>
            <div class="ag-tags">{a.tags.map(t => <span>{t}</span>)}</div>
            <a href={a.link} class="ag-link">Ver más →</a>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== PRICING ===== -->
  <section class="sec pricing-sec" id="planes">
    <span class="tag">Planes</span>
    <h2>Un sueldo fijo. Sin sorpresas.</h2>
    <p class="sec-sub">Sin cobros por token. Sin cargos ocultos. Cancela cuando quieras.</p>
    <div class="plans-grid">
      {plans.map((p) => (
        <div class={`pl-card ${p.popular ? 'pl-pop' : ''}`}>
          {p.popular && <span class="pl-badge">Popular</span>}
          <h3>{p.name}</h3>
          <p class="pl-hrs">{p.hours}</p>
          <div class="pl-price"><span class="pl-s">$</span><span class="pl-n">{p.price}</span><span class="pl-p">/mes</span></div>
          <p class="pl-pen">≈ S/{p.pricePen} soles</p>
          <p class="pl-desc">{p.desc}</p>
          <ul>{p.features.map(f => <li>✓ {f}</li>)}</ul>
          <a href="#empezar" class={p.popular ? 'btn-glow btn-sm' : 'btn-outline-dark btn-sm'}>Probar gratis</a>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== SOCIAL PROOF ===== -->
  <section class="sec proof-sec">
    <span class="tag">Resultados</span>
    <h2>Lo que dicen nuestros clientes</h2>
    <div class="proof-grid">
      <div class="proof-card">
        <div class="proof-stars">★★★★★</div>
        <p>"Sofía cerró 3 ventas la primera semana. Yo ni tuve que intervenir."</p>
        <div class="proof-author">
          <strong>Dr. Cristian C.</strong>
          <span>Clínica dental · Chiclayo</span>
        </div>
      </div>
      <div class="proof-card">
        <div class="proof-stars">★★★★★</div>
        <p>"Mis pacientes reciben respuesta inmediata. Antes perdía consultas por no contestar a tiempo."</p>
        <div class="proof-author">
          <strong>Dr. Juan J.</strong>
          <span>Geriatra · Lima</span>
        </div>
      </div>
      <div class="proof-card">
        <div class="proof-stars">★★★★★</div>
        <p>"El agente agenda citas solo. Yo solo reviso el calendario cada mañana. Increíble."</p>
        <div class="proof-author">
          <strong>Dr. Gustavo D.</strong>
          <span>Especialista · Lima</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="sec faq-sec" id="faq">
    <span class="tag">Preguntas</span>
    <h2>Preguntas frecuentes</h2>
    <div class="faq-list">
      <details class="faq-item">
        <summary>¿Qué pasa si la IA no sabe responder?</summary>
        <p>Cada agente tiene respaldo humano. Si la IA no puede resolver algo, un humano de nuestro equipo toma el control de la conversación sin que el cliente lo note.</p>
      </details>
      <details class="faq-item">
        <summary>¿Necesito un número de WhatsApp nuevo?</summary>
        <p>Sí, te proporcionamos un número dedicado ya configurado. También podemos integrarlo con tu número existente según el plan.</p>
      </details>
      <details class="faq-item">
        <summary>¿Cuánto tarda en estar listo?</summary>
        <p>Menos de 24 horas. Nos cuentas qué necesitas, configuramos el agente con tu información y lo activamos.</p>
      </details>
      <details class="faq-item">
        <summary>¿Puedo cancelar cuando quiera?</summary>
        <p>Sí, sin penalidades ni contratos a largo plazo. Pagas mes a mes.</p>
      </details>
      <details class="faq-item">
        <summary>¿Los precios son en dólares o soles?</summary>
        <p>Los precios están en dólares (USD). Aceptamos Yape, Plin, transferencia bancaria, y tarjetas VISA.</p>
      </details>
      <details class="faq-item">
        <summary>¿Qué tipo de negocios atienden?</summary>
        <p>Clínicas, consultorios, tiendas, restaurantes, inmobiliarias — cualquier negocio que atienda clientes por WhatsApp. Mira nuestras soluciones para <a href="/clinicas" style="color:var(--green-d);font-weight:600">clínicas</a>, <a href="/restaurantes" style="color:var(--green-d);font-weight:600">restaurantes</a> e <a href="/inmobiliarias" style="color:var(--green-d);font-weight:600">inmobiliarias</a>, <a href="/abogados" style="color:var(--green-d);font-weight:600">abogados</a> y <a href="/contadores" style="color:var(--green-d);font-weight:600">contadores</a>.</p>
      </details>
    </div>
  </section>

  <!-- ===== EMPEZAR (disguised waitlist) ===== -->
  <section class="sec start-sec" id="empezar">
    <div class="start-wrap">
      <div class="start-left">
        <div class="free-trial-badge">🎁 PRUEBA GRATIS</div>
        <div class="urgency-badge" id="urgency-badge">⚡ Solo 3 cupos disponibles</div>
        <h2>3 días gratis. Sin compromiso.</h2>
        <p>Completa tus datos y en menos de 24h tendrás tu agente funcionando. Si no te convence, no pagas nada.</p>
        <ul>
          <li>✓ Activo en menos de 24h</li>
          <li>✓ 3 días completamente gratis</li>
          <li>✓ Sin tarjeta de crédito</li>
          <li>✓ Setup personalizado incluido</li>
          <li>✓ Cancela cuando quieras</li>
        </ul>
      </div>
      <form id="wl-form">
        <input type="text" name="name" placeholder="Tu nombre" required/>
        <input type="email" name="email" placeholder="tu@email.com" required/>
        <input type="tel" name="phone" placeholder="WhatsApp (ej: 951234567)" required/>
        <input type="text" name="company" placeholder="Empresa (opcional)"/>
        <select name="agentType" required>
          <option value="" disabled selected>¿Qué agente necesitas?</option>
          <option value="ventas">Ventas</option>
          <option value="atencion">Atención al cliente</option>
          <option value="agendamiento">Agendamiento de citas</option>
          <option value="soporte">Soporte técnico</option>
          <option value="community">Community manager</option>
          <option value="otro">Otro</option>
        </select>
        <textarea name="message" placeholder="Cuéntanos sobre tu negocio (opcional)" rows="3"></textarea>
        <button type="submit" class="btn-glow btn-full" id="sub-btn">Activar prueba gratis →</button>
        <p id="form-msg" class="form-msg"></p>
        <div class="form-wa-alt">
          <span>¿Prefieres escribirnos directo?</span>
          <a href="https://wa.me/51987654321?text=Hola%21%20Quiero%20probar%20un%20agente%20AI%20para%20mi%20negocio.%20%F0%9F%9A%80" target="_blank" rel="noopener" class="wa-alt-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.612.616l4.532-1.474A11.943 11.943 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75c-2.17 0-4.207-.69-5.87-1.882l-.42-.312-2.689.875.891-2.633-.345-.445A9.722 9.722 0 012.25 12c0-5.385 4.365-9.75 9.75-9.75S21.75 6.615 21.75 12s-4.365 9.75-9.75 9.75z"/></svg>
            Escríbenos por WhatsApp
          </a>
        </div>
      </form>
    </div>
  </section>

  <!-- Floating CTA -->
  <a href="https://wa.me/51987654321?text=Hola%21%20Quiero%20probar%20un%20agente%20AI%20para%20mi%20negocio.%20%F0%9F%9A%80" target="_blank" rel="noopener" class="wa-float" aria-label="Escríbenos por WhatsApp">
