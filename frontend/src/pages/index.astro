---
// Landing page - AGENTES by Luminari — CEO-focused redesign with WhatsApp mockup
---
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AGENTES - IA que trabaja por tu negocio</title>
  <meta name="description" content="Tu mano derecha digital. Pídele lo que necesites por WhatsApp y tu agente lo ejecuta. Reportes, agenda, cobros, desarrollo web y más." />
  <meta property="og:title" content="AGENTES - IA que trabaja por tu negocio" />
  <meta property="og:description" content="Un asistente ejecutivo AI que administra tu empresa desde WhatsApp. Pide y ejecuta." />
  <meta property="og:image" content="/og.png" />
  <meta property="og:type" content="website" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link href="https://unpkg.com/aos@2.3.4/dist/aos.css" rel="stylesheet" />
  <script defer src="https://umami.luminari.agency/script.js" data-website-id="9a5bb1d1-9bc1-417a-8b4b-72b44044d168"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --green: #25D366;
      --green-dark: #128C7E;
      --green-light: #e8faf0;
      --white: #ffffff;
      --gray-50: #f9fafb;
      --gray-100: #f3f4f6;
      --gray-200: #e5e7eb;
      --gray-300: #d1d5db;
      --gray-400: #9ca3af;
      --gray-500: #6b7280;
      --gray-600: #4b5563;
      --gray-700: #374151;
      --gray-800: #1f2937;
      --gray-900: #111827;
    }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', -apple-system, sans-serif;
      background: var(--white);
      color: var(--gray-800);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }
    .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
    .mono-label {
      font-size: 10px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.12em; color: var(--gray-400);
    }

    /* REVEAL */
    .reveal { opacity: 1; transform: translateY(0); }
    .reveal-ready .reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.6s ease, transform 0.6s ease; }
    .reveal-ready .reveal.visible { opacity: 1; transform: translateY(0); }
    .reveal-ready .reveal[data-delay="1"] { transition-delay: 0.1s; }
    .reveal-ready .reveal[data-delay="2"] { transition-delay: 0.2s; }
    .reveal-ready .reveal[data-delay="3"] { transition-delay: 0.3s; }
    @media (prefers-reduced-motion: reduce) {
      .reveal-ready .reveal { opacity: 1; transform: none; transition: none; }
    }

    /* NAV */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      background: rgba(255,255,255,0.9); backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--gray-100);
      transition: all 0.3s;
    }
    nav.scrolled { background: rgba(255,255,255,0.97); box-shadow: 0 4px 24px rgba(0,0,0,0.08); backdrop-filter: blur(32px); }
    nav .inner {
      max-width: 1200px; margin: 0 auto; padding: 0 24px;
      display: flex; align-items: center; justify-content: space-between;
      height: 56px;
    }
    .logo { text-decoration: none; font-weight: 800; font-size: 1.1rem; letter-spacing: .12em; color: var(--gray-900); text-transform: uppercase; }
    .logo .diamond { color: var(--green); }
    nav .links { display: flex; align-items: center; gap: 28px; }
    nav .links a {
      text-decoration: none; font-size: 11px; font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.08em;
      color: var(--gray-500); transition: color 0.2s;
    }
    nav .links a:hover { color: var(--green); }
    .nav-cta {
      background: var(--green) !important; color: white !important;
      padding: 7px 20px; border-radius: 8px;
      box-shadow: 0 4px 16px rgba(37,211,102,0.2);
      transition: all 0.2s;
    }
    .nav-cta:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(37,211,102,0.3); }

    /* HERO */
    .hero {
      padding: 120px 0 0;
      position: relative;
      overflow: hidden;
    }
    .hero-content {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 48px;
      align-items: center;
    }
    .hero-text { text-align: left; }
    .hero-badge {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(37,211,102,0.06); border: 1px solid rgba(37,211,102,0.15);
      padding: 4px 14px; border-radius: 6px;
      font-size: 10px; text-transform: uppercase; font-weight: 700;
      letter-spacing: 0.12em; color: var(--green);
      margin-bottom: 24px;
    }
    .hero-badge .dot {
      position: relative; width: 6px; height: 6px;
    }
    .hero-badge .dot::before {
      content: ''; position: absolute; inset: 0;
      border-radius: 50%; background: var(--green);
      animation: ping 2s infinite;
    }
    .hero-badge .dot::after {
      content: ''; position: absolute; inset: 0;
      border-radius: 50%; background: var(--green);
    }
    @keyframes ping { 0% { transform: scale(1); opacity: 1; } 75%,100% { transform: scale(2.5); opacity: 0; } }
    .hero h1 {
      font-size: clamp(2.2rem, 4.5vw, 3.8rem);
      font-weight: 900; line-height: 0.92; letter-spacing: -0.04em;
      color: var(--gray-900); margin-bottom: 20px;
    }
    .hero h1 em { font-style: normal; color: var(--green); }
    .hero p.hero-sub {
      font-size: clamp(0.95rem, 1.8vw, 1.1rem);
      color: var(--gray-500); max-width: 480px;
      line-height: 1.6; font-weight: 500; margin-bottom: 32px;
    }
    .hero-cta {
      display: inline-flex; align-items: center; gap: 10px;
      background: var(--green); color: white; padding: 16px 40px;
      border-radius: 8px; font-weight: 700; font-size: 13px;
      text-transform: uppercase; letter-spacing: 0.1em;
      text-decoration: none; transition: all 0.3s;
      box-shadow: 0 8px 32px rgba(37,211,102,0.25);
    }
    .hero-cta:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(37,211,102,0.35); }
    .hero-cta svg { width: 16px; height: 16px; }

    /* PHONE MOCKUP */
    .phone-mockup-wrapper {
      display: flex; justify-content: center; align-items: center;
    }
    .phone-mockup {
      width: 320px;
      background: #111;
      border-radius: 40px;
      padding: 12px;
      box-shadow:
        0 25px 60px rgba(0,0,0,0.3),
        0 0 0 1px rgba(255,255,255,0.1) inset,
        0 0 80px rgba(37,211,102,0.08);
      position: relative;
      animation: phoneFloat 6s ease-in-out infinite;
    }
    @keyframes phoneFloat {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-8px); }
    }
    .phone-notch {
      width: 120px; height: 28px;
      background: #111;
      border-radius: 0 0 16px 16px;
      position: absolute;
      top: 12px; left: 50%; transform: translateX(-50%);
      z-index: 10;
    }
    .phone-screen {
      background: #ECE5DD;
      border-radius: 28px;
      overflow: hidden;
      position: relative;
    }
    /* WhatsApp Header */
    .wa-header {
      background: #128C7E;
      padding: 38px 16px 12px;
      display: flex; align-items: center; gap: 10px;
      color: white;
    }
    .wa-avatar {
      width: 32px; height: 32px; border-radius: 50%;
      background: linear-gradient(135deg, var(--green), #0a7a6a);
      display: flex; align-items: center; justify-content: center;
      font-size: 14px; font-weight: 700;
    }
    .wa-header-info { flex: 1; }
    .wa-header-name { font-size: 14px; font-weight: 600; }
    .wa-header-status { font-size: 10px; opacity: 0.8; }
    /* Chat Messages */
    .wa-chat {
      padding: 12px 10px;
      display: flex; flex-direction: column; gap: 6px;
      min-height: 320px;
    }
    .wa-msg {
      max-width: 85%;
      padding: 7px 10px 4px;
      border-radius: 8px;
      font-size: 12.5px;
      line-height: 1.4;
      position: relative;
      animation: msgAppear 0.4s ease both;
    }
    .wa-msg:nth-child(1) { animation-delay: 0.5s; }
    .wa-msg:nth-child(2) { animation-delay: 1.2s; }
    .wa-msg:nth-child(3) { animation-delay: 2.5s; }
    .wa-msg:nth-child(4) { animation-delay: 3.2s; }
    @keyframes msgAppear {
      from { opacity: 0; transform: translateY(8px) scale(0.95); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }
    .wa-msg.sent {
      align-self: flex-end;
      background: #DCF8C6;
      border-radius: 8px 0 8px 8px;
      color: #303030;
    }
    .wa-msg.received {
      align-self: flex-start;
      background: white;
      border-radius: 0 8px 8px 8px;
      color: #303030;
    }
    .wa-time {
      display: block; text-align: right;
      font-size: 9px; color: #999; margin-top: 2px;
    }
    .wa-file-preview {
      background: #f0f0f0;
      border-radius: 6px;
      padding: 8px 10px;
      margin: 6px 0 2px;
      display: flex; align-items: center; gap: 8px;
      font-size: 11px;
    }
    .wa-file-icon {
      width: 28px; height: 34px;
      background: #e74c3c;
      border-radius: 3px;
      display: flex; align-items: center; justify-content: center;
      color: white; font-size: 8px; font-weight: 700;
    }
    .wa-file-info { flex: 1; }
    .wa-file-name { font-weight: 600; color: #303030; font-size: 11px; }
    .wa-file-size { color: #999; font-size: 9px; }
    /* WhatsApp input bar */
    .wa-input-bar {
      background: #f0f0f0;
      padding: 8px 10px;
      display: flex; align-items: center; gap: 8px;
    }
    .wa-input-field {
      flex: 1; background: white; border-radius: 20px;
      padding: 8px 14px; font-size: 12px; color: #999;
    }
    .wa-send-btn {
      width: 34px; height: 34px; border-radius: 50%;
      background: #128C7E;
      display: flex; align-items: center; justify-content: center;
    }
    .wa-send-btn svg { width: 16px; height: 16px; color: white; }

    /* STATS BAR */
    .stats-bar {
      margin-top: 48px;
      padding: 20px 0;
      background: var(--gray-50);
      border-top: 1px solid var(--gray-100);
      border-bottom: 1px solid var(--gray-100);
    }
    .stats-bar .inner {
      display: flex; align-items: center; justify-content: center;
      gap: 40px; flex-wrap: wrap;
    }
    .stat-item {
      display: flex; align-items: center; gap: 8px;
      font-size: 11px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.08em; color: var(--gray-500);
    }
    .stat-item svg { width: 14px; height: 14px; color: var(--green); }

    /* PAIN POINTS */
    .pain-points {
      padding: 80px 0;
      background: linear-gradient(180deg, #f0faf4 0%, #f7fdf9 100%);
      border-bottom: 1px solid var(--gray-100);
    }
    .pain-points .section-header { margin-bottom: 48px; }
    .pain-points .section-header p {
      font-size: 15px; color: var(--gray-500); margin-top: 12px; font-weight: 500;
    }
    .pain-grid {
      display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px;
      max-width: 800px; margin: 0 auto;
    }
    .pain-card {
      padding: 28px; border-radius: 16px;
      background: rgba(255,255,255,0.7);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(37,211,102,0.12);
      transition: all 0.3s;
    }
    .pain-card:hover {
      box-shadow: 0 8px 32px rgba(37,211,102,0.1);
      border-color: rgba(37,211,102,0.25);
      transform: translateY(-2px);
    }
    .pain-card .pain-icon {
      width: 40px; height: 40px; border-radius: 10px;
      background: rgba(37,211,102,0.08);
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 14px;
    }
    .pain-card .pain-icon svg { width: 20px; height: 20px; color: var(--green); }
    .pain-card h3 {
      font-size: 14px; font-weight: 800; color: var(--gray-900);
      margin-bottom: 6px; text-transform: uppercase; letter-spacing: -0.01em;
    }
    .pain-card p { font-size: 13px; color: var(--gray-500); line-height: 1.5; }
    @media (max-width: 600px) { .pain-grid { grid-template-columns: 1fr; } }

    /* CAPABILITIES GRID */
    .capabilities { padding: 64px 0; border-bottom: 1px solid var(--gray-100); }
    .section-header { text-align: center; margin-bottom: 40px; }
    .section-header h2 {
      font-size: clamp(1.5rem, 3vw, 2.2rem);
      font-weight: 900; color: var(--gray-900); letter-spacing: -0.03em;
      text-transform: uppercase;
    }
    .cap-grid {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;
    }
    .cap-card {
      padding: 24px; border-radius: 12px;
      border: 1px solid var(--gray-200); background: white;
      transition: all 0.3s;
    }
    .cap-card:hover { box-shadow: 0 6px 24px rgba(0,0,0,0.06); border-color: rgba(37,211,102,0.3); }
    .cap-card .cap-icon {
      width: 36px; height: 36px; background: var(--gray-50);
      border: 1px solid var(--gray-200); border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 14px; color: var(--green); transition: all 0.3s;
    }
    .cap-card:hover .cap-icon { background: var(--green); color: white; }
    .cap-card .cap-icon svg { width: 18px; height: 18px; }
    .cap-card h3 {
      font-size: 13px; font-weight: 700; text-transform: uppercase;
      letter-spacing: -0.01em; color: var(--gray-900); margin-bottom: 6px;
    }
    .cap-card p { font-size: 12px; color: var(--gray-500); line-height: 1.5; }

    /* PRICING */
    .pricing { padding: 64px 0; background: var(--gray-50); border-bottom: 1px solid var(--gray-100); }
    .pricing-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; max-width: 720px; margin: 0 auto; }
    .pricing-card {
      padding: 32px; border-radius: 20px; display: flex; flex-direction: column;
      border: 1px solid var(--gray-200); background: white;
      transition: all 0.3s;
    }
    .pricing-card:hover { box-shadow: 0 12px 48px rgba(0,0,0,0.08); }
    .pricing-card.featured {
      background: var(--green); color: white; border-color: var(--green);
      box-shadow: 0 12px 48px rgba(37,211,102,0.2);
      position: relative; overflow: hidden;
    }
    .pricing-badge-ent {
      position: absolute; top: 24px; right: 24px;
      background: rgba(255,255,255,0.2); color: white;
      font-size: 8px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.12em; padding: 3px 10px; border-radius: 999px;
      backdrop-filter: blur(8px);
    }
    .pricing-card h3 {
      font-size: 1.3rem; font-weight: 900; text-transform: uppercase;
      letter-spacing: -0.01em; margin-bottom: 4px;
    }
    .pricing-card .pricing-desc {
      font-size: 13px; margin-bottom: 20px; line-height: 1.5;
    }
    .pricing-card:not(.featured) .pricing-desc { color: var(--gray-400); }
    .featured .pricing-desc { color: rgba(255,255,255,0.8); }
    .price-amount { font-size: 2.5rem; font-weight: 900; letter-spacing: -0.03em; }
    .price-period { font-size: 13px; font-weight: 700; margin-left: 4px; }
    .pricing-card:not(.featured) .price-period { color: var(--gray-400); }
    .featured .price-period { color: rgba(255,255,255,0.6); }
    .price-soles { margin-top: 2px; margin-bottom: 20px; }
    .pricing-features { list-style: none; display: flex; flex-direction: column; gap: 10px; margin-bottom: 24px; flex: 1; }
    .pricing-features li {
      display: flex; align-items: center; gap: 10px;
      font-size: 13px; font-weight: 500;
    }
    .pricing-features li svg { width: 14px; height: 14px; flex-shrink: 0; }
    .pricing-card:not(.featured) .pricing-features li { color: var(--gray-600); }
    .pricing-card:not(.featured) .pricing-features li svg { color: var(--green); }
    .featured .pricing-features li { color: rgba(255,255,255,0.9); }
    .featured .pricing-features li svg { color: white; }
    .pricing-btn {
      display: block; width: 100%; text-align: center; padding: 14px;
      border-radius: 8px; font-weight: 700; font-size: 12px;
      text-transform: uppercase; letter-spacing: 0.1em;
      text-decoration: none; transition: all 0.2s; border: none; cursor: pointer;
    }
    .pricing-btn.dark { background: var(--gray-900); color: white; }
    .pricing-btn.dark:hover { background: black; }
    .pricing-btn.white { background: white; color: var(--green); box-shadow: 0 8px 24px rgba(0,0,0,0.1); }
    .pricing-btn.white:hover { background: var(--gray-50); }

    /* FORM */
    .form-section { padding: 64px 0; border-bottom: 1px solid var(--gray-100); }
    .form-inner { max-width: 520px; margin: 0 auto; }
    .form-wrapper {
      background: white; padding: 32px; border-radius: 20px;
      border: 1px solid var(--gray-200);
      box-shadow: 0 12px 48px rgba(0,0,0,0.06);
    }
    .progress-bar { display: flex; gap: 6px; margin-bottom: 24px; }
    .progress-bar .bar {
      flex: 1; height: 3px; border-radius: 999px;
      background: var(--gray-200); transition: background 0.4s;
    }
    .progress-bar .bar.active { background: var(--green); }
    .form-step { display: none; animation: fadeIn 0.4s ease; }
    .form-step.active { display: block; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    .form-step h3 { font-size: 1.1rem; font-weight: 800; color: var(--gray-900); margin-bottom: 6px; }
    .form-step .hint { font-size: 13px; color: var(--gray-500); margin-bottom: 20px; }
    label.field { display: block; margin-bottom: 14px; }
    label.field span { display: block; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--gray-400); margin-bottom: 5px; margin-left: 4px; }
    input[type="text"], input[type="email"], input[type="tel"] {
      width: 100%; padding: 14px; border: 1.5px solid var(--gray-100);
      border-radius: 10px; font-size: 14px; font-family: inherit;
      background: var(--gray-50); color: var(--gray-900);
      transition: all 0.2s;
    }
    input:focus { outline: none; border-color: var(--green); background: white; box-shadow: 0 0 0 3px rgba(37,211,102,0.12); }
    .checkbox-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
    .checkbox-item {
      display: flex; align-items: center; gap: 8px;
      padding: 10px 12px; border: 1.5px solid var(--gray-200);
      border-radius: 10px; cursor: pointer; transition: all 0.2s;
      font-size: 13px; font-weight: 500; color: var(--gray-700);
    }
    .checkbox-item:hover { border-color: var(--green); }
    .checkbox-item.checked { border-color: var(--green); background: var(--green-light); color: #15803d; }
    .checkbox-item input { display: none; }
    .form-nav { display: flex; gap: 10px; margin-top: 20px; }
    .btn-back {
      flex: 1; padding: 14px; border-radius: 10px;
      border: 1.5px solid var(--gray-200); background: white;
      font-family: inherit; font-weight: 600; font-size: 13px;
      color: var(--gray-600); cursor: pointer; transition: all 0.2s;
    }
    .btn-back:hover { border-color: var(--gray-400); }
    .btn-next, .btn-submit {
      flex: 2; padding: 14px; border-radius: 10px;
      border: none; background: var(--green);
      font-family: inherit; font-weight: 700; font-size: 13px;
      color: white; cursor: pointer; transition: all 0.2s;
    }
    .btn-next:hover, .btn-submit:hover { box-shadow: 0 4px 16px rgba(37,211,102,0.35); transform: translateY(-1px); }
    .btn-next:disabled, .btn-submit:disabled { opacity: 0.5; cursor: not-allowed; transform: none; box-shadow: none; }
    .success-msg { display: none; text-align: center; padding: 16px; }
    .success-msg.show { display: block; animation: fadeIn 0.5s ease; }
    .success-msg h3 { font-size: 1.2rem; font-weight: 800; color: var(--gray-900); margin-bottom: 6px; }
    .success-msg p { color: var(--gray-500); font-size: 13px; }

    /* FAQ */
    .faq { padding: 64px 0; }
    .faq-list { max-width: 700px; margin: 0 auto; background: white; border: 1px solid var(--gray-200); border-radius: 16px; padding: 16px 24px; }
    .faq-item { border-bottom: 1px solid var(--gray-100); padding: 14px 0; }
    .faq-item:last-child { border-bottom: none; }
    .faq-question {
      display: flex; align-items: center; justify-content: space-between;
      width: 100%; padding: 0; cursor: pointer; background: none; border: none;
      font-family: inherit; text-align: left;
      font-size: 13px; font-weight: 700; text-transform: uppercase;
      letter-spacing: -0.01em; color: var(--gray-900); transition: color 0.2s;
    }
    .faq-question:hover { color: var(--green); }
    .faq-toggle {
      width: 22px; height: 22px; border-radius: 50%;
      background: var(--gray-50); display: flex; align-items: center; justify-content: center;
      transition: all 0.3s; flex-shrink: 0;
    }
    .faq-toggle svg { width: 12px; height: 12px; color: var(--gray-400); transition: transform 0.3s; }
    .faq-item.open .faq-toggle { background: var(--green); }
    .faq-item.open .faq-toggle svg { color: white; transform: rotate(180deg); }
    .faq-answer { max-height: 0; overflow: hidden; transition: max-height 0.4s ease; }
    .faq-item.open .faq-answer { max-height: 200px; }
    .faq-answer p { font-size: 13px; color: var(--gray-500); line-height: 1.6; padding-top: 12px; max-width: 550px; }

    /* FOOTER */
    footer {
      padding: 40px 0; border-top: 1px solid var(--gray-100); background: var(--gray-50);
    }
    footer .inner {
      max-width: 1200px; margin: 0 auto; padding: 0 24px;
      display: flex; justify-content: space-between; align-items: center;
    }
    footer .brand { display: flex; flex-direction: column; align-items: flex-start; gap: 12px; }
    footer .brand-logo { display: flex; align-items: center; gap: 8px; }
    footer .brand-logo .li { width: 22px; height: 22px; background: var(--green); border-radius: 4px; display: flex; align-items: center; justify-content: center; }
    footer .brand-logo .li svg { width: 11px; height: 11px; color: white; }
    footer .brand-logo span { font-weight: 900; font-size: 1rem; text-transform: uppercase; letter-spacing: -0.03em; }
    footer .foot-links { display: flex; gap: 32px; }
    footer .foot-links a { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--gray-400); text-decoration: none; transition: color 0.2s; }
    footer .foot-links a:hover { color: var(--green); }

    /* MOBILE */
    @media (max-width: 768px) {
      .hero-content { grid-template-columns: 1fr; text-align: center; }
      .hero-text { text-align: center; }
      .hero p.hero-sub { margin-left: auto; margin-right: auto; }
      .phone-mockup { width: 280px; }
      .cap-grid { grid-template-columns: 1fr 1fr; }
      .pricing-grid { grid-template-columns: 1fr; max-width: 360px; }
      .checkbox-grid { grid-template-columns: 1fr; }
      .stats-bar .inner { gap: 20px; }
      .stat-item { font-size: 10px; }
      nav .links a:not(.nav-cta) { display: none; }
      footer .inner { flex-direction: column; gap: 24px; text-align: center; }
      footer .brand { align-items: center; }
    }
    @media (max-width: 480px) {
      .cap-grid { grid-template-columns: 1fr; }
      .phone-mockup { width: 260px; }
    }

    /* HERO ENTRANCE ANIMATION */
    .hero-anim {
      opacity: 0; transform: translateY(24px);
      animation: heroIn 0.7s ease-out forwards;
    }
    @keyframes heroIn {
      to { opacity: 1; transform: translateY(0); }
    }

    /* MARQUEE BAR */
    .marquee-bar {
      background: #075E54; padding: .6rem 0; overflow: hidden; white-space: nowrap;
    }
    .marquee-track {
      display: flex; gap: 3rem; animation: marquee 25s linear infinite;
      font-size: .75rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: .2em; color: #fff;
    }
    @keyframes marquee { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

    /* REVEAL CUSTOM */
    .rv { opacity: 0; transform: translateY(30px); transition: 0.6s cubic-bezier(.16,1,.3,1); }
    .rv.show { opacity: 1; transform: none; }
    .rv-d1 { transition-delay: 0.1s; }
    .rv-d2 { transition-delay: 0.2s; }
    .rv-d3 { transition-delay: 0.3s; }
    .rv-d4 { transition-delay: 0.4s; }
    .rv-d5 { transition-delay: 0.5s; }
    .rv-d6 { transition-delay: 0.6s; }

    /* ENHANCED CARD HOVER */
    .pain-card:hover, .cap-card:hover {
      transform: translateY(-3px) scale(1.02);
      box-shadow: 0 12px 40px rgba(37,211,102,0.12);
    }

    /* PHONE ENHANCED */
    .phone-mockup {
      box-shadow:
        0 30px 80px rgba(0,0,0,0.35),
        0 0 0 1px rgba(255,255,255,0.1) inset,
        0 0 120px rgba(37,211,102,0.1),
        0 60px 100px rgba(0,0,0,0.15);
    }

    /* PULSE RING */
    .hero-badge .dot::before {
      animation: pulseRing 2s cubic-bezier(0.4,0,0.6,1) infinite;
    }
    @keyframes pulseRing {
      0% { transform: scale(1); opacity: 0.8; }
      50% { transform: scale(3); opacity: 0; }
      100% { transform: scale(3); opacity: 0; }
    }
  </style>
</head>
