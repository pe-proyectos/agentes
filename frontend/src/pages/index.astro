            <p>Tu solicitud fue recibida. Para activar tu prueba gratis más rápido, escríbenos por WhatsApp:</p>
            <a href="https://wa.me/51987654321?text=${encodeURIComponent(`Hola! Soy ${userName}, acabo de registrarme en AGENTES para una prueba gratis. 🚀`)}" target="_blank" rel="noopener" class="btn-glow btn-full wa-btn">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="vertical-align:middle;margin-right:6px"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.612.616l4.532-1.474A11.943 11.943 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75c-2.17 0-4.207-.69-5.87-1.882l-.42-.312-2.689.875.891-2.633-.345-.445A9.722 9.722 0 012.25 12c0-5.385 4.365-9.75 9.75-9.75S21.75 6.615 21.75 12s-4.365 9.75-9.75 9.75z"/></svg>
              Escribir por WhatsApp
            </a>
            <p class="success-sub">O espera, te contactamos en menos de 24h 📩</p>
          `;
          form.parentNode?.insertBefore(successDiv, form);
        }
        else { const j = await r.json(); throw new Error(j.message || 'Error'); }
      } catch (err: any) { msg.textContent = '❌ ' + err.message; msg.className = 'form-msg err'; }
      finally { btn.disabled = false; btn.textContent = 'Activar prueba gratis →'; }
    });

    // === Scroll reveal ===
    const io = new IntersectionObserver((es) => {
      es.forEach(e => { if (e.isIntersecting) { (e.target as HTMLElement).style.opacity = '1'; (e.target as HTMLElement).style.transform = 'translateY(0)'; io.unobserve(e.target); }});
    }, { threshold: 0.1 });
    document.querySelectorAll('.step-card, .ag-card, .pl-card, .proof-card, .faq-item').forEach(el => {
      (el as HTMLElement).style.opacity = '0';
      (el as HTMLElement).style.transform = 'translateY(24px)';
      (el as HTMLElement).style.transition = 'opacity .6s ease, transform .6s ease';
      io.observe(el);
    });
    // === ROI Calculator ===
    const plans_map: Record<string, number> = { '1': 80, '2': 80, '3': 80, '4': 250, '5': 250, '6': 250, '7': 250, '8': 400 };
    const salarySlider = document.getElementById('calc-salary') as HTMLInputElement;
    const hoursSlider = document.getElementById('calc-hours') as HTMLInputElement;
    function updateCalc() {
      const salary = Number(salarySlider.value);
      const hours = Number(hoursSlider.value);
      const aiPrice = hours <= 1 ? 80 : hours <= 4 ? 250 : 400;
      const savings = Math.max(0, salary - aiPrice);
      document.getElementById('calc-salary-val')!.textContent = `$${salary}`;
      document.getElementById('calc-hours-val')!.textContent = `${hours}h`;
      document.getElementById('calc-human-price')!.innerHTML = `$${salary}<span>/mes</span>`;
      document.getElementById('calc-ai-price')!.innerHTML = `$${aiPrice}<span>/mes</span>`;
      document.getElementById('calc-savings-val')!.textContent = `$${savings}`;
      document.getElementById('calc-savings-year')!.textContent = `$${(savings * 12).toLocaleString()}`;
    }
    salarySlider.addEventListener('input', updateCalc);
    hoursSlider.addEventListener('input', updateCalc);
    updateCalc();

    // === Dynamic month in urgency badge ===
    const months = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
    const urgBadge = document.querySelector('.urgency-badge');
    if (urgBadge) urgBadge.textContent = `⚡ Solo 3 cupos disponibles en ${months[new Date().getMonth()]}`;

    // === Sticky CTA on scroll ===
    const stickyCta = document.getElementById('sticky-cta');
    const empezarSec = document.getElementById('empezar');
    if (stickyCta && empezarSec) {
      let lastY = 0;
      window.addEventListener('scroll', () => {
        const y = window.scrollY;
        const empRect = empezarSec.getBoundingClientRect();
        const show = y > 400 && empRect.top > window.innerHeight;
        stickyCta.classList.toggle('visible', show);
        lastY = y;
      }, { passive: true });
    }

    // Fallback
    setTimeout(() => {
      document.querySelectorAll('.step-card, .ag-card, .pl-card, .proof-card, .faq-item').forEach(el => {
        (el as HTMLElement).style.opacity = '1';
        (el as HTMLElement).style.transform = 'translateY(0)';
      });
    }, 2500);
  </script>
</body>
