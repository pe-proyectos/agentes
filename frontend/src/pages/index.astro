---
const agents = [
  {
    name: "Sofía",
    role: "Ventas",
    desc: "Prospecta, califica leads y cierra ventas por WhatsApp 24/7.",
    image: "/agents/sofia.png",
  },
  {
    name: "Carlos",
    role: "Atención al Cliente",
    desc: "Resuelve dudas, gestiona reclamos y mantiene felices a tus clientes.",
    image: "/agents/carlos.png",
  },
  {
    name: "Valentina",
    role: "Agendamiento",
    desc: "Coordina citas, envía recordatorios y optimiza tu calendario.",
    image: "/agents/valentina.png",
  },
];

const plans = [
  { emoji: "☕", name: "Básico", hours: "1h/día", price: "$80", desc: "Perfecto para empezar" },
  { emoji: "🕐", name: "Media Jornada", hours: "4h/día", price: "$250", desc: "El más popular", popular: true },
  { emoji: "💼", name: "Jornada Completa", hours: "8h/día", price: "$400", desc: "Máxima productividad" },
];
---

<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AGENTES — Contrata tu primer empleado AI</title>
  <meta name="description" content="Trabajadores AI autónomos con respaldo humano. Costos fijos como un sueldo." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
</head>
<body>
  <!-- Floating shapes -->
  <div class="shape shape-1"></div>
  <div class="shape shape-2"></div>
  <div class="shape shape-3"></div>

  <!-- Nav -->
  <nav>
    <a href="#" class="logo">AGENTES</a>
    <a href="#waitlist" class="nav-cta">Únete</a>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-badge">✨ El futuro del trabajo ya llegó</div>
    <h1>Contrata tu primer<br/><span class="gradient-text">empleado AI</span></h1>
    <p class="hero-sub">
      Un trabajador autónomo con respaldo humano. Te damos un WhatsApp, lo configuras, y trabaja para ti.<br/>
      <strong>Costos fijos mensuales. Como un sueldo.</strong>
    </p>
    <a href="#waitlist" class="btn-primary">Unirme a la waitlist →</a>
  </section>

  <!-- How it works -->
  <section class="how">
    <div class="how-grid">
      <div class="how-step">
        <span class="step-number">01</span>
        <h3>Cuéntanos qué necesitas</h3>
        <p>Ventas, atención al cliente, agendamiento... tú defines el rol.</p>
      </div>
      <div class="how-step">
        <span class="step-number">02</span>
        <h3>Configuramos tu agente</h3>
        <p>Lo entrenamos con tu información y le damos respaldo humano.</p>
      </div>
      <div class="how-step">
        <span class="step-number">03</span>
        <h3>Recibe un WhatsApp listo</h3>
        <p>Tu agente empieza a trabajar. Tú supervisas cuando quieras.</p>
      </div>
    </div>
  </section>

  <!-- Agents -->
  <section class="agents" id="agentes">
    <h2>Conoce a tu<br/><span class="gradient-text">equipo AI</span></h2>
    <div class="agents-grid">
      {agents.map((agent) => (
        <div class="agent">
          <div class="agent-image-wrap">
            <div class="agent-glow"></div>
            <img src={agent.image} alt={agent.name} class="agent-img" />
          </div>
          <span class="agent-role">{agent.role}</span>
          <h3 class="agent-name">{agent.name}</h3>
          <p class="agent-desc">{agent.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Pricing -->
  <section class="pricing" id="pricing">
    <h2>Planes simples,<br/><span class="gradient-text">sin sorpresas</span></h2>
    <div class="pricing-grid">
      {plans.map((plan) => (
        <div class={`plan ${plan.popular ? 'plan-popular' : ''}`}>
          {plan.popular && <span class="popular-tag">Popular</span>}
          <span class="plan-emoji">{plan.emoji}</span>
          <h3 class="plan-name">{plan.name}</h3>
          <p class="plan-hours">{plan.hours}</p>
          <div class="plan-price">
            <span class="price-amount">{plan.price}</span>
            <span class="price-period">/mes</span>
          </div>
          <p class="plan-desc">{plan.desc}</p>
          <a href="#waitlist" class="btn-plan">Comenzar →</a>
        </div>
      ))}
    </div>
  </section>

  <!-- Waitlist -->
  <section class="waitlist" id="waitlist">
    <h2>Únete a la<br/><span class="gradient-text">waitlist</span></h2>
    <p class="waitlist-sub">Sé de los primeros en tener tu empleado AI.</p>
    <form id="waitlist-form">
      <div class="form-row">
        <input type="text" name="name" placeholder="Tu nombre" required />
        <input type="email" name="email" placeholder="tu@email.com" required />
      </div>
      <div class="form-row">
        <input type="text" name="company" placeholder="Empresa (opcional)" />
        <select name="agentType" required>
          <option value="" disabled selected>¿Qué tipo de agente necesitas?</option>
          <option value="ventas">Ventas</option>
          <option value="atencion">Atención al cliente</option>
          <option value="agendamiento">Agendamiento de citas</option>
          <option value="soporte">Soporte técnico</option>
          <option value="community">Community manager</option>
          <option value="otro">Otro</option>
        </select>
      </div>
      <textarea name="message" placeholder="Cuéntanos más sobre tu negocio (opcional)" rows="3"></textarea>
      <button type="submit" class="btn-primary btn-submit">Unirme a la waitlist →</button>
      <div id="form-status" class="form-status"></div>
    </form>
  </section>

  <!-- Footer -->
  <footer>
    <span class="logo">AGENTES</span>
    <span class="footer-by">by Luminari</span>
    <span class="footer-copy">© 2025 Luminari</span>
  </footer>

  <script>
    const form = document.getElementById('waitlist-form') as HTMLFormElement;
    const status = document.getElementById('form-status')!;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('.btn-submit') as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = 'Enviando...';
      status.textContent = '';
      status.className = 'form-status';

      try {
        const data = Object.fromEntries(new FormData(form));
        const res = await fetch('/api/waitlist', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        const json = await res.json();
        if (res.ok) {
          status.textContent = '🎉 ¡Estás en la lista! Te contactaremos pronto.';
          status.classList.add('success');
          form.reset();
        } else {
          throw new Error(json.message || 'Error al enviar');
        }
      } catch (err: any) {
        status.textContent = `❌ ${err.message}`;
        status.classList.add('error');
      } finally {
        btn.disabled = false;
        btn.textContent = 'Unirme a la waitlist →';
      }
    });
  </script>
</body>
</html>

<style is:global>
  :root {
    --bg: #0a0a0f;
    --bg-subtle: #12121a;
    --text: #f0f0f5;
    --text-muted: #8888a0;
    --accent-1: #7c5cff;
    --accent-2: #00d4ff;
    --accent-gradient: linear-gradient(135deg, var(--accent-1), var(--accent-2));
    --radius: 16px;
    --max-w: 1100px;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Inter', system-ui, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    overflow-x: hidden;
    position: relative;
  }

  /* Floating shapes */
  .shape {
    position: fixed;
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.15;
    pointer-events: none;
    z-index: 0;
  }
  .shape-1 {
    width: 600px; height: 600px;
    background: var(--accent-1);
    top: -200px; right: -200px;
  }
  .shape-2 {
    width: 400px; height: 400px;
    background: var(--accent-2);
    bottom: 20%; left: -150px;
  }
  .shape-3 {
    width: 500px; height: 500px;
    background: #ff6bca;
    bottom: -200px; right: 20%;
  }

  /* Nav */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 3rem;
    z-index: 100;
    backdrop-filter: blur(20px);
    background: rgba(10, 10, 15, 0.7);
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .logo {
    font-size: 1.2rem;
    font-weight: 900;
    letter-spacing: 0.2em;
    text-decoration: none;
    color: var(--text);
  }
  .nav-cta {
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    color: var(--accent-2);
    border: 1px solid rgba(0, 212, 255, 0.3);
    padding: 0.5rem 1.5rem;
    border-radius: 100px;
    transition: all 0.3s;
  }
  .nav-cta:hover {
    background: rgba(0, 212, 255, 0.1);
    border-color: var(--accent-2);
  }

  /* Typography */
  .gradient-text {
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  h1 {
    font-size: clamp(3rem, 8vw, 5.5rem);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.03em;
  }

  h2 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 3rem;
  }

  section {
    position: relative;
    z-index: 1;
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 6rem 2rem;
  }

  /* Buttons */
  .btn-primary {
    display: inline-block;
    background: var(--accent-gradient);
    color: #fff;
    font-weight: 700;
    font-size: 1rem;
    padding: 1rem 2.5rem;
    border-radius: 100px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.3s;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(124, 92, 255, 0.4);
  }

  /* Hero */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.5rem;
    padding-top: 8rem;
  }
  .hero-badge {
    display: inline-block;
    width: fit-content;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--accent-2);
    background: rgba(0, 212, 255, 0.08);
    border: 1px solid rgba(0, 212, 255, 0.15);
    padding: 0.5rem 1.2rem;
    border-radius: 100px;
  }
  .hero-sub {
    font-size: 1.15rem;
    color: var(--text-muted);
    max-width: 520px;
    line-height: 1.7;
  }

  /* How it works */
  .how {
    padding: 4rem 2rem;
  }
  .how-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
  }
  .how-step { position: relative; }
  .step-number {
    font-size: 5rem;
    font-weight: 900;
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    opacity: 0.2;
    line-height: 1;
    display: block;
    margin-bottom: -1rem;
  }
  .how-step h3 {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }
  .how-step p {
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  /* Agents */
  .agents { text-align: center; }
  .agents-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
    margin-top: 4rem;
  }
  .agent {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }
  .agent-image-wrap {
    position: relative;
    width: 220px;
    height: 280px;
    margin-bottom: 1rem;
  }
  .agent-glow {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 180px;
    height: 180px;
    background: var(--accent-gradient);
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0.3;
  }
  .agent-img {
    position: relative;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: bottom;
    z-index: 1;
    filter: drop-shadow(0 20px 40px rgba(0,0,0,0.5));
  }
  .agent-role {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent-2);
  }
  .agent-name {
    font-size: 1.5rem;
    font-weight: 800;
  }
  .agent-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    max-width: 260px;
  }

  /* Pricing */
  .pricing { text-align: center; }
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-top: 3rem;
  }
  .plan {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: var(--radius);
    padding: 2.5rem 2rem;
    text-align: center;
    position: relative;
    transition: transform 0.3s, border-color 0.3s;
  }
  .plan:hover {
    transform: translateY(-4px);
    border-color: rgba(255,255,255,0.12);
  }
  .plan-popular {
    border-color: rgba(124, 92, 255, 0.4);
    background: rgba(124, 92, 255, 0.05);
  }
  .popular-tag {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--accent-gradient);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.3rem 1.2rem;
    border-radius: 100px;
  }
  .plan-emoji { font-size: 2.5rem; display: block; margin-bottom: 1rem; }
  .plan-name { font-size: 1.2rem; font-weight: 700; margin-bottom: 0.25rem; }
  .plan-hours { color: var(--text-muted); font-size: 0.9rem; margin-bottom: 1.5rem; }
  .plan-price { margin-bottom: 1rem; }
  .price-amount { font-size: 3rem; font-weight: 900; }
  .price-period { color: var(--text-muted); font-size: 0.9rem; }
  .plan-desc { color: var(--text-muted); font-size: 0.85rem; margin-bottom: 1.5rem; }
  .btn-plan {
    display: inline-block;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
    text-decoration: none;
    border: 1px solid rgba(255,255,255,0.15);
    padding: 0.7rem 1.8rem;
    border-radius: 100px;
    transition: all 0.3s;
  }
  .btn-plan:hover {
    background: rgba(255,255,255,0.05);
    border-color: rgba(255,255,255,0.3);
  }

  /* Waitlist */
  .waitlist { text-align: center; max-width: 650px; }
  .waitlist-sub {
    color: var(--text-muted);
    margin-bottom: 2.5rem;
    font-size: 1.1rem;
  }
  form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-align: left;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  input, select, textarea {
    width: 100%;
    padding: 1rem 1.2rem;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    color: var(--text);
    font-family: inherit;
    font-size: 0.95rem;
    outline: none;
    transition: border-color 0.3s;
  }
  input:focus, select:focus, textarea:focus {
    border-color: var(--accent-1);
  }
  input::placeholder, textarea::placeholder {
    color: var(--text-muted);
  }
  select { cursor: pointer; }
  select option { background: var(--bg); color: var(--text); }
  textarea { resize: vertical; min-height: 80px; }
  .btn-submit {
    width: 100%;
    font-size: 1rem;
    margin-top: 0.5rem;
  }
  .form-status {
    text-align: center;
    font-size: 0.95rem;
    min-height: 1.5em;
  }
  .form-status.success { color: #4ade80; }
  .form-status.error { color: #f87171; }

  /* Footer */
  footer {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    justify-content: center;
    padding: 3rem 2rem;
    border-top: 1px solid rgba(255,255,255,0.05);
    flex-wrap: wrap;
  }
  .footer-by {
    color: var(--text-muted);
    font-size: 0.85rem;
  }
  .footer-copy {
    color: var(--text-muted);
    font-size: 0.8rem;
    margin-left: auto;
  }

  /* Responsive */
  @media (max-width: 768px) {
    nav { padding: 1rem 1.5rem; }
    section { padding: 4rem 1.5rem; }
    .how-grid { grid-template-columns: 1fr; gap: 2rem; }
    .agents-grid { grid-template-columns: 1fr; gap: 4rem; }
    .pricing-grid { grid-template-columns: 1fr; max-width: 360px; margin-inline: auto; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>
