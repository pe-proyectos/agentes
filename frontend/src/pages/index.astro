---
const agents = [
  {
    name: "Sofía",
    role: "Agente de Ventas",
    desc: "Prospecta clientes, califica leads y cierra ventas por WhatsApp. Trabaja 24/7 sin descanso.",
    tags: ["WhatsApp", "CRM", "Follow-ups"],
    image: "/agents/sofia.png",
  },
  {
    name: "Carlos",
    role: "Atención al Cliente",
    desc: "Resuelve dudas al instante, gestiona reclamos y mantiene a tus clientes felices.",
    tags: ["Soporte", "FAQ", "Tickets"],
    image: "/agents/carlos.png",
  },
  {
    name: "Valentina",
    role: "Coordinadora de Citas",
    desc: "Agenda reuniones, envía recordatorios automáticos y optimiza tu calendario.",
    tags: ["Calendario", "Recordatorios", "Booking"],
    image: "/agents/valentina.png",
  },
];

const plans = [
  { emoji: "☕", name: "Básico", hours: "1h / día", price: "80", desc: "Ideal para probar el servicio", features: ["1 agente AI", "Respaldo humano", "Reportes semanales"] },
  { emoji: "🕐", name: "Media Jornada", hours: "4h / día", price: "250", desc: "Para negocios en crecimiento", popular: true, features: ["1 agente AI", "Respaldo humano prioritario", "Reportes diarios", "Personalización avanzada"] },
  { emoji: "💼", name: "Jornada Completa", hours: "8h / día", price: "400", desc: "Máxima productividad", features: ["1 agente AI dedicado", "Respaldo humano 24/7", "Reportes en tiempo real", "Integración personalizada", "Soporte prioritario"] },
];
---

<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AGENTES — Contrata tu primer empleado AI</title>
  <meta name="description" content="Trabajadores AI autónomos con respaldo humano. Costos fijos como un sueldo." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
</head>
<body>
  <!-- Background elements -->
  <div class="bg-grid"></div>
  <div class="glow glow-1"></div>
  <div class="glow glow-2"></div>
  <div class="glow glow-3"></div>

  <!-- Nav -->
  <nav>
    <div class="nav-inner">
      <a href="#" class="logo">
        <span class="logo-icon">◆</span>
        AGENTES
      </a>
      <div class="nav-links">
        <a href="#agentes">Agentes</a>
        <a href="#pricing">Planes</a>
        <a href="#waitlist" class="nav-cta">Únete →</a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-content">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        Aceptando nuevos clientes
      </div>
      <h1>
        Contrata tu primer
        <span class="hero-highlight">empleado AI</span>
      </h1>
      <p class="hero-sub">
        Un trabajador autónomo con respaldo humano. Te damos un WhatsApp,
        lo configuras, y trabaja para ti. <strong>Costos fijos. Como un sueldo.</strong>
      </p>
      <div class="hero-actions">
        <a href="#waitlist" class="btn-primary">
          <span>Unirme a la waitlist</span>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="#agentes" class="btn-ghost">Conoce al equipo</a>
      </div>
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-value">24/7</span>
          <span class="stat-label">Disponibilidad</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-value">$80</span>
          <span class="stat-label">Desde / mes</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-value">100%</span>
          <span class="stat-label">Respaldo humano</span>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="how">
    <div class="section-label">Proceso</div>
    <h2>Así de simple funciona</h2>
    <div class="how-grid">
      <div class="how-step">
        <div class="step-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <span class="step-num">01</span>
        <h3>Cuéntanos qué necesitas</h3>
        <p>Ventas, atención al cliente, agendamiento... tú defines el rol de tu agente.</p>
      </div>
      <div class="how-connector">
        <svg width="40" height="2" viewBox="0 0 40 2"><line x1="0" y1="1" x2="40" y2="1" stroke="rgba(124,92,255,0.3)" stroke-width="2" stroke-dasharray="4 4"/></svg>
      </div>
      <div class="how-step">
        <div class="step-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <span class="step-num">02</span>
        <h3>Configuramos tu agente</h3>
        <p>Lo entrenamos con tu información y le asignamos respaldo humano profesional.</p>
      </div>
      <div class="how-connector">
        <svg width="40" height="2" viewBox="0 0 40 2"><line x1="0" y1="1" x2="40" y2="1" stroke="rgba(124,92,255,0.3)" stroke-width="2" stroke-dasharray="4 4"/></svg>
      </div>
      <div class="how-step">
        <div class="step-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <span class="step-num">03</span>
        <h3>Recibe un WhatsApp listo</h3>
        <p>Tu agente empieza a trabajar. Tú supervisas cuando quieras.</p>
      </div>
    </div>
  </section>

  <!-- Agents -->
  <section class="agents" id="agentes">
    <div class="section-label">Equipo</div>
    <h2>Conoce a tus agentes</h2>
    <div class="agents-grid">
      {agents.map((agent, i) => (
        <div class="agent" style={`--delay: ${i * 0.1}s`}>
          <div class="agent-visual">
            <div class="agent-backdrop"></div>
            <img src={agent.image} alt={agent.name} class="agent-photo" loading="lazy" />
            <div class="agent-status">
              <span class="status-dot"></span>
              Disponible
            </div>
          </div>
          <div class="agent-info">
            <span class="agent-role-label">{agent.role}</span>
            <h3 class="agent-name">{agent.name}</h3>
            <p class="agent-desc">{agent.desc}</p>
            <div class="agent-tags">
              {agent.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Pricing -->
  <section class="pricing" id="pricing">
    <div class="section-label">Planes</div>
    <h2>Precios simples, sin sorpresas</h2>
    <p class="pricing-sub">Paga un precio fijo mensual. Sin cargos ocultos, sin cobros por token.</p>
    <div class="pricing-grid">
      {plans.map((plan) => (
        <div class={`plan ${plan.popular ? 'plan-popular' : ''}`}>
          {plan.popular && <div class="popular-badge">Más popular</div>}
          <div class="plan-header">
            <span class="plan-emoji">{plan.emoji}</span>
            <h3 class="plan-name">{plan.name}</h3>
            <p class="plan-hours">{plan.hours}</p>
          </div>
          <div class="plan-price">
            <span class="price-currency">$</span>
            <span class="price-amount">{plan.price}</span>
            <span class="price-period">/mes</span>
          </div>
          <p class="plan-desc">{plan.desc}</p>
          <ul class="plan-features">
            {plan.features.map((f) => (
              <li>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M13.3 4L6 11.3 2.7 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                {f}
              </li>
            ))}
          </ul>
          <a href="#waitlist" class={`btn-plan ${plan.popular ? 'btn-plan-primary' : ''}`}>
            Comenzar →
          </a>
        </div>
      ))}
    </div>
  </section>

  <!-- Waitlist -->
  <section class="waitlist" id="waitlist">
    <div class="waitlist-inner">
      <div class="waitlist-left">
        <div class="section-label">Waitlist</div>
        <h2>Reserva tu agente</h2>
        <p>Sé de los primeros en tener tu empleado AI. Estamos aceptando un número limitado de clientes.</p>
        <div class="waitlist-perks">
          <div class="perk">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M16.7 5L7.5 14.2 3.3 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>Acceso anticipado</span>
          </div>
          <div class="perk">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M16.7 5L7.5 14.2 3.3 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>Precio de lanzamiento garantizado</span>
          </div>
          <div class="perk">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M16.7 5L7.5 14.2 3.3 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>Configuración personalizada gratis</span>
          </div>
        </div>
      </div>
      <form id="waitlist-form">
        <input type="text" name="name" placeholder="Tu nombre" required />
        <input type="email" name="email" placeholder="tu@email.com" required />
        <input type="text" name="company" placeholder="Empresa (opcional)" />
        <select name="agentType" required>
          <option value="" disabled selected>¿Qué agente necesitas?</option>
          <option value="ventas">Ventas</option>
          <option value="atencion">Atención al cliente</option>
          <option value="agendamiento">Agendamiento de citas</option>
          <option value="soporte">Soporte técnico</option>
          <option value="community">Community manager</option>
          <option value="otro">Otro</option>
        </select>
        <textarea name="message" placeholder="Cuéntanos sobre tu negocio (opcional)" rows="3"></textarea>
        <button type="submit" class="btn-primary btn-submit">
          <span>Unirme a la waitlist</span>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div id="form-status" class="form-status"></div>
      </form>
    </div>
  </section>

  <!-- Footer -->
  <footer>
    <div class="footer-inner">
      <div class="footer-brand">
        <span class="logo"><span class="logo-icon">◆</span> AGENTES</span>
        <span class="footer-by">by Luminari</span>
      </div>
      <span class="footer-copy">© 2025 Luminari. Todos los derechos reservados.</span>
    </div>
  </footer>

  <script>
    const form = document.getElementById('waitlist-form') as HTMLFormElement;
    const status = document.getElementById('form-status')!;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('.btn-submit') as HTMLButtonElement;
      const btnText = btn.querySelector('span')!;
      btn.disabled = true;
      btnText.textContent = 'Enviando...';
      status.textContent = '';
      status.className = 'form-status';

      try {
        const data = Object.fromEntries(new FormData(form));
        const res = await fetch('https://agentes-api.luminari.agency/api/waitlist', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        const json = await res.json();
        if (res.ok) {
          status.textContent = '🎉 ¡Estás en la lista! Te contactaremos pronto.';
          status.classList.add('success');
          form.reset();
        } else {
          throw new Error(json.message || 'Error al enviar');
        }
      } catch (err: any) {
        status.textContent = `❌ ${err.message}`;
        status.classList.add('error');
      } finally {
        btn.disabled = false;
        btnText.textContent = 'Unirme a la waitlist';
      }
    });

    // Intersection Observer for animations
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

    document.querySelectorAll('.agent, .how-step, .plan').forEach(el => observer.observe(el));
  </script>
</body>
</html>

<style is:global>
  :root {
    --bg: #08080c;
    --bg-card: rgba(255,255,255,0.02);
    --bg-card-hover: rgba(255,255,255,0.04);
    --border: rgba(255,255,255,0.06);
    --border-hover: rgba(255,255,255,0.12);
    --text: #eeeef0;
    --text-secondary: #9494a8;
    --text-muted: #5e5e72;
    --accent: #7c5cff;
    --accent-light: #a78bff;
    --accent-cyan: #00d4ff;
    --accent-gradient: linear-gradient(135deg, var(--accent) 0%, var(--accent-cyan) 100%);
    --max-w: 1120px;
    --radius: 20px;
    --radius-sm: 12px;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    font-family: 'Inter', -apple-system, system-ui, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
  }

  /* Background */
  .bg-grid {
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.015) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.015) 1px, transparent 1px);
    background-size: 60px 60px;
    z-index: 0;
    pointer-events: none;
  }

  .glow {
    position: fixed;
    border-radius: 50%;
    filter: blur(150px);
    pointer-events: none;
    z-index: 0;
  }
  .glow-1 { width: 500px; height: 500px; background: var(--accent); opacity: 0.08; top: -150px; right: -100px; }
  .glow-2 { width: 400px; height: 400px; background: var(--accent-cyan); opacity: 0.05; bottom: 30%; left: -100px; }
  .glow-3 { width: 350px; height: 350px; background: #ff4da6; opacity: 0.04; bottom: -100px; right: 15%; }

  /* Nav */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    background: rgba(8, 8, 12, 0.75);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .logo {
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: 0.15em;
    text-decoration: none;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .logo-icon {
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-size: 1.1rem;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  .nav-links a {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--text); }
  .nav-cta {
    color: var(--accent-light) !important;
    background: rgba(124, 92, 255, 0.08);
    border: 1px solid rgba(124, 92, 255, 0.2);
    padding: 0.45rem 1.2rem !important;
    border-radius: 100px;
    transition: all 0.2s !important;
  }
  .nav-cta:hover {
    background: rgba(124, 92, 255, 0.15) !important;
    border-color: rgba(124, 92, 255, 0.4) !important;
  }

  /* Sections */
  section {
    position: relative;
    z-index: 1;
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 7rem 2rem;
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent-light);
    margin-bottom: 1rem;
  }

  h2 {
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.025em;
    margin-bottom: 1rem;
  }

  /* Buttons */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--accent-gradient);
    color: #fff;
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.85rem 2rem;
    border-radius: 100px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: all 0.25s;
    font-family: inherit;
  }
  .btn-primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 25px rgba(124, 92, 255, 0.35);
  }
  .btn-primary:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 0.85rem 1.5rem;
    border-radius: 100px;
    border: 1px solid var(--border);
    transition: all 0.2s;
  }
  .btn-ghost:hover {
    color: var(--text);
    border-color: var(--border-hover);
    background: var(--bg-card);
  }

  /* Hero */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 6rem;
  }
  .hero-content { max-width: 640px; }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--accent-light);
    background: rgba(124, 92, 255, 0.06);
    border: 1px solid rgba(124, 92, 255, 0.12);
    padding: 0.45rem 1rem;
    border-radius: 100px;
    margin-bottom: 2rem;
  }
  .badge-dot {
    width: 6px; height: 6px;
    background: #4ade80;
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  h1 {
    font-size: clamp(2.8rem, 7vw, 4.5rem);
    font-weight: 900;
    line-height: 1.08;
    letter-spacing: -0.035em;
    margin-bottom: 1.5rem;
  }
  .hero-highlight {
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-sub {
    font-size: 1.1rem;
    color: var(--text-secondary);
    line-height: 1.75;
    margin-bottom: 2.5rem;
    max-width: 480px;
  }
  .hero-sub strong { color: var(--text); }
  .hero-actions {
    display: flex;
    gap: 1rem;
    margin-bottom: 4rem;
    flex-wrap: wrap;
  }
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  .stat-value {
    display: block;
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }
  .stat-label {
    font-size: 0.78rem;
    color: var(--text-muted);
    font-weight: 500;
  }
  .stat-divider {
    width: 1px;
    height: 36px;
    background: var(--border);
  }

  /* How */
  .how-grid {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    margin-top: 3rem;
  }
  .how-step {
    flex: 1;
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .how-step.visible { opacity: 1; transform: translateY(0); }
  .how-connector {
    padding-top: 2rem;
    flex-shrink: 0;
  }
  .step-icon {
    width: 48px; height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 14px;
    background: rgba(124, 92, 255, 0.08);
    border: 1px solid rgba(124, 92, 255, 0.15);
    color: var(--accent-light);
    margin-bottom: 1.2rem;
  }
  .step-num {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--text-muted);
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
    display: block;
  }
  .how-step h3 {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
  }
  .how-step p {
    font-size: 0.88rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* Agents */
  .agents-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
    margin-top: 3rem;
  }
  .agent {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
