    </section>

    <section class="demo-chat-wrap">
      <div class="phone-frame">
        <div class="ph-notch"></div>
        <div class="wa">
          <div class="wa-top">
            <a href="/" class="wa-back">‹</a>
            <div class="wa-av" id="chat-avatar">S</div>
            <div>
              <div class="wa-name" id="chat-name">Sofía — Ventas</div>
              <div class="wa-status" id="chat-status">en línea</div>
            </div>
          </div>
          <div class="wa-msgs" id="chat-msgs">
            <div class="wa-day">Hoy</div>
            <div class="msg msg-out"><p>Hola, quiero saber más sobre su servicio</p><span class="time">Ahora</span></div>
          </div>
          <div class="wa-typing" id="typing" style="display:none">
