---
const scenarios = [
  { id: 'ventas', name: 'Sofía — Ventas', avatar: 'S', color: '#25D366' },
  { id: 'citas', name: 'Valentina — Citas', avatar: 'V', color: '#a855f7' },
  { id: 'soporte', name: 'Carlos — Soporte', avatar: 'C', color: '#3b82f6' },
];
---
