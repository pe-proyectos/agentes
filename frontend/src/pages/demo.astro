    .btn-glow{display:inline-flex;align-items:center;gap:.4rem;font-family:var(--font);font-size:.9rem;font-weight:700;color:var(--dark);background:var(--green);padding:.8rem 1.8rem;border-radius:100px;border:none;cursor:pointer;text-decoration:none;transition:all .25s;box-shadow:0 0 20px rgba(37,211,102,.15),0 4px 14px rgba(37,211,102,.2)}
