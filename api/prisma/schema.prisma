generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model WaitlistEntry {
  id        String   @id @default(uuid())
  name      String
  email     String
  company   String?
  agentType String   @map("agent_type")
  message   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("waitlist_entries")
}
